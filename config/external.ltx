[features]

; Manool: главный флаг режима разработчика для мода
; Разные отладочные функции, логи и т.д.
debug_mode = false

; В этом режиме артефакты с radiation_immunity > 1 будут соотвествующим образом усиливать радиацию от других артефактов.
; Т.е. красные 20% усилят радиацию других артефактов на 20%.
af_radiation_immunity_mod = true

; Этот режим меняет расчет коэффициента веса при прыжках. По умолчанию этот коэффициент рассчитывается с использованием веса,
; добавляемого броней. При включении этого режима, коэффициент веса будет рассчитываться так же, как он считается для ходьбы,
; т.е. без учета добавляемого веса от брони, т.е. переносимый вес в свитере + артефакты.
condition_jump_weight_mod = false

; Первый и второй слоты у любого оружия будут принудительно равнозначными.
; Сделано для удобства - сделал слоты в инвентаре одинаковыми по размеру, включил этот режим - и всё.
; Не нужно прописывать slot = 1,2 в десятках конфигов оружия.
forcibly_equivalent_slots = false

; Показывать расширенное контекстное меню для равнознычных слотов.
; Добавляет пункты переместить в каждый доступный слот.
slots_extend_menu = false

; Эффект раскачки оружия при движении.
; Для работы требуется секция с названием wpn_bobbing_effector. Пример настроек находится чуть ниже.
wpn_bobbing = false

; Показывать полоску состояния предметов в инвентаре, на его иконке.
; Включает поддержку аттрибута condition_progress_bar для dragdrop элементов
; и статиков condition_progess_bar и cell_item_text.
show_inv_item_condition = false

; Вычисление и использование правильного положения солнца, вместо позиции из погодных конфигов (для ТЧ-погоды, в случае использования ЗП-погоды - можно отключить в другом месте)
; !Данная опция добавлялась специально для OGSE-погоды, и на других погодах её включать не рекомендуются!
dynamic_sun_movement = false

; Убирает возможность назначать альтернативные кнопки. Т.е. убирает второй
; столбец в настройках и отключает консольную команду bind_sec.
remove_alt_keybinding = false

; Оружие на классе бинокля будет вести себя, как оружие, т.е. стрелять, показывать кол-во патронов на худе и т.п.
; Бинокль тоже будет показывать на худе кол-во патронов, 0 патронов.
; По сути это костыль для совместимости со старыми конфигами.
; А по-нормальному, нужному оружию можно добавить один из следующих параметров или оба, в зависимости от желаемого результата:
; scope_dynamic_zoom = true
; vision_present     = true
; и при прицеливании оно будет обладать свойствами бинокля. Еще нужно не забыть добавить в секцию этого оружия настройки для бинокля.
binoc_firing = false

; Выключает использование анимации рассматривания болта, подкидывания гранат и кручения ножа, т.е. anim_playing.
stop_anim_playing = true

; Включает коллизию с трупами. Это значит, что мобы будут тупить, уперевшись в тушку мутантами,
; т.к. не умеют обходить препятствия, а также гора трупов будет лагать.
corpses_collision = false

; Скрывать оружие при открытом диалоге, инвентаре и т.п. и обездвиживать актора при окрытии инвентаря.
more_hide_weapon = true

; Очистка списка задач при загрузке сейва от выполненных и проваленных
keep_inprogress_tasks_only = false

; Показывать порядковый номер перед фразами в диалогах. Для этой опции необходимо изменить talk.xml
; и добавить туда статик "num_text" в "question_item", как это сделано в ЗП. Порядковые номера соответствуют акселлераторам,
; назначенным этим фразам. Этот дефайн нужен только для отображения номеров. Акселлераторы работают без этого дефайна.
show_dialog_numbers = true

; Радиоактивные предметы в инвентаре будут увеличивать радиацию.
; Тоже самое касается предметов, которые ухудшают пси-здоровье, если включено af_psy_health
objects_radioactive = true

; Артефакты с нулевым состоянием работать не будут.
af_zero_condition = true

; Влияение артефактов на сытость будет работать.
af_satiety = true

; У артефактов будет свойство восстановления пси-здоровья.
af_psy_health = true

; Обрабатывать свойства артефактов для брони. Имеются ввиду всякие *_restore_speed.
outfit_af = true

; Отключает возможность смены уровня сложности. Будет единственный уровень сложности, тот, который стоит по умолчанию, т.е. мастер.
gd_master_only = false

; Включить авторастягиваемые прицельные сетки. Для этой опции текстуры прицельных сеток должны иметь разрешение 1600x1000 (либо любое другое с таким же соотношением?).
; Текстуры сеток будут автоматически подстраиваться под любое разрешение экрана.
scope_textures_autoresize = true

; Поддержка текстурных прицелов в ЗП стиле, когда scope_texture указывает на структуру в scopes.xml
; Поддержка расширена в виде wpn_crosshair_fallback, который будет использоваться для всех прицелов, который не нашли в scopes.xml
; для конкретных прицелов fallback можно отключить через wpn_crosshair_fallback = false в секции прицела или оружия
cop_style_scope_texture = true

; Включает слоты ножа, бинокля, шлема, биорадара, ПНВ, детектора артефактов, фонаря
ogse_new_slots = true

; ОГСЕ-специфичная система оружейного зума. С ванильным ТЧ несовместима без правки оружейных конфигов.
ogse_wpn_zoom_system = false

; Цена оружия будет включать в себя стоимость установленных аддонов
wpn_cost_include_addons = false

; блокировка перезарядки по время спринта.
lock_reload_in_sprint = false

; Усложненный режим перезарядки. Патроны из оружия возвращаются в инвентарь и оружие заряжается из другой пачки с макс. кол-вом патронов.
; Если часто перезаряжаться, то через некоторое время в инвентаре будут только не полные пачки и оружие будет заряжаться не полностью.
; В пару с этим режимом желательно использовать ручной перепаковщик патронов, вместо автоматического.
hard_ammo_reload = false

; Движковый перепаковщик патронов. с hard_ammo_reload - не совместим.
engine_ammo_repacker = false

; Флаг позволяющий для всех предметов реагировать на флаг FRuckDefault. Если флаг установлен, хабар будет подбираться в рюкзак,
; а не в слот по умолчанию. Что бы все работало нормально, нужно добавить
; default_to_ruck = false
; как минимум в секцию [bolt]. Иначе не получится доставать и кидать болт.
; А для надежности, еще и в [device_pda], [device_torch] и в секции гранат.
ruck_flag_preferred = true

; Sn: при подборе предмета с default_to_ruck = false, при попытке поставить его в слот, выбран будет первый из доступных (назначенный и незанятый).
use_all_available_slots_on_take = true

; Включить старый режим отрисовки слота костюма (иконка актора в костюме в полный рост)
old_outfit_slot_style = true

; Учитывать ли дефицит предмета при расчете его цены для покуки или продаж
; дефицит рассчитываеться при каждом обновлении ассортимента у торговца 
; формула = count * probability / spawn
; count, probability - кол-во и вероятность появления из конфига торговли
; spawn - сколько реально предметов было создано
; в секции [trade] можно определить граничные значения
; min_deficit_factor          = 1     ;минимально возможный дефицит при расчете цены на товар. при 1 - не будет влиять на цену.
; max_deficit_factor          = 1     ;максимально возможный дефицит при расчете цены на товар. при 1 - не будет влиять на цену.
;use_trade_deficit_factor = true

; В ПДА, для каждого задания будут показываться только следующее
; подзадание и все предыдущие. Т.е. подзадания будут открываться по
; мере выполнения.
;show_objectives_ondemand = true

; Подбирать можно только предметы, которые находятся на виду. Т.е. не
; подбирать предметы из закрытых шкафчиков.
pickup_check_overlaped = true

; Упрощенный режим стрельбы сталкеров. Не будут рисоваться партиклы гильз, дыма
; и при стрельбе у них не будет отдачи. Соотв. стрелять они будут точнее.
npc_simplified_shooting = true

; Включить автоперезарядку когда в оружии закончились патроны.
; Опция для совсем ленивых, не способных привыкнуть, что оружие само по себе перезаряжаться не может.
autoreload_wpn = false

;------------------------Глобальные настройки оружейных фич---------------------------
; Глобальные настройки сделаны для возможности простого включения оружейных фич
; при установке движка в какие либо моды, чтобы не править там 100500 конфигов оружия.
; У настроек из конфигов оружия приоритет выше.

; Инерция при прицеливании в механический прицел
default_allow_zoom_inertion = true

; Инерция при прицеливании в присоединяемые нетекстурные прицелы (3д прицелы и тп)
default_allow_scope_zoom_inertion = true

; Изменение HUD FOV когда игрок стоит вплотную к стене.
default_nearwall_on = true
;-------------------------------------------------------------------------------------

; Жажда - ещё один ресурс для ГГ наравне с голодом.
; Инструкция по адаптации к модам находится в Wiki в официальном репозитории движка.
actor_thirst = false

; Формат отображения кол-ва потронов на худе:
; {AE} - кол-во патронов в текущем оружии.
; {AC} - кол-во патронов для этого оружия в инвентаре.
; По умолчанию: {AE}/{AC}
;wpn_magazined_str_count_tmpl = {AE} ;В таком виде будет отображаться только кол-во патронов в оружии.

; Запрет на закрытие окна диалога, если диалог не завершен.
;disable_dialog_break = true

;Игнорировать ошибки парсинга xml (в ТЧ они встречаются даже в оригинальной игре)
skip_shoc_xml_errors = false

;Включить оригинальный псевдо-респавн артефактов аномалиями.
;Может кому-то он нужен, но на мой взгляд очень странная штука.
enable_spawn_artefacts = false

;Данную опцию надо отключить если используются шрифты для языков, которые неправильно обрабатывает новый парсер текста. Для китайского языка например.
;При отключении на юникодных шрифтах перестанет работать перенос слов между строками.
use_new_parse_text = true

;Включить поддержку ANSI-символов кириллицы для юникодных шрифтов. Полезно тем, что можно юзать эти шрифты но не надо конвертировать все ресурсы игры в utf-8
enable_ansi_aupport_for_mb_fonts = true

; Отключить анимацию шкал (состояний предметов) при их отображении,
; когда они плавно увеличиваются до своего значения.
no_progress_bar_animation = true

;Включает запреты действий когда актор что то делает с оружием (перезарядка и тп): нельзя поюзать что либо, аптечку, фонарик и тп.
busy_actor_restrictions = true

; NLC-стайл быстрые слоты
nlc_quick_slots = true

;Выключить пункт "выложить\выложить всё" контекстного меню из окна обыска
off_carbody_drop = true

[dragdrop]
; ЗП-стайл подсветки ячеек инвентаря зависят от текстуры ui\ui_grid.dds. В ней нарисованы 7 клеток, по порядку слева направо:
; 1. Обычная клетка инвентаря
; 2. При наведении курсора на предмет
; 3. Подсветка предметов, находящихся на поясе и в слотах в окнах торговли и обыска ( если включена опция highlight_equipped )
; 4. При клике по предмету (соотв. при клике по оружию подсвечиваются все доступные ему патроны и аддоны, и наоборот)
; 5. Подсветка непродаваемых предметов в окне торговли
; 6. Подсветка доступных слотов для предмета
; 7. Заблокированные клетки для артефактов, если их кол-во регулируется в зависимости от надетого костюма

; подкрашивать иконки выбранного предмета/патронов/аддонов/оружия
colorize_ammo = true
; цвет подкрашенной иконки выбранного предмета/патронов/аддонов/оружия
color_ammo = 0, 128, 0, 255 ;RGBA

; В окнах торговли и обыска подкрашивать иконки предметов, которые находятся в слотах и на поясе
highlight_equipped = true
; цвет подкрашенной иконки предметов в слотах и на поясе
color_equipped = 255, 225, 0, 255 ;RGBA ;Если вдруг вообще надо убрать подкраску - можно указать 255,255,255,255

; цвет подкрашенной иконки непродаваемых предметов
color_untradable = 124, 0, 0, 255 ;RGBA ;Если вдруг вообще надо убрать подкраску - можно указать 255,255,255,255

; предметы на поясе и в слотах будут не продаваемыми
equipped_untradable = true

; Подсветка при наведении мыши на предмет будет иметь самый высокий приоритет по отношению к другим подсветкам. Если выключено - самый низкий.
select_mode_1342 = true


[user_spots]
; Переопределить тип метки, используемой для пользовательских меток на карте. По умолчанию используется red_location
;spot_type = red_location
spot_type = yellow_flag_location


; Настройки для wpn_bobbing
; [wpn_bobbing_effector]
; controller_amplitude = 0.002
; limp_amplitude = 0.011
; limp_speed     = 4.6
; run_amplitude  = 0.0075
; run_speed      = 6.74
; walk_amplitude = 0.005
; walk_speed     = 6.26
; crouch_k = 0.75
; zoom_k   = 0.1
; scope_zoom_k = 0.1


[engine_callbacks]
; ui_item_info_callback( UIDesc ) вызывается перед заполнением статика
; описания предмета в инвентаре. UIDesc - это SCrollView, в который
; можно добавлять свои статики.
;ui_item_info_callback = engine_callbacks.ui_item_info_callback

; ui_item_text_info_callback(desc, item) вызывается перед выводом текста описания
; предмета. Чтобы изменить текст, нужно вернуть функцию с изменённым текстом.
ui_item_text_info_callback = engine_callbacks.ui_item_text_info_callback

; ui_actor_info_callback( list, obj ) вызывается при обновлении
; outfit_info в инвентаре ГГ. list - CUIScrollView (xml
; outfit_info:scroll_view in inventory_new.xml). obj - текущий костюм
; ГГ, если нету - nil.
;ui_actor_info_callback = engine_callbacks.ui_actor_info_callback

; trade_purchase_item_process( npc, sobj ) вызывается для каждого
; созданного предмета при обновлении ассортимента торговца. npc -
; trader, sobj - серверный объект предмета. Вариант использования:
; включать аддоны для оружия и подобное для торгуемых вещей.
;trade_purchase_item_process = engine_callbacks.trade_purchase_item_process

; trade_get_buy_price для расчета цены покупки и trade_get_sell_price
; для расчета цены продажи торговцем. По аналогии с коллбеками из
; ЗП. Позволяют изменять цены динамически, и не плодить постоянно
; новые секции для sell_condition и buy_condition.
;
; Сигнатура: (npc, section, result, original, deficit_factor)
;
; npc            - объект торговец
; section        - секция предмета
; result         - конечная цена которую рассчитал движок
; original       - цена без учета дефицита
; deficit_factor - факто дефицита рассчитанный движком, с учетом
; ограничений min\max
trade_get_buy_price  = engine_callbacks.trade_get_buy_price
trade_get_sell_price = engine_callbacks.trade_get_sell_price

; Вызывается движком из CDangerManager::add() и разрешает или
; запрещает добавлять этот danger. Возвращаемое значение, true/false,
; показывает, можно или нельзя добавлять этот danger.
;
; on_before_add( npc, mem_obj, pos, lvl_time, danger_type, perceive_type )
;
;danger_on_before_add = dsh_danger.on_before_add

; Вызывается движком из CEnvironment::SelectEnvs() сразу после
; переключения на новую погодную секцию.
on_change_weather = engine_callbacks.on_engine_weather_change


; Коллбек вызываеться перед поднятием предмета ГГ
; Если вернуть false - движок не будет поднимать предмет
;actor_on_item_before_pickup = engine_callbacks.actor_on_item_before_pickup


; Коллбек вызывается перед перемещением в слот предмета
; Если вернуть false - движок не позволит переместить предмет
actor_on_item_before_put_in_slot = engine_callbacks.actor_on_item_before_put_in_slot

; Коллбек вызывается перед показом предмета в окне обыска
; Если вернуть false - движок не позволит показать предмет
; actor_on_item_before_show_in_carbody(obj, b_our)
; obj - предмет, b_our - флаг: true - инвентарь ГГ, false - инвентарь объекта обыска
actor_on_item_before_show_in_carbody = engine_callbacks.actor_on_item_before_show_in_carbody

; Коллбек вызывается перед показом предмета в окне торговли
; Если вернуть false - движок не позволит показать предмет
; actor_on_item_before_show_in_trade(obj, b_our)
; obj - предмет, b_our - флаг: true - окно ГГ, false - окно торговца
; actor_on_item_before_show_in_trade = engine_callbacks.actor_on_item_before_show_in_trade

ui_task_time_remaning = engine_callbacks.ui_task_time_remaning

; Переопределение секции [capture] из визуалов брони для актора.
; А то в этих визуалах такой бардак. У некоторых даже и кастомной даты нет.
[actor_capture]
bone           = bip01_tail ; bone for capture
distance       = 0.3   ; less this distance between bone and capture taget object is captured
time_limit     = 3     ; max time for trying to capture object "sec"
pull_distance  = 1.4   ; max distance target can be pulled
pull_force_factor = 4  ; force factor that applied to target to pull
velocity_scale = 1 ;0.022 ; velocity scale for pulling 1- normal
capture_force  = 6500  ; max force for holding tagett

; Тоже самое для сталкеров
[stalker_capture]:actor_capture


; Чтение patrol_path из ltx файлов напрямую
; Формат файлов такой же, как выдает acdc при распаковке.
; При загрузке, пути из файла будут заменять пути из all.spawn с таким же именем.
; Можно вообще убрать пути из своего all.spawn и все перенести в ltx файлы, для удобства.
[engine_custom_spawn]
waypoints_file = waypoints.ltx ; путь к файлу в $game_config$


; Замена шейдеров в визуалах
[vis_shaders_replace]
; шейдер тесселяции: models\model -> models\model_pn. Должен присутствовать в shaders.xr!
dynamics\weapons\wpn_hand = models\model,models\model_pn, models\weapons,models\model_pn
actors   = models\model,models\model_pn, models\weapons,models\model_pn, models\artefact,models\model_pn, models\artefact2,models\model_pn
monsters = models\model,models\model_pn


[hud_movement_layers]
;types: 0 = aim_walk, 1 = aim_crouch, 2 = crouch, 3 = walk, 4 = run, 5 = sprint
;type                    path                           speed   power
movement_layer_0        = movement\aim_walk.anm,     1,         0.85
movement_layer_1        = movement\aim_walk.anm,     0.75,     0.5
movement_layer_2        = movement\newwalk.anm,      1,      0.1
movement_layer_3        = movement\newwalk.anm,      1,      0.1
movement_layer_4        = movement\newwalk.anm,      1.25,     0.125
movement_layer_5        = movement\newrunreload.anm, 1,      0.15


