;-- Главный грабитель
[logic@gar_bandit_blokpost_robber1]
active = walker@gar_bandit_blokpost_robber1
combat_ignore = combat_ignore@gar_bandit_blokpost
on_hit = hit@gar_bandit_blokpost
on_death = death@gar_bandit_blokpost

[walker@gar_bandit_blokpost_robber1]
path_walk = robber1_1_walk
path_look = robbers_1_look
combat_ignore_cond = {-gar_bandit_blokpost_pass_fire =fighting_actor}
danger = danger_condition@gar_bandit_blokpost
def_state_moving1 = rush
def_state_moving2 = rush
def_state_moving3 = rush
meet = no_meet
on_signal = start | {-gar_bandit_blokpost_pass_on =actor_in_zone(gar_bandit_blokpost_online_rest)} walker@gar_bandit_blokpost_robber1_2, {-gar_bandit_blokpost_pass_on =actor_in_zone(gar_bandit_blokpost_online_rest_from_bar)} walker@gar_bandit_blokpost_robber1_2_bar
