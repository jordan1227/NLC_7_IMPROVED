def_state_moving1 = rush
def_state_moving2 = rush
def_state_moving3 = rush
meet = no_meet
on_signal = start2 | {-gar_bandit_blokpost_pass_on} remark@gar_bandit_robber1_see_actor
on_info = {+gar_bandit_blokpost_pass_on} walker@gar_bandit_blokpost_robber1_4

