;-------------------------------------------------------------------------------------------------
;-- Military Freedom base
;-------------------------------------------------------------------------------------------------
;-------------------------------------------------------------------------------------------------
;normal state
[danger@mil_freedom]
ignore_distance = 0
ignore_types = corpse

[hit@mil_freedom]
on_info = %+mil_freedom_under_attack%

[death@mil_freedom]
on_info = %+mil_freedom_under_attack%
;-------------------------------------------------------------------------------------------------
;------------------------------------- Lukash --------------------------------------
[logic@mil_freedom_lukash]
active = walker1@mil_freedom_lukash
on_hit = hit@mil_freedom
on_death = death@mil_freedom_lukash

[death@mil_freedom_lukash]
on_info = %+mil_lukash_dead +mil_freedom_under_attack%

[walker1@mil_freedom_lukash]
path_walk = leader_walk
path_look = leader_look
meet = meet@mil_freedom_lukash
danger = danger@mil_freedom

[meet@mil_freedom_lukash]
meet_state = 2|ward
meet_state_wpn = 2|ward
victim = 2|actor
victim_wpn = 2|actor
use = true
use_wpn = false
meet_dialog = mil_leader_new_start_dialog

;------------------------------------- Повар --------------------------------------
[logic@mil_freedom_cook]
active = walker1@mil_freedom_cook
on_hit = hit@mil_freedom
on_death = death@mil_freedom_cook

[death@mil_freedom_cook]
on_info = %+mil_cook_dead +mil_freedom_under_attack%

[walker1@mil_freedom_cook]
path_walk = cook_walk1
path_look = cook_look1
meet = meet@mil_freedom_cook
on_info = {+mil_freedom_under_attack} camper1@mil_freedom_cook
on_info2 = {+mil_freedom_cook_drink_3 -mil_freedom_cook_wakeup} walker2@mil_freedom_cook
on_info3 = {+mil_freedom_cook_wakeup} walker3@mil_freedom_cook
danger = danger_condition@mil_freedom_cook

[walker2@mil_freedom_cook]
path_walk = cook_walk1
path_look = cook_look1
meet = meet@mil_freedom_cook
on_timer = 3000 | walker4@mil_freedom_cook
danger = danger_condition@mil_freedom_cook

[walker4@mil_freedom_cook]
path_walk = cook_sleep
path_look = cook_look1
meet = no_meet
on_info = {+mil_freedom_under_attack} camper1@mil_freedom_cook
on_timer = 2000 | sleeper@mil_freedom_cook
danger = danger_condition@mil_freedom_cook

[sleeper@mil_freedom_cook]
path_main = cook_sleep
meet = no_meet
wakeable = false
on_info = {+mil_freedom_cook_wakeup} walker3@mil_freedom_cook
danger = danger_condition@mil_freedom_cook

[walker3@mil_freedom_cook]
path_walk = cook_walk1
path_look = cook_look1
meet = meet@mil_freedom_cook
on_info = {+mil_freedom_under_attack} camper1@mil_freedom_cook
danger = danger_condition@mil_freedom_cook

[meet@mil_freedom_cook]
use = true
use_wpn = true
meet_state = 5|sit
victim = 5|actor
victim_wpn = 5|actor
meet_dialog = mil_cook_start_dialog

[camper1@mil_freedom_cook]
path_walk = cook_walk2
path_look = cook_look2
radius = 0
on_info = {-mil_freedom_under_attack} walker1@mil_freedom_cook
no_retreat = true
danger = danger_condition@mil_freedom_cook

[danger_condition@mil_freedom_cook]
ignore_distance = 1
ignore_types = corpse

