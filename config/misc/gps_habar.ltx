[amk_metka]
gps_habar_on		= true	; вкл\выкл режима работы маячка на отображение списка хабара при помещении его тайник. Собственно выключатель всего аддона.

show_quantity		= true	; показывать кол-во хабара.
color_and_sort_list	= true  ; сортировать и раскрашивать список с хабаром

activity_time		= 168	; время работы маячка без подзарадяки (в часах). 0 - позрадяка не требуется.
warning_cond		= 10	; с какого процента кондиции предупреждать о низком уровне заряда и менять цвет иконки

set_label_on_npc	= true	; ставить-ли метку на NPC при продаже ему маячка.
show_health			= false	; показывать на плане состояние помеченного сталкера (жив\погиб).
warning_on_death	= false	; предупреждать при гибели помеченного сталкера

