[logic@mil_dolg_skull]
active = walker1@mil_dolg_skull
on_death = death@mil_dolg_skull
combat_ignore = combat_ignore@mil_dolg

[death@mil_dolg_skull]
on_info = {=killed_by_actor} %+mil_scull_dead +gg_kill_cherep%, %+mil_scull_dead%

[walker1@mil_dolg_skull]
path_walk = path_walk1
path_look = path_look1
meet = meet@mil_dolg_skull
danger = danger_condition@mil_dolg
combat_ignore_cond = {=check_fighting(704)}
on_actor_dist_le_nvis = 15 | walker3@mil_dolg_skull
wounded = wounded@ignore_scull

[walker3@mil_dolg_skull]
path_walk = path_walk1
path_look = path_look1
meet = meet@2mil_dolg_skull
danger = danger_condition@mil_dolg
combat_ignore_cond = {=check_fighting(704)}
wounded = wounded@ignore_scull

[meet@mil_dolg_skull]
meet_dialog = mil_dolg_skull_dialog
use = true
use_wpn = true
victim = 15|actor
victim_wpn = 15|actor
meet_state = 40|hello_wpn@mil_cherep_hi|20|ward
meet_state_wpn = 40|hello_wpn@mil_cherep_hi|20|ward

[meet@2mil_dolg_skull]
meet_dialog = mil_dolg_skull_dialog
use = true
use_wpn = true
victim = 15|actor
victim_wpn = 15|actor

[wounded@ignore_scull]
hp_state        = 0|wounded_heavy@help_heavy
hp_state_see    = 0|wounded_heavy@help_heavy
hp_victim       = 0|nil
hp_fight        = 0|false
hp_cover        = 0|false
