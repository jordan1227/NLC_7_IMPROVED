[medkit_use]:animator_base
item_attached							 = true
item_visual             				 = dynamics\weapons\wpn_eat\aptechki\wpn_aptechka_basic_hud.ogf

hands_orientation						 = 0.000000,0.000000,0.000000
hands_orientation_16x9					 = 0.000000,0.000000,0.000000
hands_position	                         = 0.000000,-0.010000,0.030000
hands_position_16x9                      = 0.000000,-0.010000,0.030000

sound_1   								 = interface\item_usage\medkit_use

anm_show								 = apteka

dof                                      = 0.0, 0.5, 5, 2.8

disable_ui_input						 = true

exo_anim_section 						 = medkit_use_exo
right_lua_callback						 = animator_callbacks.spawn_trash
trash_object                             = medkit_trash
modify_sect_lua_callback                 = animator_callbacks.modify_exo_sect

[medkit_trash]:trash_base
visual                        			 = dynamics\devices\dev_aptechka\dev_aptechka_trash.ogf

;направление, в котором предмет отбрасывается
throw_dir = right
;смещение точки спавна относительно камеры
throw_offset_y = -0.6	//вверх-вниз
throw_offset_x = -0.2	//вперед-назад
throw_offset_z =  0.6	//положительные - в сторону броска, отрицательное - в противоположную

;throw_impulse_y = -90
;throw_impulse_z = 180

throw_impulse_y = -9
throw_impulse_z = 18

[medkit_use_army]:medkit_use
item_visual             				 = dynamics\weapons\wpn_eat\aptechki\wpn_aptechka_army_hud.ogf
exo_anim_section 						 = medkit_use_army_exo_hud

[medkit_use_scientic]:medkit_use
item_visual             				 = dynamics\weapons\wpn_eat\aptechki\wpn_aptechka_scientific_hud.ogf
exo_anim_section 						 = medkit_use_scientic_exo_hud

