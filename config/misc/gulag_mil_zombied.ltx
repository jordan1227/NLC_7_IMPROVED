;-------------------------------------------------------------------------------
; Гулаг зомбированных у выхода на Радар
;-------------------------------------------------------------------------------

;-------------------------------------------------------------------------------
; Zombie 1
;-------------------------------------------------------------------------------
[logic@mil_zombie1]
active = walker@mil_zombie1_stop

[walker@mil_zombie1_stop]
path_walk = walk1_stop
path_look = look1
on_info = {+mil_fblockpost_rush_wave1} walker@mil_zombie1

[walker@mil_zombie1]
path_walk = walk1
path_look = look1
sound_idle = state

