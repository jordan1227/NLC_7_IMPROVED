[logic]
active = ph_door@locked

[ph_door@locked]
locked = true
closed = true
snd_open_start = metal_small_open
snd_close_start = metal_small_close_start
snd_close_stop = metal_small_close_stop
on_info = {+mil_stalker_casset_info +mil_stalker_casset_end_info -mil_cook_key_info} ph_door@closed

[ph_door@closed]
closed = true
locked = false
on_info = {+mil_cook_key_info} ph_door@locked
on_use = {-mil_cook_treasure_info} %+mil_cook_treasure_info =sak.povar_key_rel()% ph_door@open, ph_door@open

[ph_door@open]
closed = false
locked = false
on_use = ph_door@closed