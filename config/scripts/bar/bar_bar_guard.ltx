[logic]
active = walker@guard_door
on_death = death@garik_death

[death@garik_death]
on_info = {=killed_by_actor} %=sak.gg_bandit() +garik_death%, %+garik_death%

[walker@guard_door]
path_walk = bar_bar_guard_door_walk
path_look = bar_bar_guard_door_look
on_info = {+bar_barman_need_room} walker@guard_nodoor
danger = danger_condition
on_actor_in_zone = bar_bar_room_area | {-bar_barman_need_room -bar_dolg_territory_kill} %+bar_dolg_territory_kill =sak.gg_bandit() =bar_territory_logic%
meet = meet@1

[meet@1]
meet_state = 4 | guard@{+bar_barman_need_room} bar_guard_enter,bar_guard_stop  
meet_state_wpn = 4 | guard@threat_weap
victim 		= nil
victim_wpn  = nil
use			= true
use_wpn		= false
abuse   = true
precond = visibility

[danger_condition]
ignore_distance = 0

[walker@guard_nodoor]
path_walk = bar_bar_guard_nodoor_walk
path_look = bar_bar_guard_nodoor_look
def_state_standing = ward
def_state_moving1 = walk
def_state_moving2 = walk
def_state_moving3 = walk
on_info = {-bar_barman_need_room} walker@guard_door
danger = danger_condition
meet = no_meet