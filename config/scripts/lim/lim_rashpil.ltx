[smart_terrains]
none = true

[logic]
active = walker@lim_rashpil
combat_ignore = combat_ignore@lim_rashpil
on_hit = hit@lim_rashpil
on_death = death@lim_rashpil
danger = danger_condition@lim_rashpil

[walker@lim_rashpil]
path_walk = lim_rashpil_walk
path_look = lim_rashpil_look
on_actor_dist_le = 6 | remark@lim_rashpil
meet = meet@lim_rashpil
combat_ignore_cond = {-lim_lager2_bandits_fire =fighting_actor}
danger = danger_condition@lim_rashpil

[remark@lim_rashpil]
anim = guard
target = actor
snd = val_dram_glavn
meet = no_meet
on_signal = sound_end| walker2@lim_rashpil
on_timer = 5000| walker2@lim_rashpil
combat_ignore_cond = {-lim_lager2_bandits_fire =fighting_actor}
danger = danger_condition@lim_rashpil

[walker2@lim_rashpil]
path_walk = lim_rashpil_walk
path_look = lim_rashpil_look
meet = meet@lim_rashpil
combat_ignore_cond = {-lim_lager2_bandits_fire =fighting_actor}
danger = danger_condition@lim_rashpil

[meet@lim_rashpil]
victim = 3|actor
victim_wpn = 3|actor
meet_state 		= 5|guard
meet_state_wpn 	= 5|guard
use = true
use_wpn = false
meet_dialog	= lim_rashpil_start_dialog 

[combat_ignore@lim_rashpil]
combat_ignore_cond = {-lim_lager2_bandits_fire =fighting_actor}

[hit@lim_rashpil]
on_info = {-lim_lager2_bandits_fire =hit_by_actor} %+lim_lager2_bandits_fire =sak.mil_abuse()%

[death@lim_rashpil]
on_info = {-lim_lager2_bandits_fire =killed_by_actor} %+lim_lager2_bandits_fire +val_dram_bandit_glavn_umer =sak.mil_abuse()%, %+val_dram_bandit_glavn_umer%

[danger_condition@lim_rashpil]
ignore_distance = 5
ignore_types = corpse