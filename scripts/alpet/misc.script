function misc.easy_anom(section, gi, radius)
 -- !!! ôóíęöč˙ ďđčíčěŕĺň ňŕáëč÷íűĺ ęîîđäčíŕňű !!!
 local shapes = {}
 shapes[1] = {}
 
 if radius > 0 then    
    shapes[1].shtype = 0
    shapes[1].radius = radius
    shapes[1].center = vector():set( 0, 0.1, 0 )
 else
    -- wprintf("[~T].~C07 #WARN:~C07 misc.easy_anom  = %f ", radius)    
