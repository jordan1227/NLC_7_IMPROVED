function actor_binder:reinit()
	object_binder.reinit(self)
	local npc_id = self.object:id()
	db.storage[npc_id] = {}
	self.st = db.storage[npc_id]
	self.st.pstor = nil
	self.next_restrictors_update_time = -10000
	self.object:set_callback(callback.inventory_info, self.info_callback, self)
	self.object:set_callback(callback.article_info, self.article_callback, self)
	self.object:set_callback(callback.on_item_drop, self.on_item_drop, self)
	self.object:set_callback(callback.on_item_take, self.on_item_take, self)
	self.object:set_callback(callback.trade_sell_buy_item, self.on_trade, self) -- for game stats
	--self.object:set_callback(callback.actor_sleep, self.sleep_callback, self)
	self.object:set_callback(callback.task_state, self.task_callback, self)
	--self.object:set_callback(callback.map_location_added, self.map_location_added_callback, self)
	-- self.object:set_callback(callback.level_border_enter, self.level_border_enter, self)
	-- self.object:set_callback(callback.level_border_exit, self.level_border_exit, self)
	self.object:set_callback(callback.take_item_from_box, self.take_item_from_box, self)
	self.object:set_callback(callback.use_object, self.on_use_object, self)
	self.object:set_callback(callback.saw_object, self.on_saw_object, self)
	self.object:set_callback(callback.death,self.death_callback,    self)
	self.object:set_callback(callback.on_before_save, self.on_before_save, self)
	-- self.object:set_callback(callback.on_actor_weapon_fire, self.on_actor_weapon_fire, self)
	self.object:set_callback(callback.on_key_press, self.on_key, self)
	self.object:set_callback(callback.on_key_release, self.on_key_free, self)
	self.object:set_callback(callback.on_key_hold, self.on_key_hold, self)
	self.object:set_callback(callback.on_belt, self.item_to_belt, self)
	self.object:set_callback(callback.on_ruck, self.item_to_backpack, self)
	self.object:set_callback(callback.on_slot, self.item_to_slot, self)
	self.object:set_callback(callback.on_cell_item_focus, self.on_cell_item_focus, self)
	self.object:set_callback(callback.on_cell_item_focus_lost, self.on_cell_item_focus_lost, self)
	self.object:set_callback(callback.on_cell_item_mouse, self.on_cell_item_mouse, self)
	self.object:set_callback(callback.on_mouse_wheel, self.on_wheel_rotation, self)
	self.object:set_callback(callback.entity_alive_before_hit, self.before_hit_callback, self)
	self.object:set_callback(callback.on_footstep, self.on_footstep, self)
	self.object:set_callback(callback.on_actor_weapon_fire, self.on_actor_weapon_fire, self)
	self.object:set_callback(callback.on_actor_weapon_zoom_in, self.on_actor_weapon_zoom_in, self)
	self.object:set_callback(callback.on_actor_weapon_zoom_out, self.on_actor_weapon_zoom_out, self)
	self.object:set_callback(callback.on_actor_weapon_reload, self.on_actor_weapon_reload, self)
	self.object:set_callback(callback.on_actor_weapon_reload_end, self.on_actor_weapon_reload_end, self)
	self.object:set_callback(callback.on_before_use_item, self.on_before_use_item, self)
	self.object:set_callback(callback.on_before_switch_torch, self.on_before_switch_torch, self)
	self.object:set_callback(callback.on_before_switch_nv, self.on_before_switch_nv, self)
	self.object:set_callback(callback.on_art_anim_activation_end, self.on_art_anim_activation_end, self)
end

function actor_binder:on_before_switch_nv(status)
	self.am:call("on_before_switch_nv", status)
end

function actor_binder:on_before_switch_torch(status)
	self.am:call("on_before_switch_torch", status)
end

function actor_binder:on_before_use_item(item)
	if not item then return end
	local sobj = alife():object(item:id())
	if not sobj then return end

	self.am:call("on_actor_before_use", item, sobj)
end

function actor_binder:on_actor_weapon_fire(obj)
	self.am:call("on_actor_weapon_fire", obj)
end

local plyAimSound
function actor_binder:on_actor_weapon_zoom_in(obj)
	self.am:call("on_actor_weapon_zoom_in", obj)
	--
	local ct = time_global()
	if not plyAimSound or ct > plyAimSound then
		local snd = xr_sound.get_safe_sound_object("weapons\\aimin\\aim_in_" .. tostring(lua_random(10)))
		snd:play(db.actor, 0, sound_object.s2d)
		plyAimSound = ct + 175
	end
end

function actor_binder:on_actor_weapon_zoom_out(obj)
	self.am:call("on_actor_weapon_zoom_out", obj)
	--
	local ct = time_global()
	if not plyAimSound or ct > plyAimSound then
		local snd = xr_sound.get_safe_sound_object("weapons\\aimout\\aim_out_" .. tostring(lua_random(10)))
		snd:play(db.actor, 0, sound_object.s2d)
		plyAimSound = ct + 175
	end
end

function actor_binder:on_footstep(obj, p)
	self.am:call("on_footstep", obj, p)
end

function actor_binder:on_actor_weapon_reload(wpn)
	if wpn then
		local a_t = vergas_lib.set_pr_from_config_str(wpn:section(),"weapon_type")
		if a_t ~= "heavy" then return end
		local jam = wpn:get_weapon():misfire_status()
		-- log2("misfire_status [%s] for [%s]",tostring(jam),wpn:name())
		if jam then
			local t = get_value("jammed_wpn",{})
			if t[wpn:name()] == nil then
				t[wpn:name()] = true
				set_value("jammed_wpn",t)
			end
		end
	end
end

function actor_binder:on_actor_weapon_reload_end(wpn)
	-- self.am:call("on_actor_weapon_reload_end", wpn)
	local sec = wpn:section()
	local a_t = vergas_lib.set_pr_from_config_str(sec,"weapon_type")
	if a_t ~= "heavy" or sec == "wpn_rpg7" then
		return
	else
		--log2("actor_binder:on_actor_weapon_reload_end called for [%s] with sec [%s]", wpn:name(), sec)
		local t = get_value("jammed_wpn",{})
		if t[wpn:name()] then
			t[wpn:name()] = nil
			set_value("jammed_wpn",t)
			return
		end
		local pouch_content = razgruzka.load_pouch_content("ui_cheat_podsumok")
		pouch_content:clear()
		pouch_content:save()
		schedule.add("inv_upd_imit1","inv_buttons_use.imitation_opening_inventory()", 100)
		schedule.add("inv_upd_imit2","inv_buttons_use.imitation_closing_inventory()", 200)
	end
end

function actor_binder:before_hit_callback(hit_data)
	local obj = level.object_by_id(hit_data.who_id)
	if obj then -- ЕЯКХ ЕЯРЭ БХМНБМХЙ УХРЮ
		if -- ОПНБЕПЪЕЛ СЯКНБХЪ ХЦМНПХПНБЮМХЪ СПНМЮ НР ДПСФЕЯРБЕММНЦН НЦМЪ
			obj:id() ~= self.object:id() and obj:is_stalker() and not obj:is_relation_enemy(self.object) then
			local enemy = obj:best_enemy()
			if (not enemy) or enemy:id() ~= self.object:id() then
				-- ОНДЯРПЕКХК ДПСЦ, ХЦМНПХПСЕЛ
				hit_data.ignore_hit = true
				log3("~~[%s]: ignore ff from [%s]", script_name(), obj:name())
			end
		end
	end
	if not hit_data.ignore_hit then
		self.am:call("on_actor_before_hit", self.object, hit_data, self)
	end
end

local function check_pda_conditions()
	local pda = db.actor:object("device_pda")
	if not pda then return 'nil', nil, nil, nil, nil end
	local is_3d_pda = get_console():get_string("g_3d_pda")
	local lvl_aver = level.name() == "aver"
	local flag1 = pda and lvl_aver
	local flag2 = not pda and db.actor:object("device_pda_npc_gg")
	local in_safe_zone = not amk_anoms.check_coordinates(db.actor:position())
	local cond = (pda and pda:condition()) or 0
	return flag1, flag2, in_safe_zone, is_3d_pda, cond
end

local function pda_cb()
	local flag1, flag2, in_safe_zone, is_3d_pda, _ = check_pda_conditions()
	if flag1 == 'nil' then return end
	if is_3d_pda == 'on' then return end
	if flag1 and not flag2 then
		if in_safe_zone then return end
		if pda_on then
			pda_noise.on_info("off")
		else
			pda_noise.on_info("on")
		end
	elseif flag2 then
		if pda_on then
			pda_noise.on_info("off")
		else
			pda_noise.on_info("on")
		end
	end
end

local is_busy_on = get_bool("features", "busy_actor_restrictions", false)
function is_busy_actor_restrictions()
	local wpn = db.actor:active_item()
	if not db.actor:alive() then return true end
	if wpn and wpn:is_hud_item() and is_busy_on and wpn:get_hud_item_state() ~= global_flags.eIdle then return true end
	return false
end

local gren_fix_process
local key_actions = {
	[key_bindings.kNEW_INVENTORY] = {
		func = function()
			if is_busy_actor_restrictions() then return end
			local wnd = windows.get_active()
			if db.actor:is_talking() or wnd then

				if wnd and not level.main_input_receiver() then
					log2("lost actve_dialog object detected")
					if wnd.CloseDialog then
						wnd:CloseDialog()
					elseif wnd.on_quit then
						wnd:on_quit()
					else
						windows.set_active(false)
					end
				else
					return
				end
			end

			local gadget = used_items.can_use_gadget()

			if gadget and (not self_weapon_hide) and not get_actor_obj():IsDetectorActive() and not db.actor:ph_capture() then
				local activ = db.actor:active_slot()
				if activ == NO_ACTIVE_SLOT then
					used_items.used_inventory()
				end
			end
		end
	},
	[key_bindings.kMASK_CONTROL] = {
		func = function()
			if is_busy_actor_restrictions() then return end
			if used_items.can_use_gadget() and self_weapon_hide == false then
				vergas_masks.on_off_mask()
			end
		end
	},
	[key_bindings.kNEW_QUICKSAVE] = {
		func = function()
			-- if is_busy_actor_restrictions() then return end
			dsh.make_quicksave()
		end
	},
	[key_bindings.kOPN_FLASK] = {
		func = function()
			if is_busy_actor_restrictions() then return end
			if used_items.can_use_gadget() and self_weapon_hide == false and not db.actor:is_talking() and not get_actor_obj():IsDetectorActive() then
				used_items.used_flask_army(false)
			end
		end
	},
	[key_bindings.kINV_CB] = {
		func = function()
			if not db.actor:alive() then return end
			if used_items.can_use_gadget() and self_weapon_hide == false and not db.actor:is_talking() and not level.main_input_receiver() then
				vergas_rucksack.drop_rykzack()
			end
		end
	},
	[key_bindings.kUSE_ANTIRAD] = {
		func = function()
			if is_busy_actor_restrictions() then return end
			if used_items.can_use_gadget() and self_weapon_hide == false and not db.actor:is_talking() then
				vergas_medical_elastic.use_antirad()
			end
		end
	},
	[key_bindings.kUSE_ENERGY] = {
		func = function()
			if is_busy_actor_restrictions() then return end
			if used_items.can_use_gadget() and self_weapon_hide == false and not db.actor:is_talking() then
				allcore_hide.UseEnegry()
			end
		end
	},
	[key_bindings.kUSE_INFO] = {
		func = function()
			if
				(sak_dialog.have_razgruzka() or sak_dialog.have_razgruzka_new() or sak_dialog.podsumok_have()) and
					used_items.can_use_gadget() and
					db.actor:alive() and
					not db.actor:is_talking() and
					self_weapon_hide == false
			 then
				razgruzka.use_info()
			end
		end
	},
	[key_bindings.kNAME_SAVE] = {
		func = function()
			-- if is_busy_actor_restrictions() then return end
			if not ogse_campfire.check_near_en_flame() then return end
			local levname = translate(level.name())
			local days = timers.Get_Game_Days()
			local hours = level.get_time_hours()
			local minutes = level.get_time_minutes()
			local savename = dsh.safe_file_name(string.format("%s %u. %02u-%02u. %s", translate("ui_mm_save_day"), days, hours, minutes, levname))
			cmd("save " .. savename)
		end
	},
	[key_bindings.kNEW_QUICKLOAD] = {
		func = function()
			cmd("load_last_save")
		end
	},
	[key_bindings.kWPN_4] = {
		func = function()
			if not db.actor:alive() then return end
			local slot = db.actor:active_slot()
			if slot == 3 or slot == NO_ACTIVE_SLOT or gren_fix_process then return end
			gren_fix_process = true
			db.actor:activate_slot(NO_ACTIVE_SLOT)
			dsh.wait_condition(function() return not db.actor:active_item() end, function()
				db.actor:activate_slot(3)
				gren_fix_process = nil
			end)
		end
	},
	[key_bindings.kACTIVE_JOBS] = {
		func = function()
			pda_cb()
		end
	},
	[key_bindings.kMAP] = {
		func = function()
			pda_cb()
		end
	},
	[key_bindings.kPDA_CLOCK] = {
		func = function()
			pda_cb()
		end
	}
}

