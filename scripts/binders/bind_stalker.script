function log_init_stage(ctx)
	db.init_stage = db.init_stage + 1
	if nil == ctx then ctx = "?" end
	if db.init_stage < 100 then
		wprintf("[~T/~U/~B].~C0B #PERF:~C07 actor_binder init_stage =~C0D %d~C07, context =~C0A %s~C07", db.init_stage, ctx) -- debug.traceback('  ', 2)
	end
end

gren_fix = true

local pda_on = false
function get_pda_on()
	return pda_on
end
function set_pda_cb(flag)
	pda_on = flag
end

function snd_volume_get()
	return get_console():get_float("snd_volume_eff")
end
function snd_volume_set(vol)
	get_console():execute( sprintf("snd_volume_eff %.1f", vol) )
	--wprintf(" #DBG: sound volume changed to %.1f ", vol)
end

function snd_volume_change(delta)
	local value = snd_volume_get () + delta
	if value >= 0.0 and value <= 1.0 then
		snd_volume_set(value)
	end
end

function _G.snd_on_off()
	local vol = snd_volume_get()
	if vol > 0 then
		db.save_volume = vol
		snd_volume_set(0)
	else
		snd_volume_set(db.save_volume or 1.0)
	end
end

function _G.snd_volume_up()
	snd_volume_change(0.1)
end

function _G.snd_volume_dn()
	snd_volume_change(-0.1)
end

function bind_stalker.handle_events()
	local src = bind_stalker.info_events
	bind_stalker.info_events = {}
	-- wprintf("[~T]. #DBG: bind_stalker.handle_events: ")
	-- dump_table(src, "       ")

	for i, event in ipairs(src) do
		local info_id  = event[2]
		sak.on_info(info_id)
		vergas_lib.inventory_info(info_id)
	end
end

function bind_stalker.on_item_events(take)
	level_tasks.proceed(db.actor)
end

function bind_stalker.handle_taked()
	if not vergas_lib.flag_inventory then return end
	local src = bind_stalker.taked_items
	local cnt = #src
	if cnt == 0 then return end
	bind_stalker.taked_items = {}
	-- wprintf("[~T/~B]. #DBG: handle_taked processing~C0D %d~C07 items ", cnt)
	misc.debug_remove = true
	for i, id in ipairs(src) do
		local obj = client_obj(id) -- НАЗЕЙР ДНКФЕМ ЯСЫЕЯРБНБЮРЭ !
		if obj then
			local flag = vergas_rucksack.take_item_in_inv(obj) -- ОНОШРЙЮ ЯУБЮРХРЭ ОПЕДЛЕР Б ПЧЙГЮЙ/ХМБЕМРЮПЭ ХКХ НЯНАШИ ОПЕДЛЕР.
			if not spec_item[obj:section()] and flag then
			-- added for OGSR Signal Manager - create signal "on_take"----------------------
				local sobj = alife():object( obj:id() )
				if sobj then -- РЮЙНЕ АШБЮЕР, ЕЯКХ ДН ЩРНЦН НАЗЕЙР АШК СДЮК╦М Б on_ruck
					--self.am:call( "on_take", obj, sobj )
					ogse_signals.get_mgr():call( "on_take", obj, sobj )
				end
			--------------------------------------------------------------------------------

				-- wprintf(" processing take~C0A %s~C07, r.flag =~C0F %s~C07", obj:name(), DumpVar(razgruzka.open_inv_raz_pod))
				arc_arts.on_item_take(obj) -- ОНДАХПЮМХЕ ЮПРЕТЮЙРНБ, ОНЪЯЮ Х ПЪДЮ ДПСЦХУ БЕЫЕИ
				sak.food_thief(obj)
				-- if  razgruzka.open_inv_raz_pod == true then
				amk.on_item_take(obj)                        -- БШГНБ amk_mod.check_usable_item, ОПНБЕПЙЮ МЮ ГЮОХЯЙХ Х ДНАЮБКЕМХЕ вл
				xrs_ai.actor_item_take(obj)                  -- ОНДАНП ЦПЮМЮР Х ЛЕДХЖХМШ?
				amk_offline_alife.on_item_take(obj)
				sak.check_used_item(obj)                     -- ОПНБЕПЙЮ ОПЕДЛЕРЮ МЮ НДМС ХГ 100+ ЯЕЙЖХИ, Я ЯНБЕПЬЕМХЕЛ ХМДХБХДСЮКЭМШУ НАПЮАНРНЙ
				razgruzka.open_inv_raz_pod=false
				-- end
			else


			end
		end -- if
	end -- for
	misc.debug_remove = false

	--wprintf("[~T/~B]. #DBG: handle_taked processing end ")
	get_shadow_inv().need_update = true
	take_events = take_events + 1
end

function bind_stalker.handle_dropped(obj)
	local sec = obj:section()
	if sec=="sleeping_bag" then
		sleeping_bag.add_sleep_zone(obj)
	elseif sec=="rucksack" then
		-- sak.ruck_near_lc(obj:id(),false)
		schedule.add("ruck_near_lc","sak.ruck_near_lc("..obj:id()..")",100)
	end
	if not vergas_lib.flag_inventory then return end

	local id = obj:id()
    -- МЮДН СОПЕДХРЭ НАПЮРМНЕ ОНДАХПЮМХЕ ОПЕДЛЕРЮ ВЕПЕГ НРКНФЕММНЕ ЯНАШРХЕ
	for i, ref_id in ipairs(bind_stalker.taked_items) do
		if ref_id == id then
			wprintf("~C09 take disabled for~C0A %-35s~C09 due drop event ~C07", obj:name())
			--table.remove(bind_stalker.taked_items, i)
			bind_stalker.taked_items[i]=nil
			break
		end
	end

	local flag = vergas_lib.drop_item(obj)
	amk.on_item_drop(obj)

	if flag then
		arc_containers.lose_item(obj)
		arc_arts.on_remove(id)
		amk_offline_alife.on_item_drop(obj)
		sak.check_droped_item(obj)
		razgruzka.open_inv_raz_pod=false
		drop_events = drop_events + 1
	end
	get_shadow_inv().need_update = true
end

---- ===================================================================  CLASS actor_binder =====================================
class "actor_binder"(object_binder)

function actor_binder:__init(obj) super(obj)
    log_init_stage()
    _G.g_sim = alife()
    self.bCheckStart = false
	self.weather_manager = level_weathers.WeatherManager()
    self.actor_detector = xr_detector.actor_detector()

	--- added for signal manager from dsh-mod -----
	self.am          = ogse_signals.get_mgr()
	self.am:call( "on_load_before_all" )
	self.am:call( "on_init", obj )
	--- added for signal manager from dsh-mod -----

    log_init_stage()
end

function actor_binder:net_spawn(data)
	if not is_debug_mode then
		for _, k in ipairs(default_off) do
			cmd(k, "off")
		end
		local con = get_console()
		for _, k in ipairs(debug_only_cmd) do
			con:disable_command(k)
		end
	end

	-- cmd("r_sunshafts_intensity", "0.27")
	-- cmd("keypress_on_start", "off")
	cmd("g_first_person_death", "off")
	-- cmd("g_3d_scopes", "off")

	cmd("g_cop_death_anim 0") --нРЙКЧВЮЕЛ Death Anims, Я МХЛХ ЙСВЮ АЮЦНБ.
	if get_console():get_integer("r3_dynamic_wet_surfaces_sm_res") < 1024 then
		cmd("r3_dynamic_wet_surfaces_sm_res 1024") --вРНАШ ОНКНЯ МЮ ЯРЕМЮУ МЕ АШКН БН БПЕЛЪ ДНФДЪ.
	end
	cmd("r2_exp_donttest_shad off") --щРН ЩЙНМНЛХР ТОЯ.
	cmd("g_camera_collision_cop_mode off") -- щРН БШГШБЮЕР МЕМСФМШЕ СПНМШ НР ЙНККХГХХ

	if const.underground(level.name()) then --SSS18
		cmd("ssfx_is_underground 1")
	else
		cmd("ssfx_is_underground 0")
	end
	--
	self:fix_ui_inventory_info()
	cmd("unbind", "quick_save")
	cmd("unbind_sec", "quick_save")
	log_init_stage()
	_G.g_sim = alife()

	level.show_indicators()

	self.bCheckStart = true
	self.weapon_hide = false
	weapon_hide = false

	local lname = level.name()
	local prev_lname = get_value("prev_level_name")
	if prev_lname and prev_lname ~= lname then
		dsh.backup_autosave(prev_lname)
	end
	set_value("prev_level_name", lname)

	if object_binder.net_spawn(self, data)==false then
		return false
	end

	db.add_actor(self.object) -- ДН ЩРНЦН ЩРЮОЮ db.actor == nil!
	self.weather_manager:reset()
	log_init_stage()
	self:safe_net_spawn(data)

	local updates_funcs = {
		self.long_update,
		self.binder_update_1,
		self.binder_update_2,
		self.binder_update_3,
		self.binder_update_4,
		self.binder_update_5,
		self.binder_update_6,
		self.binder_update_7,
		self.binder_update_8,
		self.binder_update_10,
		self.binder_update_rarely,
		self.binder_update_task,
	}
	for _, f in ipairs(updates_funcs) do
		self.am:subscribe({signal = "on_update", fun = f, self = self})
	end
	ogsr_memory_control.attach()
	if not has_alife_info("reminders_main_info") then
		self.object:give_info_portion("reminders_main_info")
	end
end

function actor_binder:safe_net_spawn(data)
	if db.actor then
		wprintf("[~T/~B]. #DBG: db.actor present ")
	else
		abort("actor_binder:safe_net_spawn db.actor == nil " )
	end
	log_init_stage()
	log_init_stage()
	log_init_stage()
	watcher_act.on_load()
	log_init_stage()
	log_init_stage()

	if self.st.disable_input_time==nil then level.enable_input() end
	if (actor_stats.add_to_ranking~=nil) then actor_stats.add_to_ranking(self.object:id()) end

	death_manager.init_drop_settings()

	xrs_ai.actor_net_spawn(self)
	if rx_ai then rx_ai.actor_net_spawn() end
	self.am:call("on_init_modules")
	level_change_list()
	--
	log_init_stage()
	self.am:call("on_invoke_all")
	--ag_mayatnik.onLoad()--
	wprintf("[~T/~B]. #DBG: safe_net_spawn end ")
	---------------------------------------------------
	self.am:call( "on_spawn", data )
	--	added for OGSE Anomaly Evader -----------------
	self.am:call( "on_safe_spawn", data )
	---------------------------------------------------
	xr_box.xr_box_init()
	return true
end

function actor_binder:early_init()
	-- ХМЖХЮКХГЮЖХЪ ОН ОЕПБШЛ РХЙЮЛ АХМДЕПЮ (АНКЭЬЮЪ ВЮЯРЭ НАЗЕЙРНБ НМКЮИМ)
	if binder_loops == 2 then
		s_fixes.fix_mgr()
	end
end

function actor_binder:late_init()
	log_init_stage()
	amk.on_game_load(obj)
	sak.add_tail()
	self.am:call("on_late_init_all")
	level.enable_input()
end

function actor_binder:net_destroy()
	ODS('[~T].~CF0 #DBG: actor_binder:net_destroy() processing ...~C07')
	self.am:call("on_stop_modules")
	texman.ret_tex_trees()
	self:clear_callbacks()
	db.del_actor(self.object)
	object_binder.net_destroy(self)
end

