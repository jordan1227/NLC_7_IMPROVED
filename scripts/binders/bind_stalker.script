function actor_binder:on_item_take( obj )
	self.am:call("on_take_before_all", obj, server_obj(obj:id()))
	if debug_take then
		wprintf(" on_item_take obj =~C0A %s~C07, sak.dog_psy = %d, allow =~C0A %s~C07 ", obj:name(), sak.dog_psy, DumpVar(handle_take_drop))
	end
	if sak.dog_psy == 0 then return end

	if handle_take_drop then
		table.insert (bind_stalker.taked_items, obj:id()) -- ВРНАШ НАПЮАНРЮРЭ ЙСВМН ГЮ ОПЕДЕКЮЛХ CLevel::OnFrame
	end
	if #bind_stalker.taked_items >= 100 then
		handle_taked()
	end
	if strpos(obj:section(), "belt_[1-9]_art", 1) then
		arc_arts.on_item_take(obj)
	end
	self.am:call("on_take_after_all", obj, server_obj(obj:id()))
end

function actor_binder:on_item_drop(obj)
	self.am:call("on_drop_before_all", obj, server_obj(obj:id()))
	if handle_take_drop then
		--ODS("[~T]. #DBG: НРДЮЕЛ ~C0A"..obj:name().."   "..obj:section().."~C07")
		handle_dropped(obj)
	end
	self.am:call("on_drop_after_all", obj, server_obj(obj:id()))
end

function actor_binder:task_callback(_task, _objective, _state)
	task_manager.task_callback(_task:get_id(), _objective:get_idx(), _state)
	if _objective:get_idx()==0 then
		if _state==task.completed then
			task_manager.reward_by_task(_task)
			news_manager.send_task(db.actor, "complete", _task, _objective)
		elseif _state==task.fail then
		--if not string.find(_task:get_id(),"monster_part",1,true) and not string.find(_task:get_id(), "artefact",1,true) then
			--news_manager.send_task(db.actor, "fail", _task, _objective)
		--else
			--news_manager.send_task(db.actor, "refused", _task, _objective)
		--end
		else
			news_manager.send_task(db.actor, "new", _task, _objective)
		end
	else
		if _task:get_objective(0):get_state()==task.in_progress then
			if not string.find(_task:get_id(), "courier",1,true) then
				news_manager.send_task(db.actor, "update", _task, _objective)
			end
		end
	end
end

