function baloon_on_belt()
	for _, k in ipairs( bal_tbl ) do
		if sak_inventory.belt_items[ k ] then
       		return k
        end
	end
	return "none"
end

function handle_glass_new_on_belt()
	if sak.arts_operate == true and sak_inventory.belt_items["af_glass_new"] then
		arc_arts.discharge_art_on_belt("af_glass_new", 0.005)
		return true
	else
		return false
	end
end

local weap_class_tbl = {}
function check_weapon_class(sec)
	if weap_class_tbl[sec] == nil then
		weap_class_tbl[sec] = vergas_lib.set_pr_from_config_str(sec,"weapon_class")
	end
	return weap_class_tbl[sec]
end