function give_proha_plash()
	if sak_dialog.cond_items_have("bandit_veteran_outfit",1,0.99) then
		sak_dialog.cond_items_have("bandit_veteran_outfit",1,0.99,true)
	elseif sak_dialog.cond_items_have("bandit_master_outfit",1,0.99) then
		sak_dialog.cond_items_have("bandit_master_outfit",1,0.99,true)
	end
end
