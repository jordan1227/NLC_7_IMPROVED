	sak_inventory.release_actor_items("quest_case_02",1)
end
--	barmen_freeman 
function barmen_freeman_msg()
	if db.actor:has_info("info_barmen_freeman_start") then
		sak.send_tip(game.translate_string("barmen_freeman_msg"),game.translate_string("thinking_out_loud"),5,15,"g_g","sak","yellow")
	end
end		  
-- shurup_spas
function timer_shurup_spas()
	timers.start_timer("shurup_spas",0,12,12,"doc.timer_shurup_spas_m1()")
end
function timer_shurup_spas_m1()
	if not has_alife_info("shurup_spas_improve_info") then
		sak.send_tip(game.translate_string("timer_shurup_spas_m1"),game.translate_string("shurup_sms_h"),3,15,"g_g","sak","green")
		db.actor:give_info_portion("shurup_spas_improve_info")
	end
end
function timer_shurup_fal()
	timers.start_timer("timer_shurup_fal",0,6,10,"doc.timer_shurup_fal_end()")
end
function timer_shurup_fal_end()
	if not has_alife_info("shurup_fal_upgrade_ready") then
		sak.send_tip(game.translate_string("timer_shurup_fal_end"),game.translate_string("shurup_sms_h"),3,15,"g_g","sak","green")
		db.actor:give_info_portion("shurup_fal_upgrade_ready")
	end
end
-- upir
function add_aver_container()
    local obj = alife():create("arc_art_box_basic",sak.v3f(75.22,-8.50,-198.00),998152,2897)
	if obj then	
		local pk = get_netpk(obj)
		local data = pk:get()	  
		data.custom_data = "af_gold_fish_capsule_dyn1d_99"
		pk:set(data)
    end
    if obj then	
		level.map_add_object_spot(obj.id, "crlc_big", "add_aver_container")
	end	
end
-- marsh_lampa
function monsters_save_prec_yes()
	return ( has_alife_info("info_kontr_save") or has_alife_info("info_gig_save") or has_alife_info("info_polter_save") or has_alife_info("info_kidney_save") )
end
function monsters_save_prec_no()
	return not monsters_save_prec_yes()
end
