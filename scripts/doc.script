-- dram_novice
function add_gar_stalker_mp5()
	local obj1 = g_sim:story_object(story_ids.gar_stalker)
	local obj= g_sim:create("wpn_mp5_m1",obj1.position, obj1.m_level_vertex_id, obj1.m_game_vertex_id, obj1.id)
	local new_cond=0.85
	local pk = get_netpk(obj,1)
	local data = pk:get()
	data.condition = new_cond
	pk:set(data)  
	obj = client_obj(obj.id)
	if obj then	obj:set_condition(new_cond) end
end
