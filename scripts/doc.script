end
function take_sidor_outfit(id)
	params.obj_condition (id, 0.61)
	local objd=g_sim:object(id)
	local pk = get_netpk(objd,1)
	local data = pk:get()
	data.condition = 0.61
	pk:set(data)
	vergas_masks.set_mask_condition(id,61,true)
end
