function add_soldier_corpses()
	local points = {
		{-83.96,-16.46,-43.53,747,2560},
		{-94.52,-16.46,-77.15,754,2011},
		{-86.35,-16.45,-101.09,784,2415},
		{-69.56,-4.01,-129.33,705,3485},
		{-129.96,-3.97,-139.33,810,4}
	}
	
	for i=341,345 do
		local p = points[i - 340]
		local obj = sak.create_corpse("agr_soldier_dead",sak.v3f(p[1],p[2]+1,p[3]),p[4],p[5],i,"[dont_spawn_loot]")
		if obj then
			misc.spawn_to("dog_tag",obj)
		end
	end
end
function agr_und_soldier_dead()
	sak.send_tip(game.translate_string("agr_und_soldier_dead"),game.translate_string("thinking_out_loud"),5,15,"g_g","sak","yellow")
end
function remove_soldier_corpses()
	for i = 341,345 do
		local obj = g_sim:story_object(i)
		if obj then
			misc.release_obj(obj)
		end
	end
end
function on_agr_mines()
	local obj = g_sim:story_object(331)
	if obj then return end
	for n = 1,8,1 do
		misc.spawn_by_name("agr_zone_mine_field_"..n)
	end
end
function off_agr_mines()
	local obj = g_sim:story_object(331)
	if not obj then return end
	for n = 331,338 do
		obj = g_sim:story_object(n)
		if obj then   
			misc.release_obj(obj)
		else
			wprintf("[~T].~C0C #WARN(off_agr_mines):~C07 not found story-object~C0D %d~C07 ", n)    
		end   
	end  
end
