local t = {}

function load_job(sj, gname, type, squad, groups)
--'--------------------------------------------------------------------------	
--' Labx18
--'--------------------------------------------------------------------------
	
	if type=="dar_poltergeist_ring" then
			t = {section = "logic@dar_poltergeist_ring_base",
				idle = 0,
				prior = 10, state = {0},
				online = true,
				in_rest = "", out_rest = "",
			}
			table.insert(sj, t)
			t = {section = "logic@dar_poltergeist_ring_1_1",
				idle = 0,
				prior = 5, state = {0,2,3},
				online = false,
				in_rest = "", out_rest = "",
			}
			table.insert(sj, t)
			t = {section = "logic@dar_poltergeist_ring_1_2",
				idle = 0,
				prior = 5, state = {0,2,3},
				online = false,
				in_rest = "", out_rest = "",
			}
			table.insert(sj, t)
			t = {section = "logic@dar_poltergeist_ring_end",
				idle = 0,
				prior = 5, state = {0,1,3},
				online = false,
				in_rest = "", out_rest = "",
			}
			table.insert(sj, t)
			t = {section = "logic@dar_poltergeist_ring_end",
				idle = 0,
				prior = 5, state = {0,1,3},
				online = false,
				in_rest = "", out_rest = "",
			}
			table.insert(sj, t)
			t = {section = "logic@dar_poltergeist_ring_end",
				idle = 0,
				prior = 5, state = {0,1,3},
				online = false,
				in_rest = "", out_rest = "",
			}
			table.insert(sj, t)
			t = {section = "logic@dar_poltergeist_ring_1_1",
				idle = 0,
				prior = 10, state = {1},
				online = true,
				in_rest = "", out_rest = "",
			}
			table.insert(sj, t)
			t = {section = "logic@dar_poltergeist_ring_1_2",
				idle = 0,
				prior = 10, state = {1},
				online = true,
				in_rest = "", out_rest = "",
			}
			table.insert(sj, t)
			t = {section = "logic@dar_poltergeist_ring_base",
				idle = 0,
				prior = 5, state = {1,2,3},
				online = false,
				in_rest = "", out_rest = "",
			}
			table.insert(sj, t)
			t = {section = "logic@dar_poltergeist_ring_end",
				idle = 0,
				prior = 10, state = {2},
				online = true,
				in_rest = "", out_rest = "",
			}
			table.insert(sj, t)
			t = {section = "logic@dar_poltergeist_ring_end",
				idle = 0,
				prior = 10, state = {2},
				online = true,
				in_rest = "", out_rest = "",
			}
			table.insert(sj, t)
			t = {section = "logic@dar_poltergeist_ring_end",
				idle = 0,
				prior = 10, state = {2},
				online = true,
				in_rest = "", out_rest = "",
			}
			table.insert(sj, t)
	end
	

	if type=="dar_poltergeist_tele" then
			t = {section = "logic@dar_poltergeist",
				idle = 0,
				prior = 5, state = {0},
				in_rest = "", out_rest = "",
			}
			table.insert(sj, t)
	end

	if type=="dar_poltergeist_tele_round" then
			t = {section = "logic@dar_poltergeist",
				idle = 0,
				prior = 5, state = {0},
				in_rest = "", out_rest = "",
			}
			table.insert(sj, t)
