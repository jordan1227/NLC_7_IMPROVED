function load_job_mil_monster(sj, gname, type, squad, groups)
		local t, a
		
		for a = 1, 5 do
				t = {section = "logic@mil_monster",
				idle = 0,
				prior = 1, state = {0},
				squad = squad, group = groups[0],
				in_rest = "", out_rest = ""
				}
			table.insert(sj, t)	
		end			
end
