local spawn_flag = false
-------------------------------------------------------------------------------------------
-- Проверка состояния гулага у выхода на Радар
-------------------------------------------------------------------------------------------
function check_monolith_state(gulag)
	if has_alife_info("mil_fblockpost_rush_wave1") then
		if not has_alife_info("mil_fblockpost_rush_wave2") and not spawn_flag then
			sak.barrier_spawn_effect(1)
			spawn_flag = true
		end
		return 1
	else
		return 0
	end
end

