function weather_manager()
	ogse_signals.get_mgr():reschedule(331)
	if sync_done==false then return end
	local hour = level.get_time_hours()
	--local minut = level.get_time_minutes()
	local dynlasthour = get_value("dynlasthour", 1)
	if dynlasthour~=hour then
		sak.consum_artefact()
		sak.info_days(hour)
		set_value("dynlasthour", hour)
	end
end

