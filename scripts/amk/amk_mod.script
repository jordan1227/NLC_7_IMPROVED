function handle_pda_chip(val)
	set_value(val,true)
end

function used_item(obj)
	local sect=obj:section()
	if amk_used[sect] then
		local txt=amk_used[sect]
		loadstring(txt) ()
	end
end

-- Manool: места, в которых нельзя спать, например, бункер Сидоровича
local bad_sleep_places = {
	{"l01_escape", 20, -246.95002746582,-24.795707702637,-134.45962524414},
}

function test_for_need_sleep_matras(oid)
	--Vergas sleeping_bag---------------ON--------------------
	local flag = false
	local flag_bag = false
	if oid:section() == "sleeping_bag" then
		flag = true
	elseif type(oid) == 'number' and g_sim:object(oid) == nil then
		flag = true
	end
	--if g_sim:object(oid)==nil then
	if not flag then return end

	--Vergas sleeping_bag---------------OFF-------------------
	local enemy = false
	sak.close_window()

	-- одетый рюкзак мешает залезть в мешок
	local act = db.actor
	local equ = false

	if get_shadow_inv():update_storage() then
		equ = true
	end

	for a,i in pairs(db.storage) do
		local objg = client_obj(a)
		if objg then
			if (objg and ((IsStalker(objg) and amk.get_npc_relation(objg,db.actor)=="enemy" and objg:alive())  or 
			IsMonster(objg) and not string.find(objg:name(),"^rat_")) and objg:position():distance_to(db.actor:position()) < 30  and objg:alive()) then
				enemy=true
			break
			end 
		end 
	end

	local bad_place
	local lv, pos = level.name(), db.actor:position()
	for i, v in ipairs(bad_sleep_places) do
		if lv == v[1] and pos:distance_to(vector():set(v[3], v[4], v[5])) <= v[2] then
			bad_place = true
			break
		end
	end

	if bad_place then
		flag_bag = true
		amk.send_tip(game.translate_string("ui_inv_sms_bad_sleep_place"),nil,nil,5)
	elseif enemy == true then
		flag_bag = true
		amk.send_tip(game.translate_string("not_need_sleep_enemy"),nil,nil,5)
	else
		if get_value("blowout", 0) > 0 and get_value("blowout", 0) < 5 then
			flag_bag = true
			amk.send_tip(game.translate_string("blowout_not_sleep"),nil,nil,5)
		elseif ( equ ) then
			flag_bag = true
			wprintf("[~T]. #SLEEP_REJECT: equipment thwarted")
			amk.send_tip(game.translate_string("cant_sleep_equip"),nil,nil,5)
		elseif has_alife_info("sleep_abuse_timer_info") then
			flag_bag = true
			sak.send_tip(game.translate_string("cant_sleep_abuse"), game.translate_string("thinking_out_loud"), 1, 10, "g_g", "sak", "red")
		elseif get_value("block_sleep_menu", 0) == 0 then
			if ( sleep_manager.get_sleepiness(108) ) > 50 then
				if oid:section()=="sleeping_bag" then
					vergas_lib.s_play([[device\sleeping_bag\sleep_bag_down]])
				end
				used_items.sleep_management()
				--local spwn=ui_cheat.cheat(get_hud())
				--level.start_stop_menu(spwn,true)
			else
				--Меченный не хочет спать
				flag_bag = true
				wprintf("[~T]. #SLEEP_REJECT: actor sleepiness =~C0D %.3f~C07", sleep_manager.get_sleepiness(108))
				amk.send_tip(game.translate_string("not_need_sleep"),nil,nil,5)
			end
		else
			--действует энергетик
			flag_bag = true
			amk.send_tip(game.translate_string("not_need_sleep_nrg"),nil,nil,5)
		end
	end
	if flag_bag then
		sleeping_bag.no_sleep()
	end
	if oid:section()~="sleeping_bag" then
		amk.spawn_item_in_inv("matras")
	end
end

function esc_sleep_matras()
	if get_value("blowout", 0) >0 and get_value("blowout", 0) < 5 then
		amk.send_tip(game.translate_string("blowout_not_sleep"),nil,nil,5)
	elseif get_value("block_sleep_menu",0)==0 then
		if sleep_manager.get_sleepiness(108) > 50 then
			used_items.sleep_management()
		else
			amk.send_tip(game.translate_string("not_need_sleep"),nil,nil,5)
		end
	elseif bt > 0 then 
		amk.send_tip(game.translate_string("not_need_sleep_undegrourd"),nil,nil,5)
	else
		amk.send_tip(game.translate_string("not_need_sleep_nrg"),nil,nil,5)
	end
end

