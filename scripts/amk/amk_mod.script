function attach(sm)
	sm:subscribe({signal = "on_update", fun = this.blowout_phantoms})
	sm:subscribe({signal = "on_update", fun = this.check_metka})
	sm:subscribe({signal = "on_update", fun = this.weather_manager})
	sm:subscribe({signal = "on_update", fun = this.check_armor})
	sm:subscribe({signal = "on_update", fun = this.on_blowout_hit_actor})
end

