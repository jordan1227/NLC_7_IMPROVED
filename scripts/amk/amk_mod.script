function check_for_af_drop(obj)
	if obj and obj:id() then
		schedule.add("check_af_drop"..obj:id(), "amk_mod.check_af_drop("..obj:id()..")", 200, true) 
	end
end

function check_af_drop(af_id)
	if not af_id then
		wprintf("[~T].~C0C #ERROR: invalid param specified for check_af_drop.\n~C0A %s~C07", lua_traceback(' '))
		return
	end
	local obj = client_obj( misc.get_object_id(af_id) )
	if obj==nil or obj:parent()~=nil then return end  
    
	local section=obj:section()
	if str_in_tab (section, afs) and not strposx (section,"_capsule") then
		local id, pos, radius, dist = amk_anoms.get_nearest_anomaly(obj)
		if id and radius - dist > 1 then
			local anom_sect = client_obj(id):section()
			check_af_transform(obj, id, anom_sect) 
		end
		return
	end  
end

function af_flash(af)
	level.add_pp_effector("teleport.ppe", 1524, false)
	amk.remove_item(af)
end

function af_start_transform(v1, v2, af_from, af_target)
	if v2 == 100 then
		return af_from
	end
	local rnd = dsh.get_next_random("mods_rnd", 1, 100)
	ASSERT(sys_ini:section_exist(af_target), "Section not found: %s", tostring(af_target))
    
	if rnd > v1 then
		if rnd > v2+v1 then
			return "af_dummy_buliz"
		else
			return af_from
		end
	else
		return af_target
	end
end

function split_pair(s, delim)
	local t = SplitStr(s, delim)
	return (t[1] or '01'), (t[2] or '22') 
end

function check_reciepts(list)
	local t = SplitStr(list, ",")
	for i, info in ipairs(t) do
		if db.actor:has_info(info) then
			return true
		end
	end
	return false
end

local artefacts_cooking_tbl
local function get_artefacts_cooking()
	if not artefacts_cooking_tbl then
		artefacts_cooking_tbl = {}
		local ini = ini_file("misc\\artefacts_cooking.ltx")
		ini:iterate_sections(function(sect)
			local t = {}
			for i = 0, ini:line_count(sect) - 1 do
				local _, k, v = ini:r_line(sect, i, "", "")
				t[k] = v
			end
			artefacts_cooking_tbl[sect] = t
		end)
	end
	return artefacts_cooking_tbl
end

-- Sn: здесь варятся только модификаты, для всего остального см. вызов в конце этой функции
function check_af_transform(af, anom_id, anom_sect)
	local af_sect = af:section()
	local pos     = af:position()
	gv=client_obj(anom_id):game_vertex_id()
	lv=client_obj(anom_id):level_vertex_id()
	if gv==BAD_OBJ_ID then gv = af:game_vertex_id() end
	if gv==BAD_OBJ_ID then gv = db.actor:game_vertex_id() end
	if gv==BAD_OBJ_ID then return end
  
	if strposx(anom_sect, "_psi_field") and strpos(af_sect, "^af_unknown") then
		mike.af_transform(af, anom_sect, af_sect)
		return
	end

	for scn, sc in pairs(get_artefacts_cooking()) do
		local rlist = sc.recipes or 'nil'
		if check_reciepts(rlist) then
			local good = (af_sect == sc.source)
			local anom_pass = strposx(anom_sect, sc.anomaly or '?')
			if good and anom_pass then
				sc.auto_type = false
				af_flash(af)
				local new_sect = scn:gsub("cook.", "") -- секция создаваемого артефакта
				local required_exp_lvl = tonumber(string.sub(new_sect,string.len(new_sect))) - 1
				local p1, p2 = split_pair(sc.probability or "80,10", ",")
				local hh, mm = split_pair(sc['time'], ":")
				local cur_exp = actor_stats.get_points("artefacts")
				local threshold = 0
				threshold = math.modf(cur_exp/5)
				if threshold < required_exp_lvl then
					p2 = 100
				end
				local time_prob_coeff = (math.modf(cur_exp/10)) - 1
				if time_prob_coeff < 0 then
					time_prob_coeff = 0
				elseif time_prob_coeff > 4 then
					time_prob_coeff = 4
				end
				time_prob_coeff = time_prob_coeff * 5
				mm = tonumber(mm) - time_prob_coeff
				p1 = tonumber(p1) + time_prob_coeff
				local tr = af_start_transform(p1, tonumber(p2), af_sect, new_sect)
				xr_statistic.addCookingPoints(new_sect)

				log2("#AMK_MOD:start cooking %s with time %s:%02d, prob = %s, %s (%s)",
					new_sect, hh, mm, p1, p2, sc.probability or 'nil')
				return af_start_transform_timer(tr, pos, 0, tonumber(hh), mm)
			else
				-- wprintf("[~T].~C06 #AMK_MOD: ~C0A %-25s~C07 reject, need ~C0E %-25s~C0B (%s)~C07 in~C0F %-15s~C0B (%s)~C07, have ~C0B %s~C07", scn, sc.source, DumpVar(good), sc.anomaly, DumpVar(anom_pass), af_sect)
			end
		else
			-- wprintf("[~T].~C06 #AMK_MOD: ~C0A %-25s~C07 reject, need one reciept from ~C0E %-25s~C07 ", scn, rlist)
		end
	end
	sak.artmodscheck(anom_id, af, anom_sect) 
end

function af_start_transform_timer(af, pos, delay_d, delay_h, delay_m)
	local t={}
	t.section=af
	t.pos={}
	t.pos.x=pos.x
	t.pos.y=(pos.y+1)
	t.pos.z=pos.z
	t.gv=gv
	t.lv=lv
	local gtime = misc.game_time_minutes()
	set_value("p_"..gtime.."_af", t)  
	timers.start_timer("af_trans_"..gtime, delay_d, delay_h, delay_m, "amk_mod.af_transform_end(\"p_"..gtime.."_af\")")
end

function af_transform_end(params_string)
	local prms = get_value(params_string, {})
	--if nil == prms or type(prms) ~= "table" then return end
	local sect = prms.section
	if not sect then
		wprintf("~C0C #ERROR:~C07 af_transform_end loaded invalid table for~C0A %s~C07 ", params_string)
		dump_table(prms)
		return  
	end
    
	local name = amk.get_inv_name(sect)
	local from_sect=game.translate_string(name)
	local obj=amk.spawn_item(prms.section,vector():set(prms.pos.x,prms.pos.y+2.5,prms.pos.z),prms.gv,prms.lv)
	local se_obj = alife():object(obj.id)
	se_obj:used_ai_locations(false)
	local s
	local upgr = get_value("pda_upgr_cook")
	if upgr then
		s = string.format("[%s]: %s%%c[255,255,0,0]%s",game.translate_string(se_obj.level_name),game.translate_string("trans_finished_title_upgr"),from_sect)
		level.map_add_object_spot_ser(se_obj.id,"artefact_location",from_sect)
	else
		s = string.format("%s",game.translate_string("trans_finished_title"))
	end
	amk.send_tip(s)
	remove_value(params_string)
end

local beakons={}
function check_beacon_drop(obj)
	if has_alife_info("ui_car_body") then
		gps_habar.on_item_drop(obj)
	end
	if has_alife_info("ui_inventory_hide") then return end
	if obj:section()=="amk_metka" then
		schedule.add("close_window", "sak.close_window()", 100)
		beakons[obj:id()]=true
	end
end

function check_metka()
	ogse_signals.get_mgr():reschedule(927)
	for id,v in pairs(beakons) do
		local obj=client_obj(id)
		if obj then
			beakons[id]=nil
			if obj:parent()==nil then
				schedule.add("check_metka_ui"..id, "amk_mod.check_metka_ui("..id..")" ,300)
			end
		end
	end
end

function check_metka_ui(id)
	local spwn=ui_dots.dots(get_hud(),id)
	level.start_stop_menu(spwn,true)
end

function blowout_phantoms()
	ogse_signals.get_mgr():reschedule(271)
	bt = bt or 0   
	if bt>=2 then return end
	local blow = get_value("blowout", 0)
	if blow>1 and blow<4 then
		local lname=level.name()
		local a_pos = db.actor:position()
		if amk_anoms.check_coordinates(a_pos) and amk_hideouts.blowouts_phantoms[lname] then
			local phantoms=amk_hideouts.blowouts_phantoms[lname]
			if phantoms and phantoms.count>0 then
				if lua_random()<phantoms.probability then
					if phantom_manager:phantom_count()<phantoms.count then
						local yaw  = math.pi*2.0*lua_random()
						local radius = phantoms.radius*(lua_random()/2.0+0.5)
						local height = phantoms.height*lua_random()
						local pos   = vector():set(math.sin(yaw)*radius+a_pos.x,a_pos.y+height,math.cos(yaw)*radius+a_pos.z)
						phantom_manager.spawn_phantom(pos)
					end
				end
			end
		end
	end
end

function blowout_scary_sounds()
	local blow= get_value("blowout", 0)
	if blow>0 and blow<4 then
		local snd_obj = xr_sound.get_safe_sound_object(amk_hideouts.blowout_sounds[lua_random(table.getn(amk_hideouts.blowout_sounds))])
		local a=vector()
		a.x=lua_random(0,10)
		a.y=lua_random(0,10)
		a.z=lua_random(0,10)
		snd_obj:play_at_pos(db.actor, db.actor:position():add(a))
		timers.start_timer("blowout_ss",lua_random(10,30),"amk_mod.blowout_scary_sounds()")
		local name, delay = timers.check_timer("blowout")
		if not name then
			timers.start_timer("blowout",11,"amk_mod.Blowout_pp(0)")
		end
	end
end

function blowout_psy_sound(action)
	if action=="start" then
		snd_obj_eq = sound_object([[ambient\earthquake]],sound_object.looped+sound_object.s2d)
		snd_obj_eq:play(db.actor, 4, sound_object.looped+sound_object.s2d)
	end
	if action=="stop" then
		if snd_obj_eq then snd_obj_eq:stop() end
	end
  
	local lname=level.name()
	if not amk_hideouts.blowouts_phantoms[lname] then return end
	local psy_sound=amk_hideouts.blowouts_phantoms[lname].psy_sounds or false  
	if not psy_sound then return end

	if action=="start" then
		local level_vol=amk_hideouts.blowouts_phantoms[lname].level_vol or 1        
		sound_obj_right, sound_obj_left = xr_sound.get_sound_object("psy_voices","random")
		sound_obj_left:play_at_pos(db.actor, vector():set(-1, 0, 1), 0, sound_object.s2d + sound_object.looped)
		sound_obj_right:play_at_pos(db.actor, vector():set(1, 0, 1), 0, sound_object.s2d + sound_object.looped)
		snd_volume  = level.get_snd_volume()
		level.set_snd_volume(level_vol)
	end
	if action=="stop" then
		if sound_obj_left then sound_obj_left:stop() end
		if sound_obj_right then sound_obj_right:stop() end
		if snd_volume then level.set_snd_volume(snd_volume) end
	end  
end

function Run_Blowout_pp()
	local bl_sl = sleep_manager.sleep_blowout
	if bl_sl~=false then
		db.blowout_active=true
		set_value("blowout",1)
		level.block_change_level(true)
		_G.flag_can_save = false
		log2("game saving is disabled now!")
		if bt<1 then
			level.add_pp_effector("monolith_off.ppe", 2003, false)
			level.add_cam_effector("camera_effects\\shell_shock.anm", 2004, false,"")
			local snd_obj = xr_sound.get_safe_sound_object([[ambient\organic_moan1]])
			snd_obj:play_no_feedback(db.actor, sound_object.s2d, 0, vector(), 1.0)
		end
		sleep_manager.stopper()
		timers.start_timer("blowout_ss",lua_random(5,15),"amk_mod.blowout_scary_sounds()")
		timers.start_timer("blowout",11,"amk_mod.Blowout_pp(0)")
	end
	start_blow_timer()
end

function start_blow_timer()
	local shift = 2160
	local day = timers.Get_Game_Days() or 1
	local add_time = math.modf(day / 7) * 2 * 60
	local t_time =(lua_random()*shift)-(shift/2)+2880+add_time
	timers.start_timer("blow_shift",0,0, t_time,"amk_mod.Run_Blowout_pp()")
	news_main.next_blow(t_time)
end

function Blowout_pp(num)
---------------------------------------------------
--' TimeFactor = 5
--' GameMin = 12 RealSec
--' TimeBlowout = 184 RealSec

--' Начало(Timer = 36 sec)
--' Первая Фаза(Timer = 36 sec)
--' Вторая Фаза(Timer = 36 sec)
--' Третья Фаза(Timer = 36 sec)
--' Четвертая Фаза(Timer = 60 sec)
--' Конечнвя Фаза(Timer = 0 sec)
---------------------------------------------------
	local phase=tonumber(num)
	local lname = level.name()
	local hour = level.get_time_hours()
	if phase==0 then
		db.actor:give_info_portion("vybros_info")
		amk_anoms.pre_blow_off()
		if bt<1 then
			dbg_set_w("default_pre_blowout",true)
			dbg_set_w_fx("fx_surge_day_3",true)
		end 
		timers.start_timer("blowout",0,0,3,"amk_mod.Blowout_pp(1)")
	elseif phase==1 then
		local snd_obj = xr_sound.get_safe_sound_object([[ambient\earthquake]])
		snd_obj:play_no_feedback(db.actor, sound_object.s2d, 0, vector(), 1.0)
		level.add_cam_effector("camera_effects\\earthquake.anm", 2002, true,"")
		snd_obj = xr_sound.get_safe_sound_object([[anomaly\blowout]])
		snd_obj:play_no_feedback(db.actor, sound_object.s2d, 0, vector(), 1.0)
		blowout_psy_sound("start")
		if bt<1 then
			level.add_pp_effector("vibros.ppe", 2001, true)
		end
		in_hide=false
		timers.start_timer("blowout",0,0,3,"amk_mod.Blowout_pp(2)")
		set_value("blowout",2)
	elseif phase==2 then
		timers.start_timer("blowout",0,0,3,"amk_mod.Blowout_pp(3)")
		clear_skel_tbl()
	elseif phase==3 then
		amk_anoms.after_blow_on()
		sak.off_testobj()
	
		remove_value("tbl_bio_art")
	
		set_value("blowout",3)
		timers.start_timer("blowout",0,0,3,"amk_mod.Blowout_pp(4)")
	elseif phase==4 then
		set_value("blowout",4)
		level.remove_cam_effector(2002)
		if bt<1 then
			level.remove_pp_effector(2001)
			level.add_pp_effector("monolith_off.ppe", 2003, false)
		end
		blowout_psy_sound("stop")
		timers.start_timer("blowout",5,"amk_mod.Blowout_pp(5)")
		amk_anoms.generate_arts()
		local spwn_tbl = get_value("need_art_spawn", {})
		spwn_tbl[lname] = false
		set_value("need_art_spawn", spwn_tbl)
	elseif phase==5 then
		--dbg_set_w(get_value("weather", default),true)
		if bt<1 then
			local snd_obj = xr_sound.get_safe_sound_object([[anomaly\teleport_work2]])
			snd_obj:play_no_feedback(db.actor, sound_object.s2d, 0, vector(), 1.0)
			if level.is_wfx_playing() then
				level.stop_weather_fx()
			end
			if const.ground_levels[lname] then
				level.set_weather("default_np_thunder",true)
				set_value("after_blow_weather_lock",true)
			else
				level_weathers.get_weather_manager():forced_weather_change()
			end
			set_value("dynlasthour", hour)
		end
		remove_value("blowout")
		dsh.timeout(8000, function()
			_G.flag_can_save = true
			level.block_change_level(false)
			log2("game saving is enabled now!")
		end)
		if lname=="generators" then
			sak.spawn_teleports(sak.v3f(-20.4,34.8,-223.8),311873,3106,5,20,"amk_zone_teleport_labirint",20)
		elseif lname=="aver" then
			sak.spawn_teleports(sak.v3f(350.91,-6.01,-21.23),1492916,2902,5,30,"amk_zone_teleport_aver_labirint",40)
		elseif lname=="l11_pripyat" then
			sak.spawn_teleports(sak.v3f(29.7,1.8,355.8),139177,2260,5,30,"amk_zone_teleport_prip_labirint",40)
		end
		db.blowout_active=false
		timers.start_timer("allow_weather_change",0,0,30,"amk_mod.allow_weather_change()")
		db.actor:give_info_portion("groza_info")
		xr_statistic.add_pts(
		"otherstats", game.translate_string( "st_pda_otherstats_blowouts" ), 1, 0.5
		)
	end
end
function allow_weather_change()
	remove_value("after_blow_weather_lock")
end

local next_actor_hit_time=0
function on_blowout_hit_actor()
	ogse_signals.get_mgr():reschedule(779)
    if get_value("blowout", 0)~=3 then return end
	if next_actor_hit_time < time_global() then
		next_actor_hit_time=time_global()+1000
		on_blowout_hit (db.actor)
	end
end

function on_blowout_hit(npc,hide)
	bt = bt or 0
	if bt > 0 or get_value("blowout",-1)~=3 then 
		if npc:id()==db.actor:id() then in_hide = true end
		return false
	end
	local lname=level.name()
	local need_hit
	need_hit=true
	local khit=1
	if hide and hide.zone then
		need_hit = not check_npc_in_hideout(npc,hide)
		if not need_hit then
			if hide.defence then 
				khit=hide.defence
			else
				khit=0
			end
		end
	else
		local hides=amk_hideouts.hide[lname]
		local tmp
		if hides then
			for i,o in ipairs(hides) do
				if o.zone then
					for j,v in ipairs(o.zone) do
						if v.p3 then
							tmp=amk.check_npc_in_box(npc,vector():set(unpack(v.p1)),vector():set(unpack(v.p2)),vector():set(unpack(v.p3)))
						else
							tmp=amk.check_npc_in_box(npc,vector():set(unpack(v.p1)),vector():set(unpack(v.p2)))
						end
						need_hit = need_hit and not tmp
						if tmp then
							if o.defence then 
								khit=o.defence
							else
								khit=0
							end
						end
					end
				end
			end
		end
	end

	if npc:id()==db.actor:id() then in_hide = not need_hit end
	if (need_hit or khit>0) and get_value("blowout",-1)==3 then
	local power =(amk_hideouts.blowout_damages[lname] or 0.01)*khit
		if npc:id()==db.actor:id() then
			params.psy_health_add(-power)
			params.radiation_add(power)
			power=-(power/2)
			params.health_add(power)
		else
			local h = hit()
			h.power = power
			h.impulse = 0
			h.draftsman = npc
			h.direction = vector():set(0,0,0)
			h:bone("bip01_spine") 
			h.type = hit.strike
			npc:hit(h)
			h.type = hit.telepatic
			npc:hit(h)
			h.type = hit.radiation
			npc:hit(h)
		end
	end
	return need_hit or khit>0
end

function check_npc_in_hideout(npc,hide)
	local not_in_zone=true
	if hide and hide.zone then
		for k,v in pairs(hide.zone) do
			if v.p3 then 
				not_in_zone = not_in_zone and not amk.check_npc_in_box(npc,vector():set(unpack(v.p1)),vector():set(unpack(v.p2)),vector():set(unpack(v.p3)))
			else
				not_in_zone = not_in_zone and not amk.check_npc_in_box(npc,vector():set(unpack(v.p1)),vector():set(unpack(v.p2)))
			end
		end
	end
	return not not_in_zone
end

function blowout_type()
	local lname=level.name()
	local t=amk_hideouts.blowout_types[lname]
	return t or 0
end
				
local comm_black_tip = {
				["stalker"] = true,
				["freedom"] = true,
				["dolg"]    = true
				}
				
function IsStalkerCorpse(prn_id)
	local npc=client_obj(prn_id)
	if IsStalker(npc) then
		local comm = npc:character_community()
		return comm_black_tip[comm]
	end
	return false
end
   
function try_add_black_tip(lname,prn_id)
	local day = timers.Get_Game_Days() or 1
    if day < 10 or not IsStalkerCorpse(prn_id) then return false end
    if lua_random(100)<=2 and not has_alife_info("info_black_tip") then
		timers.start_timer("black_tip_hv",8,1,1,"sak_dialog.take_black_tip()")
		db.actor:give_info_portion("info_black_tip")
		return true
    end
    return false
end

function check_usable_item(obj)
	local actor=db.actor
	local section=obj:section()
	if section=="amk_metka" then
		amk.remove_spot_from_map(obj:id(),"red_location")
		beakons[obj:id()]=nil
	elseif string.find(obj:section(),"outfit") then
		last_armor_id = 0
	elseif section=="vehicle_btr" then
		actor:kill(actor)
	end
end

