function check_spawn()
	wprintf('~CF0[~T/~U/~B]. #PERF: amk_mod.check_spawn begin~C07');
	bt = blowout_type()
	amk_anoms.init()
	wprintf('~CF0[~T/~U/~B]. #PERF: spawn_unspawned_respawners() ~C07');
	spawn_unspawned_respawners() 
	news_main.init()
	amk_offline_alife.init()
	-- timers.tTimers = {}
	local obj1, obj2
 
	wprintf('~CF0[~T/~U/~B]. #PERF: updating LC~C07'); 

	local lc_list = { info_way91a = 91,                         -- кордон -- свалка
                    info_way100a = 9100, info_way176a = 9176,   -- агро-зх -- зх-агро
                    info_way101a = 9101, info_way182a = 9182,   -- кордон-зх -- зх-кордон					
