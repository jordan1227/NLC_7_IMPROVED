                    info_way104a = 9104, info_way172a = 9172,   -- дт-рл -- рл-дт 
                    info_way105a = 9105, info_way174a = 9174,   -- ас-рл -- рл-ас
                    info_way106a = 9106, --info_way173a = 9173, -- янтарь-рл -- рл-янтарь
                    info_way107a = 9107,                        -- вход в х12 
                    info_way108a = 9108, --info_way189a = 9189, -- радар-тесла -- тесла-радар
                    info_way109a = 9109,                        -- вход в х10
                    info_way110a = 9110, --info_way136a = 9136, -- тд-тч -- тч-тд
                    info_way111a = 9111, info_way137a = 9137,   -- ас-тч -- тч-ас
                    info_way116a = 9116, info_way117a = 9117,   -- тд-свалка -- свалка-тд 
                    info_way151a = 9151, --info_way135a = 9135, -- свалка-тч -- тч-свалка
                    --info_way130a = 9130,                      -- вход х12 
                     --info_way112a = 1008,                     -- кордон-кишка 
                    info_way113a = 592,                         -- бар-ас 
                    info_way114a = 594,                         -- бар-дт
                    info_way154a = 9154, --info_way191a = 9191, -- ас-тесла -- тесла-ас
                    info_way156a = 9156,                        -- лиманск -- склады
					info_way158a = 9158,                        -- кордон -- санаторий
					info_way159a = 9159,                        -- санаторий -- свалка!					
                    info_way165a = 9165, --info_way190a = 9190, -- лимаск-тесла -- тесла-лиманск
					info_way177a = 9177,                        -- свалка -- санаторий!					
                    info_way179a = 9179, info_way178a = 9178,   -- болота-кордон -- кордон-болота
                    info_way181b = 9181, info_way183a = 9183,   -- болота-агро -- агро-болота
                    
                    info_way180a = 9180, info_way166a = 9166,   -- болота-зх -- зх-болота
                    
                    info_way184a = 9184, info_way185a = 9185,   -- свалка-зх -- зх-свалка
					info_way255a = 9255,
					--info_way829a = 9829,                        -- exit_to_agr_underground_03!
					--info_way831a = 9831,                        -- exit_to_agr_underground_04!
					--info_way832a = 9832,                        -- exit_to_agroprom_03! 
					--info_way833a = 9833,                        -- exit_to_agroprom_05!
					info_way301a = 191,                           -- свалка -- агро!
					info_way303a = 196,                           -- свалка -- тд!					
                    val_raid_start = 9199,
					water_tunnel = 9813,						  -- БУМ-ТЧ
					prizrak_news_info = 9261,					  -- х10-ТД (в овраге)
					marsh_new_theme_info = 9120,				  -- х18-ТЧ
					gg_has_pass_info = 9814						  -- Тесла-ЧАЭС
					}
       
	for info, sid in pairs(lc_list) do        
		-- wprintf(" out_new_lc~C0D %4d~C0B =~C0A '%s'~C07", sid, info) 
		sak.out_new_lc(sid, info)
	end
 
	local sid = 593
	local objt = g_sim:story_object(sid)
	if not objt then     
		wprintf("~C0C #ERROR: level changer not exists~C0D %d~C0C, trying respawn~C07", sid)
		g_sim:create(g_sim:spawn_id(sid))
	end                            
  
	local lname = level.name()
	local sname = get_value("level_on_save", "")
	wprintf('~CF0[~T/~U/~B]. #PERF: updating npc tables ~C07'); 
	amk_offline_alife.update_npc_tables()       
	if lname ~= sname then
		wprintf('~CF0[~T/~U/~B]. #PERF: updating map spots~C0A %s / %s~C07 ~C07', lname, sname)
		update_spots(lname, sname)
	end    
  
	obj = g_sim:story_object(story_ids.aes_exit_to_pripyat)
	if obj then
		level.map_add_object_spot_ser(obj.id,"level_changer_self","to_pripyat")
	end
	wprintf('~CF0[~T/~U/~B]. #PERF: updating weahter ~C07');
    
	schedule.add ("r_sun", "amk_mod.restore_sun()", 50)
	if get_value("blowout", 0) > 0 and get_value("blowout", 0) <4 then
		level.add_cam_effector("camera_effects\\earthquake.anm", 2002, true,"")
		if bt<1 then
			dbg_set_w("default_pre_blowout",true)
			level.add_pp_effector("vibros.ppe", 2001, true)
			blowout_psy_sound("start")
		end
	end
	if get_value("blowout", 0) > 0 then
		level.block_change_level(true)
	end
  
	sak.get_command("unbind contacts")
	-- sak.get_command("cl_cod_pickup_mode off")
    wprintf('~CF0[~T/~U/~B]. #PERF: amk_mod.check_spawn end~C07');
end

function restore_sun()
    --ODS( sprintf("[~T]. #DBG: restore_sun") )
    timers.initialize_timers()

    local lname = level.name()
    local sname = get_value("level_on_save", "")
    --wprintf("[~T]. #DBG: weather %s name, sname=%s, w = %s", lname, sname, w)
	if get_value("blow_started",0)==0 then
		start_blow_timer()
		set_value("blow_started",1)
	end
	if tmp_intro then
		tmp_intro=false
	end
	if db.actor then
		sak.some_updates()
		vergas_art.spawn_art()
	end
	idMapNow = g_sim:level_id()
	sMapNow = (idMapNow and g_sim:level_name(idMapNow)) or ""
	db.idMapSav = get_value("map_sav", 0)
	db.sMapSav = (db.idMapSav ~= 0 and g_sim:level_name(db.idMapSav)) or ""
	db.idMapNow,db.sMapNow = idMapNow,sMapNow
	set_value("map_sav", idMapNow)
	set_value("level_on_save", lname)
    sak.start_progress()
	sak.amb_clear()
end

function freeplay()
	set_value("freeplay", 1)
	local obj = g_sim:story_object(story_ids.aes_exit_to_pripyat)
	if not obj then   
		misc.spawn_by_name ('exit_to_pripyat_from_st1')
	end
	for a=1,5 do
		if (amk_anoms) then
			amk_anoms.after_blow_on()
		end
	end
end

local function get_community_strings(community,num)
	return translate(community.."_news_"..lua_random(num))
end

function show_news()
	timers.start_timer("show_news_main",49,"news_main.on_news()")
	local min_rand=lua_random(27,53)
	timers.start_timer("show_news",0,0,min_rand,"amk_mod.show_news()")
	local ln = level.name()
	if (news_main.isIsolatedLevel(ln)==true) or db.actor:has_info("pda_is_broken") then return end
	if lua_random()>0.5 then
		if lua_random()>0.875 then
			if lua_random()>0.5 then
				local dolg_news=get_community_strings("dolg",8)
				db.actor:give_game_news(dolg_news,"ui\\ui_iconsTotal", Frect():set(498,141,83,47), 4000, 15000)
			else
				local freedom_news=get_community_strings("freedom",7)
				db.actor:give_game_news(freedom_news,"ui\\ui_iconsTotal", Frect():set(498,94,83,47), 3000, 15000)
			end
		end 
	else
		if lua_random()>0.5 then
			local info,who,uniq,who2,uniq2,info2=amk_uniq_news_lists.get_strings()
			if (info=="" or not has_alife_info(info)) and (info2=="" or has_alife_info(info2)) then
				local name,sname = amk_names_lists.get_strings()
				if who~="" then
					amk.send_tip(uniq,who,nil,15,"uniq","news","gray")
				else
					amk.send_tip(uniq,name.." "..sname,nil,15,"uniq","news","gray")
				end
				if uniq2~="" then
					name,sname = amk_names_lists.get_strings()
					if who2~="" then
						amk.send_tip(uniq2,who2,10,15,"uniq","news","gray")
					else
						amk.send_tip(uniq2,name.." "..sname,7,15,"uniq","news","gray")
					end
				end
			end
		end
	end
end

