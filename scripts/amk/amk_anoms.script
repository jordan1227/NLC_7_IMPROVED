local on_anoms_per_level={}
local anti_spawn_zones={}
local arts_spawn_restr = {}

function init()
	local lname=level.name()
	local ini=ini_file("scripts\\amk\\anoms\\anoms.ltx")                                                              
  
	if ini:section_exist(lname) then
		for a = 0, ini:line_count(lname) - 1 do
			local result, id, _ = ini:r_line(lname, a, "", "") 
			if result and amk.trim(id)~="" then        
				local s = string.explode(",", id, true)
				local v = vector():set(tonumber(s[1]),tonumber(s[2]),tonumber(s[3]))
				table.insert(anti_spawn_zones,{v, tonumber(s[4])})
			end
		end
	end
	
	ini=ini_file("scripts\\amk\\anoms\\arts_spawn_restr.ltx")
	if ini:section_exist(lname) then
		for a = 0, ini:line_count(lname) - 1 do
			local result, id, _ = ini:r_line(lname, a, "", "")
			if result and amk.trim(id)~="" then        
				local s = string.explode(",", id, true)
				local tbl = {}
				for k,v in ipairs(s) do
					tbl[k] = tonumber(v)
				end
				table.insert(arts_spawn_restr, tbl)
			end
		end
	end
	-- dump_table(arts_spawn_restr)
	
	ini:release()
	collect_info()
end

function test_around(pos, radius)
	local ids = misc.find_around(pos, "physic_destroyable_object", radius)
	local cnt = #ids
	local result=false
	if cnt > 0 then
		for i=1,cnt do
			local obj = g_sim:object(ids [i])
			if (obj ~=nil) then
				local pk = get_netpk(obj,1)
				local data = pk:get()
				local v = data.visual_name
				if strpos(v, "box_wood") ~=nil then result=true end
			end
		end
		return result
	end
	return false
 end

