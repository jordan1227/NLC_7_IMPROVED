function detector_quest_done_check()
	if has_alife_info("detector_quest_start") and not has_alife_info("detector_quest_end") and not has_alife_info("detector_quest_fail") and not has_alife_info("detector_quest_refuse") then
		if not has_alife_info("detector_quest_done") then
			local q_tbl = get_value("art_detect_quest_tbl", {})
			local flag1, flag2, flag3 = false, false, false
			for k,v in pairs(q_tbl) do
				if k == "lvl1" then
					local count = 0
					for _,vv in pairs(v) do
						count = count + vv
						if count >= 3 then
							flag1 = true
							break
						end
					end
				elseif k == "lvl2" then
					local count = 0
					for _,vv in pairs(v) do
						count = count + vv
						if count >= 2 then
							flag2 = true
							break
						end
					end
				elseif k == "lvl9" then
					local count = 0
					for _,vv in pairs(v) do
						count = count + vv
						if count >= 1 then
							flag3 = true
							break
						end
					end	
				end
			end
			if flag1 and flag2 and flag3 then
				db.actor:give_info_portion("detector_quest_done")
			end
		end
	end
end
function detector_quest_have(give)
	local g = false
	if give and type(give) == "boolean" then 
		g = give
	end
	local items = get_shadow_inv():get_content(true)
	for k,v in items:ipairs() do
		if v.sect == "detector_art" then
			if g then
				sak.relocate_item("out", v.sect, 1)
				misc.release_obj(v.obj)
			end
			return true
		end
	end
end
function detector_quest_end_precond(give)
	local g = false
	if give and type(give) == "boolean" then
		g = give
	end
	local q_tbl = get_value("art_detect_quest_tbl", {})
	local inv = sak_inventory.rucksack
	local c_a, c_b, c_cap = 0, 0, 0
	local c_obj
	local exact_arts = {}
	for k,v in pairs(q_tbl["lvl1"]) do
		if c_a >= 3 then break end
		for kk,vv in pairs(inv) do
			if c_a >= 3 then break end
			if k == kk then
				local temp_count = 0
				for i=1,#vv do
					if c_a >= 3 then break end
					c_obj = client_obj(vv[i])
					if c_obj and isArt(c_obj) and c_obj:condition() > 0.98 then
						c_a = c_a + 1
						temp_count = temp_count + 1
						table.insert(exact_arts,vv[i])
						if temp_count == v then
							break
						end
					end
				end
				break
			end
		end
	end
	for k,v in pairs(q_tbl["lvl2"]) do
		if c_b >= 2 then break end
		for kk,vv in pairs(inv) do
			if c_b >= 2 then break end
			if k == kk then
				local temp_count = 0
				for i=1,#vv do
					if c_b >= 2 then break end
					c_obj = client_obj(vv[i])
					if c_obj and isArt(c_obj) and c_obj:condition() > 0.98 then
						c_b = c_b + 1
						temp_count = temp_count + 1
						table.insert(exact_arts,vv[i])
						if temp_count == v then
							break
						end
					end
				end
				break
			end
		end
	end
	for k,v in pairs(q_tbl["lvl9"]) do
		if c_cap >= 1 then break end
		for kk,vv in pairs(inv) do
			if k == kk then
				for i=1,#vv do
					c_obj = client_obj(vv[i])
					if c_obj and isArt(c_obj) then
						c_cap = c_cap + 1
						table.insert(exact_arts,vv[i])
						break
					end
				end
				break
			end
		end
	end
	if #exact_arts == 6 then
		if g then
			sak_dialog.cond_items_give(exact_arts,6)
		end
		return true
	else
		return false
	end
end
