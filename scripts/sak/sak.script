function turn_off_lamp(l_sid)
	local obj=level_object_by_sid(l_sid)
	if obj then
		obj:get_hanging_lamp():turn_off()
	end
end

function turn_on_lamp( l_sid )
    local obj = level_object_by_sid( l_sid )
    if obj then 
		obj:get_hanging_lamp():turn_on()
	end
end

local monolit_zone_msg = false
function monolit_zone_in()
	if not aver_monolit_zone then
		aver_monolit_zone = true
		if have_items_count("item_kamaz_accum",1) and not has_alife_info("akk_aver_done") and not monolit_zone_msg then
			send_tip(game.translate_string("monolit_zone_in"),game.translate_string("thinking_out_loud"),0,10,"g_g","sak","green")
			monolit_zone_msg = true
		end
	end
end
function monolit_zone_out()
	if aver_monolit_zone then
		aver_monolit_zone = false
	end
end

function some_updates()
	local npc=db.actor
	local lname=level.name()
	local sname=(get_value("level_on_save",""))
	if lname=="l04u_labx18" then
		check_x18_lamp()
	elseif lname=="l08u_brainlab" then
		check_x16_lamp()
	elseif lname=="labx8" then
		check_x8_lamp()
		check_x8_pribor()
	elseif lname=="l10_radar" then
		check_radar_pribor()
	elseif lname=="l01_escape" then
		check_sid_lamp()
	elseif lname=="l10u_bunker" then
		check_bun_lamp()
	elseif lname=="labx10" then
		check_x10_lamp()
	end
	
	if has_alife_info("pda_is_broken") then
		level.set_actor_allow_pda(false)
	end

	local r_task_rew,r_treasur,g_dif=(get_value("r_task_reward",1)),get_value("r_treas_items",1),(get_value("g_diff") or tonumber(level.get_game_difficulty()))
    get_command("g_game_difficulty "..game_difficulty_by_num[g_dif])

	if lname~=sname and sname~="" then
		-- фюсртыхэю mike фы  ёяртэр ьхЁъют
		if lname=="l07_military" and npc:has_info("lim_zub_last_info") and not npc:has_info("gross_merc_spawned") then
			mike.spawn_gross_merc()
			npc:give_info_portion("gross_merc_spawned")
		end
		if lname=="l10_radar" then
			if npc:has_info("mercs_call") and not npc:has_info("rad_mercs_spawned") then
				mike.spawn_radar_mercs()
				npc:give_info_portion("rad_mercs_spawned")
			end
			if npc:has_info("have_tools") and not npc:has_info("after_x12_spawned") then
				mike.spawn_after_x12()
				npc:give_info_portion("after_x12_spawned")
			end
			if has_alife_info("rad_izm_have") and not has_alife_info("halfdead_botan_sos") then
				timers.start_timer("halfdead_botan_msg",0,0,3,"sak.halfdead_botan_sos_msg()")
				npc:give_info_portion("halfdead_botan_sos")
			end
		end
		if lname=="l10u_bunker" and npc:has_info("mercs_gun_1_info") and not npc:has_info("x12_mercs_spawned") and not npc:has_info("mil_mercs_fire") then
			mike.spawn_x12_mercs()
			npc:give_info_portion("x12_mercs_spawned")
		end	
		if lname=="l05_bar" and npc:has_info("assistant_go_to_bar") and not npc:has_info("assistant2_umer") and not npc:has_info("assistant_bar") then
			npc:give_info_portion("assistant_bar") 	-- ґсшЁрхь ╠рҐтххтр
			misc.release_by_name("assistant2")
			misc.release_by_name("mil_vasilev") 	-- ґсшЁрхь ┬рёшы№хтр
		end
		-- фюсртыхэю mike фы  ёяртэр т ёрЁъюЄрух
		if lname=="l12u_sarcofag" then
			mike.spawn_in_sarcofag()
		end
		-- фюсртыхэю mike фы  ёяртэр т ╥хёых
		if lname=="generators" and not npc:has_info("tesla_gift_info") then
			mike.spawn_in_generators()
			npc:give_info_portion("tesla_gift_info")
		end
		-- фюсртыхэю mike фы  ёяртэр т ЁрщІхэҐЁх
		if lname=="deadcity" and not npc:has_info("deadcity_gift_info") then
			mike.spawn_in_deadcity()
			npc:give_info_portion("deadcity_gift_info")
		end
		-- фюсртыхэю mike фы  ёяртэр ьр Ґэшър т ╥╫ шыш ╧Ёшя Ґш
		if lname=="aver" and npc:has_info("mayatnik_aver_ready_info") and not npc:has_info("mayatnik_aver_info") then
			mike.add_mayatnik_aver()
			npc:give_info_portion("mayatnik_aver_info")
		end
		if lname=="l11_pripyat" and npc:has_info("mayatnik_prip_ready_info") and not npc:has_info("mayatnik_prip_info") then
			mike.add_mayatnik_prip()
			npc:give_info_portion("mayatnik_prip_info")
		end	
		if lname=="generators" then
			if npc:has_info("petrenko_tesla_job_info") and not npc:has_info("petrenko_tesla_job_done") then
				npc:give_info_portion("akk_is_ready")
			end
			if sname=="warlab" and npc:has_info("deactivate_radar_fall") and not npc:has_info("gen_hermit_new_gg") then
				timers.start_timer("mozgun_sms",0,0,2,"sak.mozgun_sms()")
			end
		end
		-- фюсртыхэю mike фы  ёяртэр т ╧Ёшя Ґш
		if lname=="l11_pripyat" then
			g_sim:create("amk_zone_sphere",vector():set(29.7,10,355.8), 139177, 2260)
		end	
		-- ґсшЁрхь ╚ёърҐхы  ш хую фЁґур ё ╥хёы√
		if lname=="red_forest" and npc:has_info("gen_iskatel_akkum_info") and not npc:has_info("gen_iskatel_akkum_done") then
			npc:give_info_portion("gen_iskatel_akkum_done")	
			misc.release_by_name("gen_iskatel_drug")
		end
		if lname~="limansk" then
			-- ґсшЁрхь ═хсютр шч ╦шьрэёър
			if npc:has_info("gen_iskatel_akkum_done") and not npc:has_info("ivan_umer") then	
				misc.release_by_name("ivan")
			end
			-- ґсшЁрхь ╘ЁрхЁр шч ╦шьрэёър
			if npc:has_info("info_fraer_pripyat_done") and not npc:has_info("fraer_umer") then	
				misc.release_by_name("td_stalker_fraer")
			end
			if npc:has_info("borov_lim_quest_surprise_info") and not npc:has_info("borzyi_borov_quest_surprise") then
				borov_offline_death()
			end
		end
		-- ґсшЁрхь ╘ЁрхЁр ё ─╥
		if lname~="l06_rostok" and npc:has_info("dt_fraer_dialog_done") and not npc:has_info("dt_fraer_pda_know") then
			npc:give_info_portion("dt_fraer_pda_know")	
		end
		-- ґсшЁрхь ╩юіхЁуґ ё ─╥
		if lname~="l06_rostok" and ( npc:has_info("dt_kocherga_secret_done") or npc:has_info("deactivate_radar_fall") ) then	
			misc.release_by_name("td_kocherga")
