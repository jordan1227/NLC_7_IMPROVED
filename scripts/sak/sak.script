function bar_investigation_body()
	local tbl = {}
	local trup = create_corpse("trup_dolg_dummy",sak.v3f(84.6492,0.3616,55.6066),1186,43099,9820,"[known_info]\nzub_investigation_body_info")
	table.insert(tbl,trup.id)
	
	local pos = {{85.4884,-0.0016,57.9925},{83.0438,-0.0011,57.9146}}
	for i=1,2 do
		local dead_dog = g_sim:create("physic_object",vector():set(pos[i][1],pos[i][2],pos[i][3]),30015,1221)
		if dead_dog then
			local pk = get_netpk(dead_dog,1)
			local data = pk:get()
			data.visual_name="monsters\\pseudodog\\pseudodog_grey_dead"
			pk:set(data)
			table.insert(tbl,dead_dog.id)
			local id = tostring(dead_dog.id)
			schedule.add("handle_investigation_dog"..id, "sak.handle_investigation_dog("..id..")", 500) 
		end
	end
	
	local item = g_sim:create("physic_object",vector():set(81.6353,-0.0015,53.1515),30015,1221)
	if item then
		local pk = get_netpk(item,1)
		local data = pk:get()
		data.visual_name="new_item\\meshok"
		data.fixed_bones = "link"
		data.mass = 50
		pk:set(data)
		table.insert(tbl,item.id)
	end
	
	for i=0,2 do
		local y = -0.0019 + i * 0.3
		item = g_sim:create("physic_object",vector():set(77.4102,y,53.2347),30015,1221)
		if item then
			local pk = get_netpk(item,1)
			local data = pk:get()
			data.visual_name="new_item\\box_wood_mil"
			data.fixed_bones = "bone01"
			data.mass = 50
			pk:set(data)
			table.insert(tbl,item.id)
		end
	end
	
	item = g_sim:create("physic_object",vector():set(84.4310,-0.0014,54.4109),30015,1221)
	if item then
		local pk = get_netpk(item,1)
		local data = pk:get()
		data.visual_name="new_item\\box_conserv_full"
		data.fixed_bones = "bone01"
		data.mass = 50
		pk:set(data)
		table.insert(tbl,item.id)
	end

	set_value("investigation_objs",tbl)
end
function handle_investigation_dog(id)
	-- local x,y,z = lua_random(0,3),1,lua_random(1,3)
	-- coord_params.set_obj_dir(id,x,y,z)
	misc.touch_obj(client_obj(id))
end
function freq_scanner_handle()
	close_window()
	set_inactivate_input_time(15)
	if not has_alife_info("borov_rep_up_done") then
		schedule.add("freq_scanner_signal1","sak.freq_scanner_signal(1)", 3000)
		schedule.add("freq_scanner_signal2","sak.freq_scanner_signal(2)", 17000)
		schedule.add("fix_relations","sak.fix_relations()", 40000)
		db.actor:give_info_portion("borov_rep_up_done")
		sak.send_tip(game.translate_string("freq_scanner_handle"),game.translate_string("thinking_out_loud"),35,15,"g_g","sak","green")
	else
		sak.send_tip(game.translate_string("freq_scanner_handle_2"),game.translate_string("thinking_out_loud"),10,15,"g_g","sak","yellow")
	end
end
function freq_scanner_signal(num)
	vergas_lib.s_play("script_replics\\radio\\message\\radio_noise_"..tostring(num))
end
function fix_relations()
	local a = db.actor 
	local r = a:character_reputation()
	-- log2("fix_relations: actor rep = %d",r)

	local enemies = {}
	for _,v in pairs(db.creatures) do
		if v and v:is_stalker() and v:alive() then
			local com = v:character_community()
			if com ~= "bandit" and com ~= "military" and com ~= "killer" and com ~= "monolith" and com ~= "zombied" then
				if v:relation(db.actor) == game_object.enemy then
					table.insert(enemies, v:id())
				end
			end
		end
	end
	-- log2("fix_relations:dumping enemies tbl\n")
	-- dump_table(enemies)
	if #enemies > 0 and #enemies < 4 then
		for _, v in ipairs(enemies) do
			local obj = client_obj(v)
			if obj then
				-- log2("fix_relations: making npc [%s] neutral",obj:name())
				obj:set_relation(game_object.neutral,db.actor)
			end
		end
	end
end
function val_raid_evac()
	for id=1,BAD_OBJ_ID,1 do
		local obj = server_obj(id)
		if obj and IsStalker(obj) and obj:alive() and obj:community() == 'military' then
			local lvl = g_sim:level_name(game_graph():vertex(obj.m_game_vertex_id):level_id())
			if lvl == 'l04_darkvalley' then
				-- log2("val_raid_evac: releasing [%s]",obj:name())
				misc.release_obj(obj)
			end
		end
	end
end

