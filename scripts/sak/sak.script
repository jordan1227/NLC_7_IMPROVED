	vergas_lib.s_play("script_sound\\treasure_sounds\\treasure_2_open",1)
end
function s_play_rem_close()
	vergas_lib.s_play("script_sound\\treasure_sounds\\treasure_2_close",1)
end

local rep_percent=0.1
local rep_percent_tiski=0.15
function repair_boxoutfit(repiout,repiweap)
	local actr=db.actor
	local dir=device().cam_dir
	local a=math.atan2(dir.x,dir.z)
	local xdelta=math.sin(a)
	local zdelta=math.cos(a)
	local pos=actr:position()
	local lvid=actr:level_vertex_id()
	local gvid=actr:game_vertex_id()
	local obj= g_sim:create("physic_object",v3f((pos.x+xdelta), pos.y+0.1, (pos.z+zdelta)), lvid, gvid)
	if obj then
		local open="[logic]\nactive = ph_button@closed\n[ph_button@closed]\ntooltip = search_self_rep\nanim = rembox_close_static\non_press = %=sak.actor_hide_weapon() =sak.s_play_rem_open()% ph_button@open\n[ph_button@open]\ntooltip = \nanim = rembox_open\non_timer = 1900| %=sak.restore_weap() +rem_open% ph_button@opened\n[ph_button@opened]\ntooltip = \nanim = rembox_open_static\non_info = {+rem_close} ph_button@close %=sak.actor_hide_weapon() =sak.s_play_rem_close() -rem_close -rem_open%\n[ph_button@close]\ntooltip = \nanim = rembox_close\non_timer = 1900| ph_button@close_end\n[ph_button@close_end]\ntooltip = \nanim = rembox_close_static"
		local dirs=math.atan2(-dir.x,dir.z)-1.57
		obj.direction = vector():set(0,dirs,0)
		local pk = get_netpk(obj,1)
		local data = pk:get()
			data.visual_name = "new_item\\rembox"
			data.custom_data = open
			data.skeleton_name = "rembox_close_static"
			data.mass=20
			data.fixed_bones="link"
			pk:set(data)
		local robjd= g_sim:create("m_repair_boxoutfit",v3f((pos.x+xdelta), pos.y+0.3, (pos.z+zdelta)), lvid, gvid)
		local c_box= misc.spawn_obj("closer_box", robjd.position, robjd.id, 1)
		if repiout~=0 then
			se_respawn.create_ammo ("repair_itemoutfit", robjd.position, robjd.level_vertex_id, robjd.game_vertex_id, robjd.id, repiout)
		end
		if repiweap~=0 then
			se_respawn.create_ammo ("repair_item_weapon", robjd.position, robjd.level_vertex_id, robjd.game_vertex_id, robjd.id, repiweap)
		end
		robjd.direction = vector():set(0,dirs,0)
		local pk = get_netpk(robjd,1)
		local data = pk:get()
		data.custom_data = "[logic]\ncfg = scripts\\self_rep_box.ltx"
		pk:set(data)
		self_rep_boxes = get_value("self_rep_boxes", {})
		self_rep_boxes[c_box.id] = {}
		self_rep_boxes[c_box.id]["treas"]=robjd.id
		self_rep_boxes[c_box.id]["phis"]=obj.id
		self_rep_boxes[c_box.id]["direct"]=dirs
		set_value("self_rep_boxes", self_rep_boxes)
	end
	close_window()
end

function repair_box_close(obj)
	close_window()
	-- UpdateRegistry(false)
	self_rep_boxes = get_value("self_rep_boxes", {})
	local temp_t = {}
	local c_box_id=obj:id()
	local rbox = nil
	for k,v in pairs(self_rep_boxes) do
		if tostring(k) == tostring(c_box_id) then
			rbox = v
		else
			temp_t[k] = v
		end
	end
	if rbox == nil then
		log2("rbox == nil")
		return
	end
  
	local objd_id,objr_id,dirs = rbox["treas"], rbox["phis"], rbox["direct"]
	local out_object,outr_object = client_obj(objd_id),client_obj(objr_id)
	local repiout=0
	local repiweap=0
	if out_object then
		local cnt = out_object:inv_box_count()
		for i = 0, cnt - 1 do
			local item = out_object:object_from_inv_box(i)
			if item then
				local sect=item:section()
				if     strposx(sect, "repair_itemoutfit")  then repiout  = repiout  + 1
				elseif strposx(sect, "repair_item_weapon") then repiweap = repiweap + 1
				else   
				--wprintf(" non expected item %s in repair box", item:name())     
				out_object:transfer_item(item, db.actor) 
				end
			end
		end
		--send_tip("┬ ЁхьюэҐэюь  їшъх:\\n╬Ёґцхщэ√є ЁхьъюьяыхъҐют - "..repiweap.." ЇҐ.\\n╩юьяыхъҐют фы  сЁюэш - "..repiout.." ЇҐ.",nil,2,5,"g_g","no", "green")
		misc.release_obj(obj)
		misc.release_obj(out_object)
		self_rep_boxes = {}
		set_value("self_rep_boxes", temp_t)
		db.actor:give_info_portion("rem_close")
		schedule.add("cl_rep", "sak.repair_box_closed("..objr_id..","..repiout..","..repiweap..","..dirs..")", 2500)
	end
end

function repair_box_closed(obj_id,repiout,repiweap,dirs)
	local robjd=client_obj(tonumber(obj_id))
	local pos=robjd:position()
	local dir=tonumber(dirs)
	if robjd then
		misc.release_obj(obj_id)
	end
	local r_box=misc.spawn_obj("repair_boxoutfit", pos)
	if r_box then
		r_box.direction = vector():set(0,dir,0)
		local pk = get_netpk(r_box,1)
		local data = pk:get()
		data.custom_data = repiout..","..repiweap
		pk:set(data)
	end
	restore_weap()
	db.actor:disable_info_portion("rem_close")
end

local function check_repairable_cond(cond_to_check, tiski_flag)
	local cond = 0.87
	if tiski_flag then
		cond = 0.75
	end
	return cond_to_check >= cond and cond_to_check < 0.985
end

local function is_repairable_item(sec)
	local cant_repair_tbl = {"wpn_rpg", "wpn_flame", "gauss", "exo"}
	for _,v in ipairs(cant_repair_tbl) do
		if strposx(sec,v) then
			if v == "exo" and get_value("exo_self_rep",false) then
				return true
			end
			return false
		end
	end
	return true
end

local function get_repair_coeff()
	local cur_exp = actor_stats.get_points("repair_exp") or 0
	local val = math.modf(cur_exp / 10)
	if val > 5 then
		val = 5
	end
	return val
end

local function play_repair_snd(num)
	local repair_sound={
	  "device\\tiski_pistol_",
	  "device\\tiski_avto_",
	  "device\\tiski_bronik_"
	  }

	local r = lua_random(1,3)
	local sound = repair_sound[num]..r
	local snd_obj = xr_sound.get_safe_sound_object(sound)
	snd_obj:play_no_feedback(db.actor, sound_object.s2d, 0, vector(), 1.0)
end

local weapon_def_rep = 0.07
local armor_def_rep = 0.05

function repair_box_repair(obj)
	if obj then
		close_window()
		local actor=db.actor
		local sec = obj:section()
		local slot_1, slot_2, armor
		if sec == "repair_item_weapon" then
			slot_1 = actor:item_in_slot(1)
			slot_2 = actor:item_in_slot(2)
		elseif sec == "repair_itemoutfit" then
			armor = actor:item_in_slot(6)
		else
			return
		end
		
		local slot_to_repair = -1
		if slot_1 and check_repairable_cond(slot_1:condition()) then
			slot_to_repair = 1
		elseif slot_2 and check_repairable_cond(slot_2:condition()) then
			slot_to_repair = 2
		elseif armor and check_repairable_cond(armor:condition()) then
			slot_to_repair = 6
		end
		
		if slot_to_repair == -1 then
			if (slot_1 and slot_1:condition() < 0.87) or (slot_2 and slot_2:condition() < 0.87) or (armor and armor:condition() < 0.87) then
				send_tip(game.translate_string("st_repair_box_1"),game.translate_string("thinking_out_loud"),1,7,"g_g","pda_news","red")
			else
				send_tip(game.translate_string("st_repair_box_2"),game.translate_string("thinking_out_loud"),1,7,"g_g","pda_news","red")
			end
			misc.spawn_to(obj:section().."_feik", actor)
			amk.remove_item(obj)
			return
		end
		
		local item = actor:item_in_slot(slot_to_repair)
		if item and not is_repairable_item(item:section()) then
			send_tip(game.translate_string("st_repair_box_3"),game.translate_string("thinking_out_loud"),1,7,"g_g","pda_news","red")
			misc.spawn_to(obj:section().."_feik", actor)
			amk.remove_item(obj)
			return
		end
		
		local coeff = get_repair_coeff() / 100
		if slot_to_repair ~= 6 then
			actor_hide_weapon()
			local rep_point = item:condition() + coeff + weapon_def_rep
			if rep_point > 1 then rep_point = 1 end
			item:set_condition(rep_point)
			play_repair_snd(slot_to_repair)
			send_tip(game.translate_string("st_repair_box_4"),game.translate_string("thinking_out_loud"),12,5,"g_g","pda_news","green")
			timers.start_timer("time_rep",13,"sak.restore_weap()")
			actor_stats.add_points("repair_exp", "st_repair_weapon", 1, 1)
		else
			if strpos(item:section(),"bandit_veteran_",1,true) or strpos(item:section(),"bandit_master_",1,true) then
				send_tip(game.translate_string("st_repair_box_5"),game.translate_string("thinking_out_loud"),1,7,"g_g","pda_news","red")
				misc.spawn_to(obj:section().."_feik", actor)
			else
				actor_hide_weapon()
				vergas_masks.set_mask_on_off_flag(false)
				local rep_point=item:condition() + coeff + armor_def_rep
				if rep_point > 1 then rep_point = 1 end
				amk_mod.repair_armor(rep_point)
				play_repair_snd(3)
				send_tip(game.translate_string("st_repair_box_6"),game.translate_string("thinking_out_loud"),12,5,"g_g","pda_news","green")
				schedule.add("tm_rep", "sak.return_mask()", 12500)
				actor_stats.add_points("repair_exp", "st_repair_armor", 1, 1)
			end
		end
		amk.remove_item(obj)
	end
end
function return_mask()
	vergas_masks.set_mask_on_off_flag(true)
	restore_weap()
end

local rep_armor

function repair_on()
	local tiski = nil
	for a,i in pairs(db.storage) do
		local objg = client_obj(a)
		if objg then
			if (objg and strpos(objg:name(),"_tiski_repair",1,true) and objg:position():distance_to(db.actor:position()) < 3
				and objg:position():distance_to(db.actor:position()) > 1.0) then
				tiski = objg
				break
			end
		end
	end
	
	if tiski~=nil then
		local slot_to_repair = -1
		local slot_1 = db.actor:item_in_slot(1)
		local slot_2 = db.actor:item_in_slot(2)
		local armor = db.actor:item_in_slot(6)
		
		if slot_1 and check_repairable_cond(slot_1:condition(),true) then
			slot_to_repair = 1
		elseif slot_2 and check_repairable_cond(slot_2:condition(),true) then
			slot_to_repair = 2
		elseif armor and check_repairable_cond(armor:condition(),true) then
			slot_to_repair = 6
		end
		
		if slot_to_repair == -1 then
			if (slot_1 and slot_1:condition() < 0.75) or (slot_2 and slot_2:condition() < 0.75) or (armor and armor:condition() < 0.75) then
				send_tip(game.translate_string("st_repair_box_1"),game.translate_string("thinking_out_loud"),1,7,"g_g","pda_news","red")
			else
				send_tip(game.translate_string("st_repair_box_2"),game.translate_string("thinking_out_loud"),1,7,"g_g","pda_news","red")
			end
			return
		end
		
		local slot_obj = db.actor:item_in_slot(slot_to_repair)
		local slot_id = slot_obj:id()
		local slot_sec = slot_obj:section()
		
		if slot_obj and not is_repairable_item(slot_sec) then
			send_tip(game.translate_string("st_repair_box_3"),game.translate_string("thinking_out_loud"),1,7,"g_g","pda_news","red")
			return
		end
		
		local r_box_id = sak_inventory.eatable["repair_boxoutfit"][1]
		local r_box = server_obj(r_box_id)
		local pk = get_netpk(r_box,1)
		local data = pk:get()
		local str = data.custom_data
		
		local rem = vergas_lib.str_explode(",",str,true)
		local repiout = tonumber(rem[1]) or 0
		local repiweap = tonumber(rem[2]) or 0
		
		if ( ( slot_to_repair == 1 or slot_to_repair == 2 ) and repiweap == 0 ) or ( slot_to_repair == 6 and repiout == 0 ) then
			send_tip(game.translate_string("st_repair_box_7"),game.translate_string("thinking_out_loud"),1,7,"g_g","pda_news","red")
			return
		end
		
		actor_hide_weapon()
		local ltx = system_ini()
		local vis_str = "visual"
		local t_pos = tiski:position()
		local pos_x_adjust = 0.09
		local pos_z_adjust = 0.1
		
		if tiski:name() == 'val_tiski_repair' or tiski:name() == 'mil_tiski_repair_03' then
			pos_x_adjust = t_pos.x + pos_x_adjust
		else
			pos_x_adjust = t_pos.x - pos_x_adjust
		end
		
		if slot_to_repair ~= 2 then
			pos_z_adjust = 0
		end
		
		if slot_to_repair ~= 6 then
			local vis = tostring(ltx:r_string(slot_sec,vis_str))
			create_physic_object(vis,v3f(pos_x_adjust,t_pos.y+0.20,t_pos.z-pos_z_adjust),tiski:level_vertex_id(),tiski:game_vertex_id(),slot_obj)
			play_repair_snd(slot_to_repair)
			schedule.add("tm_rep", "sak.repair_tiski_do("..slot_to_repair..","..slot_id..","..r_box_id..","..repiout..","..repiweap..")", 12500)
		else
			if strpos(slot_sec,"bandit_veteran_",1,true) or strpos(slot_sec,"bandit_master_",1,true) then
				send_tip(game.translate_string("st_repair_box_5"),game.translate_string("thinking_out_loud"),1,7,"g_g","pda_news","red")
				restore_weap()
			else
				local vis = tostring(ltx:r_string(slot_sec,vis_str))
				create_physic_object(vis,v3f(t_pos.x,t_pos.y+0.28,t_pos.z),tiski:level_vertex_id(),tiski:game_vertex_id(),slot_obj)
				play_repair_snd(3)
				vergas_masks.set_mask_on_off_flag(false)      
				schedule.add("tm_rep", "sak.repair_tiski_do("..slot_to_repair..","..slot_id..","..r_box_id..","..repiout..","..repiweap..")", 12500)
			end
		end
	else
		send_tip(game.translate_string("st_repair_box_8"),game.translate_string("thinking_out_loud"),1,7,"g_g","pda_news","red")
	end
end

function repair_tiski_do(slot,slot_obj_id,r_box_id,repiout,repiweap)
	local slot_obj = client_obj(slot_obj_id)
	local coeff = get_repair_coeff() / 100
	if slot_obj then
		if slot == 1 or slot == 2 then
			local rep_point = slot_obj:condition() + ( (coeff + weapon_def_rep) * 1.5 )
			if rep_point > 1 then rep_point = 1 end
			slot_obj:set_condition(rep_point)
			send_tip(game.translate_string("st_repair_box_4"),game.translate_string("thinking_out_loud"),1,7,"g_g","pda_news","green")
			repiweap = repiweap - 1
			actor_stats.add_points("repair_exp", "st_repair_weapon", 1, 1)
		else
			local rep_point = slot_obj:condition() + ( (coeff + armor_def_rep ) * 1.5 )
			if rep_point > 1 then rep_point = 1 end
			amk_mod.repair_armor(rep_point)
			send_tip(game.translate_string("st_repair_box_6"),game.translate_string("thinking_out_loud"),1,7,"g_g","pda_news","green")
			repiout = repiout - 1
			actor_stats.add_points("repair_exp", "st_repair_armor", 1, 1)
			vergas_masks.set_mask_on_off_flag(true)
		end
	end
	local r_box = server_obj(r_box_id)
	local pk = get_netpk(r_box,1)
	local data = pk:get()
	data.object_flags = bit_not(5)
	data.custom_data = repiout..","..repiweap
	pk:set(data)
	misc.release_obj(rep_armor)
	rep_armor = nil
	restore_weap()
end
-- Manool: фюя. ЄшъёрІш  т Ґшёърє
function create_physic_object(p_visual,p_position,p_lvertex_id,p_gvertex_id,clobj)
	local obj=misc.spawn_obj("physic_object", p_position)
	if obj then
		local pk = get_netpk(obj,1)
		local data = pk:get()
		data.visual_name = p_visual
		if clobj then data.fixed_bones = clobj:get_bone_name(0) end
		data.physic_type=3
		pk:set(data)    

		obj = alife():object(obj.id)
		obj:used_ai_locations(false)
		local ini = obj:spawn_ini()
		ini.readonly = false
		for _, k in ipairs({"dynamic", "ragdoll", "static"}) do
			local kk = "ignore_" .. k
			ini:w_bool("collide", kk, true)
		end
		obj:save_spawn_ini()
		-- Manool: ёъЁ√Ґшх ъюёҐхщ юҐёґҐёҐтґ■їшє рффюэют
		if clobj:is_weapon() then
			local hb = {}
			if ogse_wpn_utils.get_scope_status(clobj) == 2 and not ogse_wpn_utils.get_scope_flag(clobj) then
				hb["wpn_scope"] = true
			end
			if ogse_wpn_utils.get_grenade_launcher_status(clobj) == 2 and not ogse_wpn_utils.get_grenade_launcher_flag(clobj) then
				hb["wpn_launcher"] = true
			end
			if ogse_wpn_utils.get_silencer_status(clobj) == 2 and not ogse_wpn_utils.get_silencer_flag(clobj) then
				hb["wpn_silencer"] = true
			end
			level.client_spawn_manager():add(obj.id, -1,
				function(id, item)
					for bone, _ in pairs(hb) do
						item:set_bone_visible(bone, false)
					end
				end
			)
		end
	end
	rep_armor=obj.id
end

function have_n_repair_item_weapon(n)
	local repiweap=0
	if sak_inventory.rucksack["repair_item_weapon_feik"] then
		repiweap=#sak_inventory.rucksack["repair_item_weapon_feik"]
	end
	if sak_inventory.eatable["repair_boxoutfit"] then
		for a=1,#sak_inventory.eatable["repair_boxoutfit"] do
			local repbox_id=sak_inventory.eatable["repair_boxoutfit"][a]
			local rem={}
			local sobj = alife():object(repbox_id)
			local pk = get_netpk(sobj,1)
			local data = pk:get()
			local str=data.custom_data
			rem = vergas_lib.str_explode(",",str,true)
			local weap=tonumber(rem[2]) or 0
			repiweap=repiweap+weap
		end
	end
	return repiweap >=n
end
function give_n_repair_item_weapon(n)
	local repiwp=n
	if sak_inventory.rucksack["repair_item_weapon_feik"] then
		for a=1,#sak_inventory.rucksack["repair_item_weapon_feik"] do
			local id=sak_inventory.rucksack["repair_item_weapon_feik"][a]
			local obj= g_sim:object(id)
			if obj then
				misc.release_obj(obj)
				repiwp=repiwp-1
			end
			if repiwp==0 then break end
		end
		sak_inventory.need_update_inventory()
		if repiwp==0 then 
			relocate_item("out", "repair_item_weapon", n)
			return
		end
	end
	local repbox_id=sak_inventory.eatable["repair_boxoutfit"][1]
	local rem={}
	local sobj = alife():object(repbox_id)
	local pk = get_netpk(sobj,1)
	local data = pk:get()
	local str=data.custom_data
	rem = vergas_lib.str_explode(",",str,true)
	local repiout=tonumber(rem[1]) or 0
	local repiweap=tonumber(rem[2]) or 0
	repiweap=repiweap - repiwp
	data.custom_data = repiout..","..repiweap
	pk:set(data)
	relocate_item("out", "repair_item_weapon", n)
end
function have_n_repair_itemoutfit(n)
	local repiweap=0
	if sak_inventory.rucksack["repair_itemoutfit_feik"] then
		repiweap=#sak_inventory.rucksack["repair_itemoutfit_feik"]
	end
	if sak_inventory.eatable["repair_boxoutfit"] then
		for a=1,#sak_inventory.eatable["repair_boxoutfit"] do
			local repbox_id=sak_inventory.eatable["repair_boxoutfit"][a]
			local rem={}
			local sobj = alife():object(repbox_id)
			local pk = get_netpk(sobj,1)
			local data = pk:get()
			local str=data.custom_data
			rem = vergas_lib.str_explode(",",str,true)
			local weap=tonumber(rem[1]) or 0
			repiweap=repiweap+weap
		end
	end
	return repiweap >=n
end
function give_n_repair_itemoutfit(n)
	local repiwp=n
	if sak_inventory.rucksack["repair_itemoutfit_feik"] then
		for a=1,#sak_inventory.rucksack["repair_itemoutfit_feik"] do
			local id=sak_inventory.rucksack["repair_itemoutfit_feik"][a]
			local obj= g_sim:object(id)
			if obj then
				misc.release_obj(obj, 'sak.script:2842')
				repiwp=repiwp-1
			end
			if repiwp==0 then break end
		end
		sak_inventory.need_update_inventory()
		if repiwp==0 then 
			relocate_item("out", "repair_itemoutfit", n)
			return
		end
	end
	local repbox_id=sak_inventory.eatable["repair_boxoutfit"][1]
	local rem={}
	local sobj = alife():object(repbox_id)
	local pk = get_netpk(sobj,1)
	local data = pk:get()
	local str=data.custom_data
	rem = vergas_lib.str_explode(",",str,true)
	local repiout=tonumber(rem[1]) or 0
	local repiweap=tonumber(rem[2]) or 0
	repiout=repiout - repiwp
	data.custom_data = repiout..","..repiweap
	pk:set(data)
	relocate_item("out", "repair_itemoutfit", n)
end
