function start_progress()
	local act = db.actor
	local frun  = ( get_value("first_run") == nil )  
	local lname = level.name()
  
	if frun then
		level.add_pp_effector("agr_u_fade.ppe", 3121, false)
		sak_inventory.inventory_control()                                
		local armor = sak_inventory.rucksack["stalker_outfit"]													  
		if armor then
			params.upd_condition(armor, 0.18)
			schedule.add("dmg_first_outfit", "sak.damage_first_outfit()", 500)         
		else
			ODS("~C0C[~T]. #ERROR:~C07 not found stalker_outfit in actor inventory")  
		end
		set_value("first_run", false)
		sleep_manager.change_sleepiness(100)
		params.satiety_add(-0.8)
		-- params.offs_huds()
		add_first_spawn()
		for aa = 1, 15 do
			sak_dialog.search_npc(rand_stalk[aa],"fake_new_gg_"..aa,"fake_new_"..aa)
		end
		sak_dialog.search_npc("esc_green_respawn_2","dsc_green_near_dv_dialog","dsc_near_dv")
		act:give_info_portion("esc_lamp_1_on")
		den1s_test.on_new_game()
		oxyr.spawn_restr_agro_undrgrnd()
		s_fixes.new_game_spawn()
		g_sim:create("green_guard",vector():set(246.0223,-0.0579,-192.9343),688041,4091)
		local obj = server_obj("mil_cook_treasure")
		if obj then
			level.map_add_object_spot_ser(obj.id,"crlc_big_treasure0","?")
		end
		for _,v in ipairs({9138,9188,9161,9162}) do
			local lc = g_sim:story_object(v)
			if lc then
				misc.release_obj(lc)
			end
		end
		for a=15,25 do
			act:give_info_portion("labx10_lamp_"..a.."_off")
		end
		game_began=true
	else
		schedule.add ("paused_game", "sak.paused_game()", 500)  
		local rand=lua_random(1,4)
		act:give_info_portion(mus_bar[rand]) 
		act:give_info_portion("ui_inventory") -- ьюцхҐ чфхё№ юэю ёсюшҐ№ эх сґфхҐ?   		
	end
  
	day_shmoney      = timers.Get_Game_Days()+1
	day_money        = day_shmoney / 2
	mass_add         = math.floor(day_shmoney / 7)

	local level_poisoned = { -- ъю¤ЄЄшІшхэҐ√  фютшҐюёҐш тючфґєр эр ърцфюь ґЁютэх
	["l01_escape"]=0.9,
	["l02_garbage"]=1,
	["l03_agroprom"]=1,
	["l03u_agr_underground"]=1.7,
	["l04_darkvalley"]=1,
	["k01_darkscape"]=1,
	["l04u_labx18"]=1.8,
	["l05_bar"]=1,
	["l06_rostok"]=1.3,
	["l07_military"]=1.4,
	["l08_yantar"]=1.4,
	["l08u_brainlab"]=2,
	["l10_radar"]=1.6,
	["limansk"]=1.5,
	["lost_village"]=0.9,
	["marsh"]=0.9,
	["red_forest"]=1.5,
	["warlab"]=2.2,
	["labx10"]=2,
	["labx8"]=2.5,
	["generators"]=1.6,
	["aver"]=1,
	["hospital"]=1,
	["deadcity"]=1.7,
	["av_peshera"]=1,
	["l10u_bunker"]=3,
	["l11_pripyat"]=1.7,
	["l12_stancia_new"]=1.8,
	["l12_stancia_2_new"]=1.9,
	["l12u_control_monolith"]=1.9,
	["l12u_sarcofag"]=1.9
	}

	mask_poison      = (1.1 - tonumber(level_poisoned[lname])) * 0.2
	dog_psy          = level_difficulty[lname] - 0.79
	loka_on          = 1 + math.max (0, level_difficulty[lname]-1.3)
  
	if lname=="aver" then loka_on=5 end
	-- params.offs_huds()
	amk_mod.sync_done = true
	ui_params.move_mainwnd_static("static_weapon", nil, 668)
end

