function ruck_near_lc(box_id,flag_release)
	local lvl = level.name()
	local skip = const.underground(lvl) and lvl ~= 'l03u_agr_underground'
	if skip then return end
	local r_ids = {}
	local lc_ids = {}
	level.iterate_level_objects(function(obj)
		local sec = obj.section and obj:section()
		if sec == 'rucksack' then
			table.insert(r_ids,obj:id())
		elseif sec == 'level_changer' then
			table.insert(lc_ids,obj:id())
		end
	end)
	
	if box_id ~= nil and box_id ~= 0 then
		local dont_add = false
		for _,v in ipairs(r_ids) do
			if box_id == v then
				dont_add = true
				break
			end
		end
		if not dont_add then
			table.insert(r_ids,box_id)
		end
	end
	local box_obj = client_obj(box_id)
	
	-- log2("ruck_near_lc: #r_ids [%d], #lc_ids [%d]",#r_ids,#lc_ids)
	if #r_ids > 0 then
		-- log2("ruck_near_lc: found [%d] items",#r_ids)
		for i=1,#r_ids do
			local obj = client_obj(r_ids[i])
			if obj then
				-- log2("ruck_near_lc: checking [%s]",obj:name())
				for ii=1,#lc_ids do
					local lc = client_obj(lc_ids[ii])
					if lc and lc:name() ~= 'aver_exit_to_x18' then
						if lc:position():distance_to(obj:position()) < 50 then
							if box_obj and box_obj:name() == obj:name() then
								sak.send_tip(game.translate_string("ruck_near_lc"),game.translate_string("thinking_out_loud"),3,10,"g_g","sak","yellow")
							elseif flag_release and db.actor:position():distance_to(obj:position()) > 1 and ( obj:parent() == nil or obj:parent() == BAD_OBJ_ID ) then
								misc.release_obj(obj)
							end
							-- log2("ruck_near_lc: [%s] is too close to [%s] | [%.2f]",obj:name(),lc:name(),lc:position():distance_to(obj:position()))
							break
						else
							-- log2("ruck_near_lc: [%s] is far enough to [%s] | [%.2f]",obj:name(),lc:name(),lc:position():distance_to(obj:position()))
						end
					end
				end
			end
		end
	end
end
