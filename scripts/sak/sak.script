function aver_phantom_arts(obj)
	local cur_tbl = get_value("aver_phantom_arts_tbl", {})
	if table_empty(cur_tbl) then
		cur_tbl = { ["af_red_dummy_battery"] = false, ["af_red_dummy_spring"] = false, ["af_red_dummy_pellicle"] = false }
	end
	local counter = 0
	for k,v in pairs(cur_tbl) do
		-- dump_table(cur_tbl)
		if v == true then
			counter = counter + 1
		elseif k == obj:section() and not v then
			cur_tbl[k] = true
			counter = counter + 1
			amk_mod.af_flash(obj)
		end
	end
	if counter == 3 then
		schedule.add("close_window","sak.close_window()",100)
		db.actor:give_info_portion("aver_phantom_off")
		send_tip(game.translate_string("aver_phantom_arts"),game.translate_string("thinking_out_loud"),5,15,"g_g","sak","yellow")
		remove_value("aver_phantom_arts_tbl")
	else
		set_value("aver_phantom_arts_tbl", cur_tbl)
	end
end
local aver_bt_msg = false
function aver_bt_release(obj)
	local cur_tbl = get_value("aver_bt_arts_tbl", {})
	if table_empty(cur_tbl) then
		cur_tbl = { ["art1"] = false, ["art2"] = false, ["art3"] = false }
	end
	local sec = obj:section()
	local counter = 0
	local lvl_to_tbl = { sak_dialog.table_aart, sak_dialog.table_bart, sak_dialog.table_cart }
	for k,v in pairs(cur_tbl) do
		-- dump_table(cur_tbl)
		if v == true then
			counter = counter + 1
		else
			local temp_t = lvl_to_tbl[tonumber(string.sub(k,-1))]
			if str_in_tab(sec,temp_t) and sak_dialog.check_cond(server_obj(obj:id()),0.99) then
				cur_tbl[k] = true
				counter = counter + 1
				amk_mod.af_flash(obj)
			end
		end
	end
	set_value("aver_bt_arts_tbl", cur_tbl)
	if counter == 3 and sec ~= 'af_dummy_black_tip' then
		schedule.add("close_window","sak.close_window()",100)
		if not aver_bt_msg then
			send_tip(game.translate_string("aver_bt_release_1"),game.translate_string("thinking_out_loud"),2,10,"g_g","sak","yellow")
			aver_bt_msg = true
		end
	elseif counter == 3 and sec == 'af_dummy_black_tip' then
		schedule.add("close_window","sak.close_window()",100)
		amk_mod.af_flash(obj)
		db.actor:disable_info_portion("info_black_tip")
		remove_value("catched_bt")
		remove_value("aver_bt_arts_tbl")
		set_value("black_off", 0.8)
		send_tip(game.translate_string("aver_bt_release_2"),game.translate_string("black_tip_sms_1_h"),1,10,"default","sak", "red")
	end
end
function set_aver_monolith_scanner()
	if level.name() ~= "aver" then
		misc.spawn_to("aver_monolith_scanner",db.actor)
		close_window()
		return
	end
	local actr=db.actor
	local dir=device().cam_dir
	local a=vector() a.y=math.atan2(dir.x,dir.z)
	local xdelta=math.sin(a.y)
	local zdelta=math.cos(a.y)
	local pos=actr:position()
	local lvid=actr:level_vertex_id()
	local gvid=actr:game_vertex_id()
	if aver_monolit_zone and has_alife_info("aver_phantom_off") then
		sak.send_tip(game.translate_string("add_scanner_artefact"),game.translate_string("add_scanner_artefact_h"),3,15,"pribor","sak","green")
		actr:give_info_portion("aver_monolith_scanner_set")
		aver_monolit_spot_off()
		local obj=amk.spawn_item("physic_object",v3f((pos.x+xdelta), pos.y, (pos.z+zdelta)), gvid, lvid)
		if obj then
			local pk = get_netpk(obj,1)
			local data = pk:get()
			data.visual_name = "new_item\\scanner_artefact"
			data.skeleton_name = "idle"
			data.mass=20
			data.fixed_bones="link"
			pk:set(data)
			obj.set_direction=v3f(0,math.atan2(-dir.x,dir.z),0)
		end
	elseif aver_monolit_zone and not has_alife_info("aver_phantom_off") then
		sak.send_tip(game.translate_string("set_aver_monolith_scanner"),game.translate_string("thinking_out_loud"),1,10,"g_g","sak","red")
		misc.spawn_to("aver_monolith_scanner",db.actor)
	else
		sak.send_tip(game.translate_string("set_aver_monolith_scanner_2"),game.translate_string("thinking_out_loud"),1,10,"g_g","sak","yellow")
		misc.spawn_to("aver_monolith_scanner",db.actor)
	end
	close_window()
end
