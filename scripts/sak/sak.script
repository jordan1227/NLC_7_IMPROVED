		-- т√фр╕ь яюЁЇхэ№ фы  фшрыюур ё ╘ЁрхЁюь т ╦шьрэёъх	
		if lname=="l11_pripyat" and npc:has_info("lim_fraer_gg_know") and not npc:has_info("lim_fraer_pripyat_info") then
