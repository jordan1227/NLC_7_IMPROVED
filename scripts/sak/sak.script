local recipes_asked = {}
function recipes_tostring(rec)
	recipes_asked = {}
	local res = ""
	if rec and type(rec) == 'string' then
		local tbl = sak_artmods.artmod_resiepts
		for k,v in pairs(tbl) do
			local sec = v[6]
			if sec == rec then
				table.insert(recipes_asked,{k,v[5],v[7]})
			end
		end
	end
	local count = #recipes_asked
	if count == 0 then
		return
	elseif count == 1 then
		res = game.translate_string(recipes_asked[1][3]).."."
	elseif count == 2 then
		table.sort(recipes_asked, function(a,b) return a[1] < b[1] end)
		res = game.translate_string(recipes_asked[1][3])..", "..game.translate_string(recipes_asked[2][3]).."."
	end
	
	if res ~= "" then
		db.actor:give_talk_message(res,"ui\\ui_iconsTotal",Frect():set(0,0,0,0), "simple_answer_item")
	end
end
function give_dlg_recipe(val)
	local count = #recipes_asked
	local rec = ""
	if count == 1 then
		rec = recipes_asked[1][2]
	elseif count == 2 then
		rec = recipes_asked[val][2]
	end
	if rec ~= "" and not has_alife_info(rec) then
		db.actor:give_info_portion(rec)
		info_artmod()
	end
end
