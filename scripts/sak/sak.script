function mayat_phase_check()
	local day, hour = level.get_time_days(), level.get_time_hours()
	local d_h = day + hour
	local phase = ""
	if isEven(day) and hour < 13 and not isEven(d_h) then
		phase = "g"
		-- log2("mayat_phase_check: d = %d, d_h = %d, phase = %s",day,d_h,phase)
	elseif not isEven(day) and hour > 12 and isEven(d_h) then
		phase = "b"
		-- log2("mayat_phase_check: d = %d, d_h = %d, phase = %s",day,d_h,phase)
	else
		phase = "n"
		-- log2("mayat_phase_check: d = %d, d_h = %d, phase = %s",day,d_h,phase)
	end
	return phase
end
function mayat_sect_change()
	if not has_alife_info("klyk_remember") and not has_alife_info("water_tunnel") then
		return
	end
	if razgruzka.inventory_opened() then
		return
	end
	for k,v in arc_arts.inv_arts:pairs() do
		if strpos(v.section,"af_mayatnik") and not strpos(v.section,"capsule") then
			check_art(v.section,k)
		end
	end
	for k,v in arc_arts.belt_arts:pairs() do
		if strpos(v.section,"af_mayatnik") and not strpos(v.section,"capsule") then
			check_art(v.section,k,true)
		end
	end
end
function check_art(sec,id,flag)
	local mayat_phase_tbl = { ["g"] = "af_mayatnik", ["b"] = "af_mayatnik_bad", ["n"] = "af_mayatnik_none" }
	local mayat_eff_tbl = { ["g"] = "brighten.ppe", ["b"] = "surge_shock_old.ppe", ["n"] = "noise.ppe" }
	local p = mayat_phase_check()
	local obj = server_obj(id)
	if obj then
		local change_sect = ""
		local belt = false
		if flag ~= nil then
			belt = flag
		end
		if strpos(sec,"bad") then
			if p ~= "b" then
				-- log2("mayat_sect_change: switching from bad to [%s]",p)
				change_sect = p
			end
		elseif strpos(sec,"none") then
			if p ~= "n" then
				-- log2("mayat_sect_change: switching from none to [%s]",p)
				change_sect = p
			end
		else
			if p ~= "g" then
				-- log2("mayat_sect_change: switching from good to [%s]",p)
				change_sect = p
			end
		end
		if change_sect ~= "" then
			local cond = params.get_condition(id,0.99)
			misc.release_obj(obj)
			local new_mayat = misc.spawn_to(mayat_phase_tbl[p],db.actor)
			for k,v in pairs(mayat_eff_tbl) do
				if p == k then
					level.add_pp_effector(v, 1010, true)
					schedule.add("remove_mayat_eff","sak.remove_mayat_eff()",10000)
					break
				end
			end
			level.client_spawn_manager():add(
			new_mayat.id, -1,
			function( id, obj )
				obj:set_condition(cond)
			end )
			if belt then
				local foo_text = sprintf('sak.art_to_belt(%d)',new_mayat.id)
				schedule.add("to_belt"..tostring(new_mayat.id),foo_text,500)
			end
		end
	end
