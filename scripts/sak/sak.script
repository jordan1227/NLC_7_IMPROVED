function add_borov_treasure(val)
	treasure_manager.get_treasure_manager():give_treasure("mil_secret_borov")
	if val and val == 'more' then
		local obj = g_sim:object("borov_inventory_box")
		if obj then
			for i=1,5 do
				g_sim:create("vodka", obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id)
				g_sim:create("suhpay", obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id)
			end
		end
	end
end
