function kolb_baded()
	if kolb then return end

	local pt = profile_timer()
	pt:start()

	local temp, cnt = {}, 0
	for id, obj in alife():objects() do
		local p_obj=obj.parent_id
		local nname = obj:name()
		if (string.sub(nname,1,7)=="mutant_" or strpos(nname,"bread") or strpos(nname,"kolbasa")) and (p_obj==nil or p_obj==BAD_OBJ_ID or p_obj==0 or str_in_tab( g_sim:object( p_obj ):section_name(), { "rucksack", "inventory_box", "rukzak_inventory_box", "shadow_inventory" } ) or IsStalker(g_sim:object(p_obj))) then
			local pk = get_netpk(obj,1)
			local data = pk:get()
			local new_cond=0.10
			local iitem = obj:get_inventory_item()
			local iicond = iitem and iitem.item_condition
			local cond = iicond or data.condition
			if strpos(nname,"green_kolbasa") then
				new_cond=0.02
			elseif strpos(nname,"kolbasa") then
				new_cond=0.08
			elseif strpos(nname,"mutant_chimera_kogot") then
				new_cond=0.01
			elseif strpos(nname,"mutant_krovosos_jaw") then
				new_cond=0.08
			elseif strpos(nname,"mutant_poltergeist_glas") then
				new_cond=0.05
			elseif strpos(nname,"mutant_hand_kontroler") then
				new_cond=0.05
			elseif strpos(nname,"mutant_psevdogigant_hand") then
				new_cond=0.05
			elseif strpos(nname,"mutant_e_chimera_kidney") then
				new_cond=0.035
			elseif strpos(nname,"mutant_boar_leg") then
				new_cond=0.025	
			elseif strpos(nname,"mutant_zombie_hand") then
				new_cond=0.07
			elseif strpos(nname,"mutant_fracture_spleen") then
					new_cond=0.45
			end
			if cond and cond>0.15 then
				data.condition=cond-new_cond
				local cobj = client_obj(id)
				if cobj then
					cobj:set_condition(data.condition)
					cnt = cnt + 1
				elseif iicond ~= nil then
					iitem.item_condition = data.condition
					cnt = cnt + 1
				else
					pk:set(data)
				end
			else
				cnt = cnt + 1
				temp[id] = obj
			end
		end
	end
	release_tbl(temp)
	kolb=true

	pt:stop()
	log2("[%s.kolb_baded]: %d changed, time: %.2fms (%s)", script_name(), cnt, pt:time() / 1000, pt:time())
end
      
function off_testobj()
	local lname=level.name()
	local art_no_change_boxes = {
		"esc_sak_box_0001", "mil_sak_box_0001", "dv_sak_box_0001",
		"bar_sak_box_0001", "bar_sak_box_0002", "bar_sak_box_0003",
		"pri_sak_box_0001", "art_exchanger", "art_exchanger2" }
	local excl_arts = {"af_mayatnik","af_compass","af_red_","af_dummy_green","af_unknown_"}
	local change_flag = false
	local t_change_art_aver, t_changes_art_class = {}, {}
	for a=1,MAX_OBJ_ID do
		local obj= g_sim:object(a)
		if obj then 
			local p_obj=obj.parent_id
			local nname=obj:name()
			local lvl_id = (p_obj == BAD_OBJ_ID and obj.level_id) or server_obj(p_obj).level_id
			if type(lvl_id) ~= 'number' or lvl_id == 0 or lvl_id == NONE_SID then
				log2("off_testobj: corrupted obj [%s] id [%d], type(lvl_id) [%s], lvl_id [%s]",obj:name(),obj.id,type(lvl_id),tostring(lvl_id))
			end
			local is_valid_lvl_id = type(lvl_id) == 'number' and lvl_id ~= 0 and lvl_id ~= NONE_SID
			local lvl_name = (is_valid_lvl_id and g_sim:level_name(lvl_id)) or 'null'
			if strpos(nname,"amk_zone_teleport_",1,true)  
				or strpos(nname,"sak_skelet",1,true) 
				or strpos(nname,"_surprise_box",1,true)
				or strpos(nname,"amk_zone_greedy_",1,true) then
					misc.release_obj (obj)
			elseif strpos(nname,"banka_full") then
				if p_obj and p_obj~=0 then
					local par= g_sim:object(p_obj)
					misc.release_obj (obj)
					if par then
						misc.spawn_to("banka", par)
						obj_off_on(par)
					end
				elseif (p_obj==nil or p_obj==BAD_OBJ_ID) then
					misc.release_obj (obj)
				end
			elseif strpos(nname,"^af_") and not strpos(nname,"^af_full") and const.ground_levels[lvl_name] then
				-- log2("[off_testobj]: checking art %s with par %s",obj:name(),tostring(p_obj))
				if ( p_obj==nil or p_obj==BAD_OBJ_ID ) then
					if ( str_in_tab(nname,sak_dialog.table_aart) or str_in_tab(nname,sak_dialog.table_bart) or str_in_tab(nname,sak_dialog.table_cart) ) then
						if lvl_name == "aver" and obj.position:distance_to(v3f(350.91,-6.01,-21.23))<30 and not change_flag and has_alife_info("marsh_new_theme_done") then
							change_flag = true
							t_change_art_aver[a] = true
						else
							misc.release_obj (obj)
						end
					elseif str_in_tab(nname,excl_arts) then
						--
					else
						log2("[off_testobj]: releasing obj %s",obj:name())
						misc.release_obj (obj)
					end
				else
					local parent = g_sim:object(p_obj)
					if parent then
						local p_name = parent:name()
						if p_name ~= nil then -- яЁютхЁ хь, эх ыхцшҐ ыш рЁҐ т яырҐэющ э√іъх шч ҐрсышІ√, т ёєЁюэх ё ьхҐъющ, т Ё■ъчръх яюф яґч√Ё╕ь (╥╫) шыш ґ ╠хэ ы√
							local under_aver_bubble = parent.position:distance_to(v3f(350.91,-6.01,-21.23))<15
							local is_rucksack = parent.section_name and parent:section_name() == 'rucksack'
							if is_rucksack and under_aver_bubble
								and ( str_in_tab(nname,sak_dialog.table_aart) or str_in_tab(nname,sak_dialog.table_bart) or str_in_tab(nname,sak_dialog.table_cart) )
								and not change_flag and has_alife_info("marsh_new_theme_done") then
								change_flag = true
								t_change_art_aver[a] = true
							elseif is_rucksack and under_aver_bubble then
								misc.release_obj (obj)
							elseif is_rucksack and not under_aver_bubble then
								--log2("[off_testobj] catched obj %s, id = %d with parent %s, id = %d | ingored par rucksack, not under_aver_bubble", nname,a,p_name,p_obj)
							else
								if str_in_tab(p_name,art_no_change_boxes) == nil
									and level.map_has_object_spot(p_obj, "crlc_big_treasure0")==0
									and level.map_has_object_spot(p_obj, "crlc_big_treasure1")==0
									and level.map_has_object_spot(p_obj, "crlc_big_treasure2")==0
									and level.map_has_object_spot(p_obj, "crlc_big_treasure3")==0
									and level.map_has_object_spot(p_obj, "crlc_big_treasure4")==0 then
									--log2("[off_testobj] catched obj %s, id = %d with parent %s, id = %d | no tbl match, changes_art_class is called", nname,a,p_name,p_obj)
									t_changes_art_class[a] = p_obj
								else
									--log2("[off_testobj] catched obj %s, id = %d with parent %s, id = %d | tbl match, changes_art_class will not be called", nname,a,p_name,p_obj)
								end
							end	
						end
					end
				end
			end
		end
	end
	
	for a, _ in pairs(t_change_art_aver) do
		change_art_aver(a)
	end
	
	for a, p_obj in pairs(t_changes_art_class) do
		changes_art_class(a,p_obj)
	end

	for _,v in pairs(s_tbl) do
		v = true
	end
	s_tbl[lname] = false
	set_value("need_art_spawn", s_tbl)
	
	if has_alife_info("mar_military_post_ecolog_have") and not has_alife_info("scaner_artefact_done") then
		local lim_scanner = get_value("lim_scanner")
		if lim_scanner ~= nil and lim_scanner == 1 then
			db.actor:give_info_portion("scaner_artefact_done")
			remove_value("lim_scanner")
		end		
	end
	if has_alife_info("marsh_pribor_aver_start") then
		mike.marsh_pribor_aver_end()
	end
	if has_alife_info("akk_aver_start") then
		mike.akk_aver_end()
	end  
	if has_alife_info("mayatnik_aver_start_info") then
		mike.mayatnik_aver_ready()
	end  
	if has_alife_info("mayatnik_prip_start_info") then
		mike.mayatnik_prip_ready()
	end   
	if db.actor:has_info("pda_will_be_broken") then
		pda_will_brock()
		db.actor:disable_info_portion("pda_will_be_broken")
		return
	end
  ------ ╤ьюҐЁшь, эх ёыюьрҐ№ ыш эрь яфр ----
	local brock_flag = get_value("brocked_flag")
	if brock_flag == nil then
		brock_flag = lua_random(7,14) - tonumber(level.get_game_difficulty())
		set_value("brocked_flag",brock_flag)
	end
	if db.actor:has_info("val_raid_start") then -- хёыш чръЁ√ыш ╒-18, эх Ёрэ№Їх
		if brock_flag > 1 then
			local var = 1
			if black_tip.have_black_tip() then
				var = 2
			end
			set_value("brocked_flag",brock_flag - var)
		else 	
			db.actor:give_info_portion("pda_will_be_broken")
			remove_value("brocked_flag")
		end
	end
end
function pda_will_brock()
	db.actor:give_info_portion("pda_is_broken")
	out_many_pda_broken()
	-- local pda = db.actor:object("device_pda")
	-- if pda then
	-- 	misc.release_obj(pda)
	-- end
	level.set_actor_allow_pda(false)
	if get_shadow_inv():update_storage() then
		misc.spawn_to("device_pda_npc_gg", db.actor)
	else
		local t = {}
		for id, sobj in alife():objects() do
			if sobj:name() == "dropped_rucksack" then
				t[id] = sobj
			end
		end
		for id, sobj in pairs(t) do
			misc.spawn_to("device_pda_npc_gg", id)
		end
	end
	remove_value("brocked_flag")
end
function pda_new()
	db.actor:disable_info_portion("pda_is_broken")
	g_sim:disable_all_articles()
	-- misc.spawn_to("device_pda",db.actor)
	level.set_actor_allow_pda(true)
end
local money_percent = 80
function add_docent_self_pda()
	db.actor:disable_info_portion("pda_is_broken")
	-- misc.spawn_to("device_pda",db.actor)
	sak.relocate_item("in", "device_pda_npc_gg")
	level.set_actor_allow_pda(true)
	if get_value("gg_money") then
		db.actor:give_money(math.floor(get_value("gg_money")*(money_percent*0.01)))
		remove_value("gg_money")
	end
end
function x18_harddisc_off()
	local rnd=lua_random(1,5)
	schedule.add ("t_paus", "sak.harddisc_off_done()", 6000)
	local sound=sound_object("scripts\\hdd_out_"..rnd)
	sound:play_at_pos(db.actor, db.actor:position(), 0) 
	level.disable_input()
	bind_stalker.hide_weapon()
	local counter = get_value("x18_disks", 0)
	counter = counter + 1
	set_value("x18_disks", counter)
	if counter == 3 then
		send_tip(game.translate_string("x18_harddisc_off"),game.translate_string("thinking_out_loud"),7,15,"g_g","sak","yellow")
		db.actor:give_info_portion("barmen_x18_harddisc")
		remove_value("x18_disks")
	end
end
function x10_harddisc_off()
	local rnd=lua_random(1,5)
	schedule.add ("t_paus", "sak.harddisc_off_done()", 6000)
	local sound=sound_object("scripts\\hdd_out_"..rnd)
	sound:play_at_pos(db.actor, db.actor:position(), 0) 
	level.disable_input()
	bind_stalker.hide_weapon()
	local counter = get_value("x10_disks", 0)
	counter = counter + 1
	set_value("x10_disks", counter)
	if counter == 11 then
		send_tip(game.translate_string("x10_harddisc_off"),game.translate_string("thinking_out_loud"),7,15,"g_g","sak","yellow")
		db.actor:give_info_portion("botan_harddisc_found")
		remove_value("x10_disks")
	end
end
function harddisc_off_done()
	bind_stalker.restore_weapon()
	level.enable_input()
	create_items("hard_disc",1)
end
