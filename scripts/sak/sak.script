		elseif db.actor:active_slot()==2 then 
			local slot_2=db.actor:item_in_slot(2)
			wpn_params.start_fire(slot_2:id())
			local fire=lua_random(1000,5000)
			schedule.add ("wpn_fire","sak.stop_fire("..slot_2:id()..")", fire) 
	end
end
