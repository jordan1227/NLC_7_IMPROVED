end
function flash_set_status()
	local sound = sound_object("pda\\finish_pda")
	if sak.have_items_count("x12_secret_flash",1) and not has_alife_info("x12_secret_flash_have") and flash_inside == nil then
		set_inactivate_input_time(10)
		sound:play_at_pos(db.actor, db.actor:position(), 0)
		sak_inventory.release_actor_items("x12_secret_flash",1)
		flash_inside = true
	elseif not sak.have_items_count("x12_secret_flash",1) and flash_inside and flash_ready then
		set_inactivate_input_time(10)
		sound:play_at_pos(db.actor, db.actor:position(), 0)
		sak.create_items("x12_secret_flash",1)
		send_tip(game.translate_string("flash_set_status"),game.translate_string("thinking_out_loud"),5,15,"g_g","sak","yellow")
		db.actor:give_info_portion("x12_secret_flash_have")
		sak_spawn.bun_ambush_spawn()
		flash_inside = nil
	end
end
function check_for_flash()
	if sak.have_items_count("x12_secret_flash",1) then
		return true
	else
		return false
	end
end
function get_flash_ready()
	if flash_ready then
		return true
	else
		return false
	end
end

function cats_near()
	level.iterate_nearest(db.actor:position(), 10,
		function(obj)
			local cls = obj and obj:clsid()
			if (cls == clsid.cat) or (cls == clsid.cat_s) then
				return true
			end
		end
	)
	return false
end
function add_anom_spot()
	local actor=db.actor
	local dir=device().cam_dir
	local a=vector() a.y=math.atan2(dir.x,dir.z)
	local xdelta=6*math.sin(a.y)
	local zdelta=6*math.cos(a.y)
	local act_pos=actor:position()
	local lvid=actor:level_vertex_id()
	local gvid=actor:game_vertex_id()
	local robjd=amk.spawn_item("dots_item",v3f((act_pos.x+xdelta),(act_pos.y-1),(act_pos.z+zdelta)),gvid,lvid)
	amk.add_spot_on_map(robjd.id,"anomaly_zone_location","%c[255,255,0,0] "..game.translate_string("anl.snames_630"))
end
