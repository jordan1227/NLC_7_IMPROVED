function add_kolbasa_prohod()  
	local obj = g_sim:object("esc_inventory_box_0010")
	if obj then
		for a=1,2 do
			local sobj= g_sim:create("kolbasa",obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id)
			local new_cond=0.4*a
			local pk = get_netpk(sobj,1)
			local data = pk:get()
			data.condition = new_cond
			pk:set(data)
			if is_object_online(sobj.id) then
				local kolb = client_obj(sobj.id)
				kolb:set_condition(new_cond)
			end
		end
		obj_off_on(obj)
	end
end

