function attach(sm)
  sm:subscribe({signal = "on_init_modules", fun = this.init_module})
  sm:subscribe({signal = "on_late_init_all", fun = this.late_init})
--   sm:subscribe({signal = "on_before_save_game", fun = this.on_before_save})
  sm:subscribe({signal = "on_update", fun = this.actor_heart})
  sm:subscribe({signal = "on_update", fun = this.hazards_handle})
  sm:subscribe({signal = "on_update", fun = this.discharge_tasks})
  sm:subscribe({signal = "on_update", fun = this.actor_bio_upd})
end

