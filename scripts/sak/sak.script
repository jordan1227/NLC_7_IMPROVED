function borzyi_borov_quest_timer_end()
	if level.present() and level.name() ~= "red_forest" then
		if not has_alife_info("borzyi_borov_quest_surprise") then
			misc.release_by_name("cit_bandit_leader")
		end
	else
		timers.start_timer("borzyi_borov_quest_timer_add",0,1,5,"sak.borzyi_borov_quest_timer_end()")
	end
end

