		end
		if lname=="l04_darkvalley" and not has_alife_info("val_sos_give_tip_first") then
			timers.start_timer("vlad_sms",0,0,3,"sak.vlad_first_sms()")
			npc:give_info_portion("val_sos_give_tip_first")
		end
		if lname=="marsh" and has_alife_info("info_way178a") and not has_alife_info("oksana_kordon_out") and not has_alife_info("oksana_give_tip_first") then
			timers.start_timer("vlad_sms",0,0,3,"sak.oksana_first_sms()")
			npc:give_info_portion("oksana_give_tip_first")
		end
		if sname == "aver" and has_alife_info("doc_last_speech_info") and has_alife_info("detector_quest_end") and not has_alife_info("gluzov_letter_msg_info") then
			gluzov_letter_msg_timer()
		end
		if sname=="l04_darkvalley" then
			if has_alife_info("val_escort_new_begin") then
				if not has_alife_info("val_escort_guards_free") then
					npc:give_info_portion("val_escort_guards_free")
				end
				if not has_alife_info("val_mongol_talk") then
					kill_offline_npc(424)
				end
				if not has_alife_info("val_escort_task_start") then
					kill_offline_npc(400)
