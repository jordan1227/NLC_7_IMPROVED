-- ьюцэю т√ч√трҐ№ т ы■сющ ьюьхэҐ ЁрчуютюЁр, ёЁрсрҐ√трэшх яЁюшчющф╕Ґ яюёых чръЁ√Ґш  юъэр
local saved_func = nil
function post_dialog_exec(func_text)
	local func = func_text or saved_func
	if func then
		local f
		if type(func) == "string" then
			f = loadstring(func_text)
			saved_func = f
		else
			f = func
		end
		if not db.actor:is_talking() then
			f()
			saved_func = nil
		else
			timers.start_timer("repeat_post_dialog_exec",5,"sak.saved_func_exec()")
		end
	end
end
function saved_func_exec()
	if saved_func ~= nil then
		if not db.actor:is_talking() then
			local f = saved_func
			f()
			saved_func = nil
			post_dialog_exec()
		else
			post_dialog_exec()
		end
	end
end
