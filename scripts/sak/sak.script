function kill_offline_npc(sid)
	local obj = g_sim:story_object(sid)
	if obj and obj.alive and obj:alive() then
		local pk = get_netpk(obj)
		local data = pk:get()
		data.custom_data = "[dont_spawn_character_supplies]\n[dont_spawn_loot]"
		data.health     = 0
		data.upd.health = 0
		pk:set(data)
	end
end
