function check_lim_lager_bandits_enemies(obj)
	if not has_alife_info("borzyi_borov_quest_surprise") or has_alife_info("borzyi_borov_quest_reward_info") then return end
	local g = xr_gulag.get_npc_gulag(obj)
	if g and g.name == 'lim_lager_bandits' and has_alife_info("lim_lager_bandits_fire") then
		local val = get_value("lim_bandits_emenies")
		if val == nil then
			set_value("lim_bandits_emenies",true)
		end
	end
end

function val_bandits_enemies_yes_prec()
	local val = get_value("lim_bandits_emenies")
	return val ~= nil and val == true
end

function val_bandits_enemies_no_prec()
	return not val_bandits_enemies_yes_prec()
end

