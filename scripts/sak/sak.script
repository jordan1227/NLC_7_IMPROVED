function esc_shustryi_stalker()
	local npc=level_object_by_sid(4)
	if npc and npc:alive() and npc.online then
		npc:set_character_community("stalker",0,0)
	else 
		npc = g_sim:story_object(story_ids.esc_shustryi)
		if npc then
			local pk = get_netpk(npc)
			local data = pk:get()
			data.community_index=3
			pk:set(data)
		end
	end
	timers.start_timer("shustriy_go_lager",0,0,10,"sak.shustriy_esc_lager()")
	post_dialog_exec("sak.shustriy_move_out()")
end
function shustryi_mem_clear()
	local sh = client_obj(server_obj("esc_shustryi").id)
	local tbl = {}
	if sh then
		for o in sh:memory_visible_objects() do
			local obj = o:object()
			if validate_enemy_object(obj) then
				table.insert(tbl, obj)
			end
		end
	end
	for _,v in ipairs(tbl) do
		sh:enable_memory_object(v, false)
	end
	
	level.iterate_level_objects(function(obj)
		local nname = obj:name()
		local sobj = server_obj(obj:id())
		if IsStalker(obj) and obj:alive() and ( strpos(nname,"esc_factory_bandit") or sobj and sobj.smart_terrain_id and 
			sobj:smart_terrain_id() ~= BAD_OBJ_ID and server_obj(sobj:smart_terrain_id()):name() == "esc_lager" ) then
			tbl = {}
			for o in obj:memory_visible_objects() do
				local en = o:object()
				if validate_enemy_object(en) then
					table.insert(tbl, en)
				end
			end
			for _,v in ipairs(tbl) do
				obj:enable_memory_object(v, false)
			end
		end
	end)
end
