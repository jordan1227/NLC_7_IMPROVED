function consum_artefact()
	local hangr=-0.065
	if arts_operate~=false and (sak_inventory.belt_items["af_flower_new"] or sak_inventory.belt_items["af_armor_4"] or sak_inventory.belt_items["af_kol_4"]) then
		hangr=hangr+0.033
	end
	params.satiety_add(hangr)
end
local nv_on=0
local loka_on=1

local tmr_discharge_akb = misc.game_timer()

function get_accum()
	return db.actor:item_in_slot(10) 
end

function sak.discharge_accum()
	local obj = get_accum()
	if obj == nil then
		tmr_discharge_akb:elapsed(true) -- іҐюс√ тЁхь  ЁрчЁ фр эх ъюяшыюё№
		nvd_params.disable_NVD()
		arts_operate = false
		return
	end 
	local accum_id = obj:id()
	local accum = g_sim:object(accum_id)
	if accum then
		local lvl = level.name()
		local coef_add = 1
		if lvl == "aver" then
			coef_add = 5
		end
		local diff_t = tmr_discharge_akb:elapsed(true)
		-- local coef = coef_add * balance.devices.accum_discharge / 100.0 or 0.001
		local coef = coef_add * 0.055 / 100.0 or 0.001
		diff_t = math.abs ( diff_t ) / 60.0   -- ёъюы№ъю яЁюЇыю тЁхьхэш т шуЁют√є ьшэґҐрє       
		nv_on = 0 -- яюҐЁхсыхэшх ╧═┬
		if nvd_params.get_NVD_powered () then
			nv_on = 1
		end
		-- хёыш юфэр ьшэґҐр яЁюЇыр (diff_t = 1.0), яюҐЁхсыхэшх ёюёҐртшҐ coef * ішёыю яюҐЁхсшҐхыхщ    
		-- ╧═┬ ¤ътштрыхэҐхэ юфэюьґ рЁҐхЄръҐґ яю яюҐЁхсыхэш■
		local consumption = (af_count + nv_on) * coef      
		consumption = consumption * diff_t                           -- ё ґіхҐюь Ґхъґїхщ ёъюЁюёҐш тЁхьхэш    
		if lvl == "generators" then
			consumption = consumption * 0.5                           -- CHEAT: эр¤ыхъҐЁшчютрээр  ыюърІш , Ґрь ЁрчЁ ф ьхэ№Їх
		end    
		consumption = consumption + coef * diff_t * 0.01             -- яы■ё ЁрчЁ ф ётхҐюфшюфрьш яю ёр    
		local cond = params.get_condition(accum_id, 0.9999) + (0.5 - lua_random()) * coef * diff_t -- яюуЁхЇэюёҐ№ шчьхЁхэш  чрЁ фр 
		-- wprintf("[~T].C0F #DBG: accum power =~C0D %.5f~C07, consumption =~C0D %.5f~C0F, diff_t =~C0D %.3f~C0F, nvd power =~C0F %d~C07~C07", cond, consumption, diff_t, nv_on)
		-- wprintf("~C0A %s~C07", lua_traceback('    '));   
			if (cond <= 0.13) and (diff_t >= 1.0) then
				local act = db.actor
				local sound=sound_object("ambient\\special\\marsh_beep_1")      
				sound:play_at_pos(act, act:position(),0)    
			end    
			if cond >= 0.07 then
				arts_operate = true
				local new_cond = cond - consumption                       -- ЁрчЁ ф срҐрЁхш Ґхъґїшь Ґюъюь
				params.upd_condition (accum_id, new_cond)
				arts_operate=true
				-- nvd_params.enable_NVD() -- хёҐ№ чрЁ ф, ьюцэю тъы■ірҐ№    
			else
				if arts_operate==true then
					send_tip(game.translate_string("battery_dead"),game.translate_string("battery"), 2, 10, "pribor", "pda_news", "red")          
					nvd_params.disable_NVD()
					arts_operate = false
					razgruzka.open_inv_raz_pod = false
				end
			end
		sak_inventory.update_accum_leds()
	else  
		wprintf("[~T].~C0C #FATAL:~C07 bad object in slot 11 = %d ", accum_id)
		nvd_params.disable_NVD() 
	end
end

local tmr_art_discharge = misc.game_timer()

function discharge_tasks()
	ogse_signals.get_mgr():reschedule(12000)
	if db.init_stage < 500 then
		return
	end 
	discharge_accum()
	-- local coef = balance.artefacts.time_damage_coef * tmr_art_discharge:elapsed(true) / 60.0 -- ъю¤ЄЄшІшхэҐ чртшёшьюёҐш юҐ тЁхьхэш
	local coef = 0.125 * tmr_art_discharge:elapsed(true) / 60.0 -- ъю¤ЄЄшІшхэҐ чртшёшьюёҐш юҐ тЁхьхэш
	if coef < 0.00001 then
		return
	end -- эх чріхь ш ╓╧ ьґірҐ№  
	if get_accum() then    
			arc_arts.discharge_artefacts(coef)
		else  
			arts_operate=false   
	end  
	if sleep_manager.sleeping then
		return
	end
	if wake_up_upd then
		coef = 0.125
		wake_up_upd = false
	end
	black_tip.discharge(coef)
end

function adjust_hemi(hour)
	if level.name() == 'l12_stancia_2_new' then
		get_command( "r2_sun_lumscale_hemi 1.2" )
	elseif const.ground_levels[ level.name() ] then
		local hour = level.get_time_hours()
		if hour == 21 then
			get_command( "r2_sun_lumscale_hemi 1.8" )
		elseif hour >= 5 and hour < 21 then
			get_command( "r2_sun_lumscale_hemi 2.0" )
		else
			get_command( "r2_sun_lumscale_hemi 1.5" )
		end
	else
		get_command( "r2_sun_lumscale_hemi 0" )
	end
end

function info_days(hour)
	local info=""
	if hour>=21 or hour<6 then
		info="time_night"
	elseif hour>=6 and hour<11 then 
		info="time_morning"
	elseif hour>=11 and hour<17 then 
		info="time_day" 
	elseif hour>=17 and hour<21 then 
		info="time_evening"
	end
	if not has_alife_info(info) then 
		db.actor:give_info_portion(info) 
		vodka_stas_new(info) 
		lysyi_art_new(info) 
		hellcar_attack(info) 
		mil_find_prizrak(info)
		sleep_manager.clear_need_sleep_nrg(info)
	end
	local lname = level.name()
	dead_chudishe_check(lname,hour)
	agro_mines_check(lname,hour)
	adjust_hemi()
	local coeff = 1
	if black_tip.have_black_tip() then
		coeff = 1.5
	end
	params.hit_probability_add(level_difficulty[lname]*time_difficulty[hour]*coeff)
	db.actor:disable_info_portion("botans_dialog_done")
end
function dead_chudishe_check(lname,hour)
	if lname == "deadcity" and has_alife_info("mar_gg_psy_scan_ask") and not has_alife_info("mar_gg_psy_scan_ask_done") then
		local bs = server_obj("dead_chudishe")
		if hour < 6 then
			if not bs then
				local sp_obj = misc.spawn_by_name("dead_chudishe")
				-- ╘шъёрІш , іҐюс√ эх ґяры
				local sobj = server_obj(sp_obj.id)
				local pk = get_netpk(sobj,1)
				local data = pk:get()
				data.fixed_bones="bip01_head, bip01_spine1, bip01_l_foot, bip01_r_foot"
				pk:set(data)
			end
		else
			if bs then
				misc.release_by_name("dead_chudishe")
			end
		end
	end
end
function agro_mines_check(lname,hour)
	local l = lname or level.name()
	if l ~= 'l03_agroprom' or not has_alife_info("agr_mil_dumenko_job_start") then
		return
	end
	local h = hour or level.get_time_hours()
	if h>=21 or h<6 then
		doc.on_agr_mines()
	else
		if not has_alife_info("agr_und_blood_spawned") or has_alife_info("info_dsc_kolonna_done") then
			doc.off_agr_mines()
		end
	end
end
function hellcar_attack(info)
	local act=db.actor
	if info=="time_evening" and has_alife_info("gar_start_quest") and has_alife_info("hellcar_today") and not has_alife_info("hellcar_raid_start") then
		act:give_info_portion("hellcar_raid_start_soon")
		timers.start_timer("hellcar_raid",0,0,8,"sak.add_hellcar_raid()")
	elseif info=="time_morning" and has_alife_info("gar_start_quest") and not has_alife_info("hellcar_raid_start") then
		act:give_info_portion("hellcar_today")
	end
end
function add_hellcar_raid()
	local lname=level.name()
	local act = db.actor
	act:give_info_portion("hellcar_raid_start")
	act:give_info_portion("gar_bandits_raid")
	if not has_alife_info("gar_direction") then
		act:give_info_portion("gar_direction")
	end
	if lname~="l02_garbage" then
		local obj= g_sim:story_object(story_ids.gar_hellcar)
		if obj then
			local pk = get_netpk(obj)
			local data = pk:get()
			data.health     = 0
			data.upd.health = 0
			pk:set(data)
		end
		act:give_info_portion("gar_hellcar_death")
	else
		local gulag = xr_gulag.get_gulag_by_name("gar_bandit_agr")
		if gulag then
			gulag.smrttrn:update()
		end
	end
end
function mil_find_prizrak(info)
	local act=db.actor
	if info~="time_night" then  
		if has_alife_info("mil_find_prizrak_start") and not has_alife_info("gen_mil_group_info") then
			if not has_alife_info("mil_find_prizrak_today") and not has_alife_info("esc_blockpost_commander_gg_know") then
				act:give_info_portion("mil_find_prizrak_today")
			end
		elseif has_alife_info("gen_mil_group_info") and has_alife_info("info_escape_trader_tesla_done") and not has_alife_info("esc_blockpost_commander_info_know") and not has_alife_info("esc_blockpost_commander_full_info_know") then
			if not has_alife_info("mil_find_prizrak_today") then
				act:give_info_portion("mil_find_prizrak_today")
			end
		end
	elseif info=="time_night" then
		act:disable_info_portion("mil_find_prizrak_today")
		act:disable_info_portion("esc_mil_nagrad_info")
	end
end
function mil_abuse()
	params.hit_probability_add(10)
end
function vodka_stas_new(info)
	if info=="time_day" then
		set_value("vodka_win", 0)
		set_value("art_exchange_count", 0)
		db.actor:disable_info_portion("gen_hermit_change_done")
		local name, delay = timers.check_timer("kolb")
		if not name then
			timers.start_timer("kolb",0,1,lua_random(15,45),"sak.kolb_baded()")
			kolb = false
		end
	elseif info=="time_night" then
		local name, delay = timers.check_timer("kolb")
		if not name then
			timers.start_timer("kolb",0,1,lua_random(15,45),"sak.kolb_baded()")
			kolb = false
		end
	end
end
function lysyi_art_new(info)
	if info=="time_morning" then
		set_value("art_win", 0)
		set_value("vergas_rem", 0)
		set_value("greens_kolbasa", 0)
		set_value("dan_ammo", 0)
		set_value("mar_tower_ammo", 0)
		esc_no_charge()
		bar_no_charge()
		new_quests.generate_ignat_mutants()
	end
end

function actor_pickup(id, on_fail)
	local obj = client_obj(tonumber(id)) 
 
	if obj and not arc_arts.is_actor_item(id) then
		local parent = obj:parent() 
		if parent then
			parent:transfer_item(obj, db.actor)
		else
			obj:transfer_item(obj, db.actor)
		end   
		sak_inventory.need_update_inventory()
	elseif obj == nil then
		wprintf("[~T].~C0C #WARN:~C07 actor cannot pickup non existent~C0D %d~C07", DumpVar(id))
		if on_fail then on_fail() end     
	end
end

