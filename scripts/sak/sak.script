				end
			end
		end
		loks_count()
	end

	if lname=="aver" then 
		level.set_time_factor(system_ini():r_float("alife","time_factor")*5)
		t_s_1=45150
	elseif const.ground_levels[lname] then
		level.set_time_factor(system_ini():r_float("alife","time_factor"))
		t_s_1=math.floor(600000-(level_difficulty[lname]^2*160000))
	else
		level.set_time_factor(system_ini():r_float("alife","time_factor"))
		t_s_1=160000
	end
	local hour = level.get_time_hours()
	local coeff = 1
	if black_tip.have_black_tip() then
		coeff = 1.5
	end
	params.hit_probability_add(level_difficulty[lname]*time_difficulty[hour]*coeff)
	sak_off_corpses.off_corpses(l_change)
	razgruzka.end_use_info()
	sak.reset_actor_bio()   
	wprintf('#PERF: sak.add_tail end')
end

function actor_bio_upd()
	ogse_signals.get_mgr():reschedule(5000)
	actor_bio()
end

function actor_bio()
	params.tiredness_add(0)
end

function sak.reset_actor_bio() 
	params.health_v_add  (1, level_difficulty[level.name()]) -- тюёёҐрэютыхэшх чфюЁют№  тю тЁхь  сюфЁёҐтютрэш 
	params.satiety_v_add (1, 1)  -- эрЁрёҐрэшх уюыюфр яю ґьюыірэш■
	actor_bio()
end

function grabb_bar_seif (obj_id,actor)
	have_many=0
	local box = client_obj(obj_id)
	local rem_items = {}
	if box then
		local cnt = box:inv_box_count()
		for i = 0, cnt - 1 do
			local item = box:object_from_inv_box(i)
			if item then
				rem_items[item:id()] = item
				local nname=item:section()
				if strpos(nname, "af_",1,true) or strpos(nname, "arc_art_box_",1,true) then
					add_price_arts(item)
				end
			end
		end
	end
	if (have_many>350000 or actor:has_info("deactivate_radar_fall")) and not actor:has_info("bar_seif_prot_out") then 
		actor:give_info_portion("bar_seif_prot_out")
		local name,sname = amk_names_lists.get_strings()
		send_tip(game.translate_string("grabb_bar_seif"),name.." "..sname,20,15,"uniq","news","gray")
		name,sname = amk_names_lists.get_strings()
		send_tip(game.translate_string("grabb_bar_seif2"),name.." "..sname,25,15,"uniq","news","gray")
		release_tbl(rem_items)
	end
end
function voronin_seif_out()
	local box=level_object_by_sid(9142)
	if box then
		local cnt = box:inv_box_count()
		for i = 0, cnt - 1 do
			local obj = box:object_from_inv_box(i)
			if obj and get_bool( obj:section(), "watcher_act.bad_item", false ) ~= true then
				misc.release_obj(obj:id())
			end
		end
	end
end
function habar_by_nps(lid)
	local npc = client_obj(lid)
	if not npc then return end
	npc:iterate_inventory(function(_, item)
		if is_food(item)==true or is_arts(item)==true then
			misc.release_obj(item:id())
		end
	end)
	for k, v in pairs(table_food) do
		if lua_random()<0.15 and k~= "sleeping_pill" then
			local obj=misc.spawn_to(k, npc)
			if k=="bread" or k=="kolbasa" or k=="green_kolbasa" then
				local rand=lua_random(30,80)/100
				local pk = get_netpk(obj,1)
				local data = pk:get()
				data.condition=rand
				pk:set(data)
				obj=client_obj(obj.id)
				if obj then obj:set_condition(rand) end
			end
		end
	end
	if npc:rank() > 500 then
		for k, v in pairs(aart_table) do
			if lua_random()<0.03 then
			local art = k.."_dyn"..lua_random(1,4).."d"
			local obj = misc.spawn_to(art, npc)
				local rand=lua_random(30, 80) / 100
				local pk = get_netpk(obj,1)             
				local data = pk:get()
				data.condition=rand
				pk:set(data)
				obj=client_obj(obj.id)
				if obj then obj:set_condition(rand) end
				break
			end
		end
	end
end

function is_food(item)
	local section
	if type(item) == 'string' then
		section = item
	else
		section = item:section()
	end
	if table_food[section] then
		return true
	else
		return false
	end
end
function is_arts(item)
	local section = string.sub(item:section(),1,-7)
	if aart_table[section] then
		return true
	else
		return false
	end
end
function spawn_red_mines()
	if has_alife_info("borzyi_borov_quest_reward_info") then return end
	local obj = g_sim:story_object(525)
	if obj then return end
	for n = 1,4,1 do
		misc.spawn_by_name("red_zone_mine_field_"..n)
	end
end
function off_red_mines()
	local obj= g_sim:story_object(525) -- story_object(525)
	if not obj then return end
		for n = 524,527 do
			local obj = g_sim:story_object(n)
			if obj then   
				misc.release_obj(obj, 'sak.script:3628')
			else
				wprintf("[~T].~C0C #WARN(off_red_mines):~C07 not found story-object~C0D %d~C07 ", n)    
		end   
	end
end

function loks_count()
	local n_count=get_value("mik_count", 0)
	if n_count>=10 and lua_random()>0.5 then
		local t=lua_random(1,3)
		schedule.add ("chat_content","news_mikelik.chat_content()",10000*t)
		n_count=0
	else
		n_count=n_count+1
	end
	set_value("mik_count", n_count)
	local r_count=get_value("rem_count", 0)
	if r_count>8 then return end
	local count=get_value("loks_count", 0)
	if count>=7+r_count*10 then
		if lua_random()>0.5 then
			local t=lua_random(1,3)
			schedule.add ("remer_loks","sak.add_rem_infos()",10000*t)
			count=0
		end
	else
		count=count+1
	end
	set_value("loks_count", count)
end
function rem_loks()
end
function add_rem_infos()
	local count=get_value("rem_count", 0)
	if count>8 then return end
	send_tip(game.translate_string("add_rem_infos"),game.translate_string("st_memory_h"),2,20,"g_g","rememb","yellow")
	set_value("rem_count", count + 1)
	local character=math.floor(((get_value("r_task_reward",1))+(get_value("x18_iq_check",1)))/2)
	local info="rem_"..tostring(character).."_"..tostring(count)
	db.actor:give_info_portion(info)
end
