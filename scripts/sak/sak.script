function borzyi_returned()
	local priemnik = client_obj(server_obj("red_near_bridge_priemnik").id)
	local borzyi = client_obj(server_obj("cit_bandit_leader").id)
	return borzyi:position():distance_to(priemnik:position()) < 2.5
end

