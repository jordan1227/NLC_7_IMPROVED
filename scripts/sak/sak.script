function create_corpse(section, pos, gvid, lvid, story_id, custom_data) -- ёючфрхҐ юс·хъҐ ё эґыхт√ь чфюЁют№хь
	local obj = amk.spawn_item(section, pos, gvid, lvid)
	local pk = get_netpk(obj)
	local data = pk:get()
	data.story_id   = story_id
	data.health     = 0
	data.upd.health = 0
	if custom_data then data.custom_data = custom_data end
	pk:set(data)   
	return obj
end

