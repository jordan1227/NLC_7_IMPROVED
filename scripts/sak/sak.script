function check_fox_dogs()
	local t = get_value("fox_dogs_tbl",{})
	local counter = 0
	local pos = v3f(139.2623,0.2501,346.4197)
	if t and #t == 5 then
		for _,v in ipairs(t) do
			local obj = server_obj(v)
			if obj and IsMonster(obj) then
				if not obj:alive() then
					counter = counter + 1
				else
					if obj.online and obj.position:distance_to_xz(db.actor:position()) > 60 then
						g_sim:teleport_object(obj.id, pos, 444253, 233)
						play_spawn_eff(obj.position)
						play_spawn_eff(pos)
						client_obj(obj.id):berserk(true)
					end
				end
			end
		end
		if counter == 5 then
			remove_value("fox_dogs_tbl")
			return true
		end
	end
	return false
end
