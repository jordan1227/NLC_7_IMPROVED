function marsh_scan_restr()
	local res = g_sim:create("space_restrictor",vector():set(-155.2772,1.8136,-274.8190),66045,3372)
    local custom = "[logic]\nactive = sr_idle@idle_out\n[sr_idle@idle_out]\non_actor_inside = sr_idle@work\n[sr_idle@work]\non_info = {+gg_psy_scan_rules -gg_psy_scan_finish} %=sak.marsh_scan_process()% sr_idle@idle_in\n[sr_idle@idle_in]\non_actor_inside = sr_idle@idle_out\non_actor_outside = sr_idle@idle_out %=sak.marsh_scan_process_msg_reset()%"
	kotovod_restrictors.rewrite_restrictor(res, custom, 1.0)
	set_value("marsh_scan_restr",res.id)
end
