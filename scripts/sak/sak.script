local marsh_scan_process_msg = nil
function marsh_scan_process()
	if has_alife_info("gg_psy_scan_start") then
		return
	end
	local act = db.actor
	local aobj = get_actor_obj()
	if (aobj and (aobj:is_actor_crouch() or aobj:is_actor_creep())) and act:item_in_slot(1) == nil and act:item_in_slot(2) == nil and act:item_in_slot(6) == nil then
		db.actor:give_info_portion("gg_psy_scan_start")
		close_window()
		level.add_pp_effector("blink.ppe",1000,false)
		set_inactivate_input_time(140)
		params.set_direction(-1.5,0,-3)
		schedule.add("psy_effect","sak.fake_vodka_drink()",5000)
		local id = get_value("marsh_scan_restr")
		if id then
			misc.release_obj(id)
			remove_value("marsh_scan_restr")
		end
	else
		if not marsh_scan_process_msg then
			send_tip(game.translate_string("marsh_scan_process"),game.translate_string("thinking_out_loud"),1,7,"g_g","sak","yellow")
			marsh_scan_process_msg = true
		end
	end
end
function marsh_scan_process_msg_reset()
	marsh_scan_process_msg = nil
end
