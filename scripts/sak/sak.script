			if obj and obj:alive() then
				obj = client_obj(obj.id)
				obj:kill(obj)
			end
		else
			if obj then
				local pk = get_netpk(obj)
				local data = pk:get()
				data.health     = 0
				data.upd.health = 0
				pk:set(data)
			end
		end
	end
end
