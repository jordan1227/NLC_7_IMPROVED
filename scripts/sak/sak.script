function borzyi_borov_quest_restr()
	if not has_alife_info("borzyi_borov_quest_check_process") then
		local res = g_sim:create("space_restrictor",vector():set(-92.8203,-0.8174,-178.5806),13397,3241)
		local custom = "[logic]\nactive = sr_idle@in\n[sr_idle@in]\non_actor_inside = %=sak.borzyi_borov_quest_flag_in% sr_idle@out\n[sr_idle@out]\non_actor_outside = %=sak.borzyi_borov_quest_flag_out% sr_idle@in"
		kotovod_restrictors.rewrite_restrictor(res, custom, 4.0)
		set_value("borzyi_borov_quest_restr",res.id)
		db.actor:give_info_portion("borzyi_borov_quest_check_process")
	end
end

function borzyi_borov_quest_restr_rel()
	local id = get_value("borzyi_borov_quest_restr")
	if id then
		misc.release_obj(id)
		remove_value("borzyi_borov_quest_restr")
	end
end

