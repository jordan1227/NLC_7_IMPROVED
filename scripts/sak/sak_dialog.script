function add_luber_soul(first_speaker, second_speaker)   
	local obj = misc.spawn_to ( "af_soul_dyn2d", db.actor )
	if obj then
		sak.relocate_item("in", "af_soul_dyn2d", 1 )
		local objd = g_sim:object( obj.id )
		local pk = get_netpk( objd, 1 )
		ASSERT( ( pk and pk:isOk() ), "can't read netpacket of %s", obj:name() )
		local data = pk:get()
		local cond = lua_random( 35, 45 ) * 0.01
		data.condition = cond
		pk:set( data )
		level.client_spawn_manager():add(
			obj.id, -1,
			function( id, obj )
				obj:set_condition( cond )
			end
		)
	end
end
