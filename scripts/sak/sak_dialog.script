function add_docs_X18()
	local points ={
		{26.4552,4.1895,4.9480,1119,6646},
		{-7.7478,1.8946,12.0030,1125,1907},
		{17.2166,-16.3431,68.7431,1163,6077},
		{8.9668,-14.2566,48.2067,1162,3799},
		{-39.1282,-10.9054,12.6159,1148,327}
		}

	local r1 = get_value("r_task_reward",2)
	local r2 = get_value("r_treas_items",1)
	if r1 == 1 then
		r1 = 2
	end
	table.sort(points,function(a,b) return a[r2] > b[r2] end)
	set_value("count_done_docs_x18",0)

	for n = 1, r1 do
		local p = points[n]
		local obj = amk.spawn_item("destroyable_box",sak.v3f(p[1],p[2],p[3]),p[4],p[5])
		if obj then
			local pk = get_netpk(obj,1)
			local data = pk:get()
			data.custom_data = "[drop_box]\ncommunity = def_box\nitems = x18_document"
			data.mass = 10
			pk:set(data)
		end
	end
end
function docs_X18_nagrad1()					-- забираем документы из Х-18 для Сахарова у Меченного, считаем их количество, даем предварительную награду.
	local cur_docs = 0
	for kk,k in pairs(sak_inventory.rucksack) do
		if strpos(kk, "x18_document",1,true) then
			sak_inventory.release_actor_items("x18_document", #k)
			cur_docs = #k
			break
		end
	end
	local v = get_value("count_done_docs_x18",0)
	set_value("count_done_docs_x18",v+cur_docs)
	dialogs.relocate_money(db.actor,cur_docs*4000,"in")
end
function docs_X18_have_done()				-- проверка, сдал ли Меченный все документы из Х-18 для Сахарова
	local docs = get_value("r_task_reward",2)
	if docs == 1 then
		docs = 2
	end
	local v = get_value("count_done_docs_x18",0)
	return v == docs
end
function docs_X18_not_have_done()
	return not docs_X18_have_done()
end
