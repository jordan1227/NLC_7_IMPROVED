	local obj=g_sim:object(tonumber(id))
	if obj then
		g_sim:create("af_unknown_1_new",obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id) --239
		g_sim:create("af_unknown_2_new",obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id) --274
		g_sim:create("af_unknown_12_new",obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id)--244
		g_sim:create("af_unknown_29_new",obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id)--237
		g_sim:create("af_unknown_20_new",obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id)--609--16.03kg
		sak.obj_off_on(obj)
	end
end
