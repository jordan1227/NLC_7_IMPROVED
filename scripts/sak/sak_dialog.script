function have_kuz_vodka()
	local days = math.ceil(sak.day_money/15)
	if days>5 then days=5 end
		return sak.have_items_count("vodka",days)~=false
end
function give_kuz_vodka()
	local days = math.ceil(sak.day_money/15)
	if days>5 then days=5 end
	sak_inventory.release_actor_items("vodka",days)
end

function text_kuz_vodka()
	local days = math.ceil(sak.day_money/15)
	local text=game.translate_string("text_kuz_vodka_1")
	if days==2 then text=game.translate_string("text_kuz_vodka_2")
		elseif days==3 then text=game.translate_string("text_kuz_vodka_3")
		elseif days==4 then text=game.translate_string("text_kuz_vodka_4")
		elseif days>=5 then text=game.translate_string("text_kuz_vodka_5")
	end
	return "%c[255,216,186,140]"..text
end
function text_sher_vodka()
	local days = math.ceil(sak.day_money/15)
	local text=game.translate_string("text_sher_vodka_1")
	if days==2 then text=game.translate_string("text_kuz_vodka_2")
		elseif days==3 then text=game.translate_string("text_sher_vodka_2")
		elseif days==4 then text=game.translate_string("text_sher_vodka_3")
		elseif days>=5 then text=game.translate_string("text_sher_vodka_4")
	end
	return "%c[255,216,186,140]"..text
end
function have_rgo_vodka()
	local day = timers.Get_Game_Days() or 1
	local count = math.floor((day - 1) / 30) + 2
	if count > 4 then
		count = 4
	end
	return sak.have_items_count("vodka",count)
end
function give_rgo_vodka()
	local day = timers.Get_Game_Days() or 1
	local count = math.floor((day - 1) / 30) + 2
	if count > 4 then
		count = 4
	end
	sak_inventory.release_actor_items("vodka",count)
end
function text_rgo_vodka()
	local day = timers.Get_Game_Days() or 1
	local text = game.translate_string("text_kuz_vodka_2")
	if day>30 and day<61 then
		text=game.translate_string("text_sher_vodka_2")
	elseif day>60 then
		text=game.translate_string("text_sher_vodka_3")
	end
	return "%c[255,216,186,140]"..text
end
