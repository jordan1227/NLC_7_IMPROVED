function get_art_tbl(x)
	if x==nil or type(x) ~= "string" then
		log2("[get_art_tbl]: wrong parameters!")
		return nil
	end
	local t
	if x == "a" then
		t = table_aart
	elseif x == "b" then
		t = table_bart
	elseif x == "c" then
		t = table_cart
	else
		log2("[get_art_tbl]: wrong parameters!")
		return nil
	end
	return t
end
function have_any_x_art(x,new_flag)
	local tbl = get_art_tbl(x)
	if tbl == nil then
		return
	end
	local flag = false
	if new_flag then
		flag = true
	end
	for i=1, table.getn(tbl) do
		if sak.have_items_count(tbl[i],1,flag) then 
			return true
		end
	end
	return false
end
function transfer_any_x_art(x)
	local tbl = get_art_tbl(x)
	if tbl == nil then
		return
	end
	for i=1, table.getn(tbl) do
		if sak.have_items_count(tbl[i],1,true) then
			sak_inventory.release_actor_items(tbl[i],1,false,true)
			break
		end
	end
end
function have_bart()
	for i=1, table.getn(table_bart) do
		if sak.have_items_count(table_bart[i],1) then return true end
	end
	return false
end
function gg_2_1_art_have()
	return (have_any_x_art("b",true) and gg_2_aart_have())
end
function gg_1_3_art_have()
	return (have_any_x_art("b",true) and gg_3_aart_have())
end
function have_any_dart()
	for i=1, table.getn(table_dart) do
