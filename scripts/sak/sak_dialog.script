function add_dsc_container()
	local d_p = level.get_time_days() + 2
	while d_p > 3 do
		d_p = d_p - 3
	end
	-- под прицепом // в трубе // под бетонной плитой
	local c = { {-19.3533,-0.4409,-323.8792,4029,369877}, {51.9895,-0.0953,-268.0631,4051,450636}, {-36.6396,0.2291,-239.8620,4013,350692} }
	local obj = amk.spawn_item("rukzak_inventory_box",sak.v3f(c[d_p][1],c[d_p][2],c[d_p][3]),c[d_p][4],c[d_p][5])
	if obj then
		level.map_add_object_spot_ser(obj.id,"crlc_big_treasure0","?")
		fill_dsc_container(obj.id)
		add_treas_tbl("k01_darkscape",obj.id)
	end
end	
function fill_dsc_container(id)
	local obj = g_sim:object(id)
	if obj then
		local box = g_sim:create("arc_art_box_basic", obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id)
		if box then
			local pk = get_netpk(box)
			local data = pk:get()	  
			data.custom_data = "af_rusty_sea-urchin_capsule_dyn1d_99"
			pk:set(data)
		end
		sak.obj_off_on(obj)
	end
end
