	if db.actor:has_info("borov_11_done") and db.actor:has_info("bandit_krisyk_done") then
			return true
		else
			return false
	end
end
-- wolf_limansk
function esc_wolf_cycle_end()
	return ( has_alife_info("esc_kill_bandits_quest_done") and not has_alife_info("val_raid_start") )
end
function jila_abuse_prec_yes()
	local abuse = get_value("esc_band_abuse", false)
	return (abuse == true)
end
function jila_abuse_prec_no()
	return not jila_abuse_prec_yes()
end

function add_doc_start()
	sak.create_items("medkit",1)
	sak.create_items("conserva",1)
	sak.create_items("energy_drink",1)
end
-- разбор завала через Борова
function borov_zaval_yes_prec()
	return jila_abuse_prec_no() and bandit_pda_trading() and harmonica_cracked_no() and has_alife_info("borov_harmonica_start") and has_alife_info("borov_harmonica_done") 
		and has_alife_info("new_borov_kill_stalker_start") and has_alife_info("new_borov_kill_stalker_done") and not has_alife_info("atp_bandits_open_fire")
		and not has_alife_info("voron_help_me_entres_ok") and not has_alife_info("kulinar_help_entres_ok") and not has_alife_info("barman_help_me_entres_ok")
end
function borov_zaval_no_prec()
	return not borov_zaval_yes_prec()
end
-- kulinar_food_zaval
function have_kulinar_food()
	return sak.have_items_count("bread",30)~=false and sak.have_items_count("conserva",30)~=false and sak.have_items_count("vodka",10)~=false and vergas_lib.search_items("energy_drink",20,1)~=false and vergas_lib.search_items("ammo_12x70_buck",300,1)~= false
end

function give_food_kulinar()
	sak_inventory.release_actor_items("bread",30)
	sak_inventory.release_actor_items("conserva",30)
	sak_inventory.release_actor_items("vodka",10)
	vergas_lib.search_items("energy_drink",20,2)
	vergas_lib.search_items("ammo_12x70_buck",300,2)	
end
-- tesla_new
function esc_trader_tesla()
	if not has_alife_info("esc_blockpost_abuse") then
		timers.start_timer("trader_tesla",0,0,10,"sak_dialog.timer_trader_tesla_end()")
	end
end
function timer_trader_tesla_end()
	if not has_alife_info("info_escape_trader_tesla_start") then
		sak.send_tip(game.translate_string("timer_trader_tesla_end"),game.translate_string("sidor_sms_h"),11,20,"g_g","sak","green")
		db.actor:give_info_portion("info_escape_trader_tesla_start")
	end
end
