function sbruy_desertir_spawn()
	local shron = g_sim:object("mil_inventory_box_0005")
	if shron then
		local wpn = g_sim:create("wpn_abakan",shron.position, shron.m_level_vertex_id, shron.m_game_vertex_id, shron.id)
		local arm = g_sim:create("dolg_gaz_outfit_m1",shron.position, shron.m_level_vertex_id, shron.m_game_vertex_id, shron.id)
		local w_id, a_id = wpn.id, arm.id
		sbruy_desertir_spawn2(w_id,a_id)
		sak.obj_off_on(shron)
		level.map_add_object_spot_ser(shron.id,"crlc_big_treasure0","?")
		-- Manool: у нас можно серверному объекту состояние менять
		-- schedule.add("sbruy_desertir_spawn2","sak_dialog.sbruy_desertir_spawn2("..w_id..","..a_id..")",1000) -- схрон изначально в онлайне, поэтому ломать нужно после завершениЯ свитча офф/он
	end
end
function sbruy_desertir_spawn2(w_id,a_id)
	params.post_cond_check(w_id,(lua_random(30,40) / 100))
	params.post_cond_check(a_id,(lua_random(30,40) / 100))
	vergas_masks.set_mask_condition(a_id, lua_random(30,40),true)
end
