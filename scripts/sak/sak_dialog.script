function fill_red_terasure()
	local obj1 = g_sim:story_object(story_ids.red_inventory_box_01)
	if obj1 then
		local rand=get_value("r_treas_items",1)
		g_sim:create(table_bart[rand * 2].."_dyn5d",obj1.position, obj1.m_level_vertex_id, obj1.m_game_vertex_id, obj1.id)
		g_sim:create("af_unknown_"..lua_random(1,31).."_new",obj1.position, obj1.m_level_vertex_id, obj1.m_game_vertex_id, obj1.id)
		g_sim:create("red_shtreck_letter",obj1.position, obj1.m_level_vertex_id, obj1.m_game_vertex_id, obj1.id)
		g_sim:create("monolit_scientific_outfit",obj1.position, obj1.m_level_vertex_id, obj1.m_game_vertex_id, obj1.id)
		rand=level.get_time_days()
		while rand > 6 do
			rand = rand - 6
		end
		local art = table_dart[rand]
		g_sim:create(art,obj1.position, obj1.m_level_vertex_id, obj1.m_game_vertex_id, obj1.id)
		level.map_add_object_spot_ser(obj1.id,"crlc_big_treasure0","?")
	end
end
