	return sak.have_items_count("wpn_eagle_m1",1)~=false
end
function colt_not_have()
	return not colt_have()
end
-- semenov akkum end pda
function semenov_akkum_have()
	if db.actor:has_info("time_evening") or db.actor:has_info("time_night") then
			return true
		else
			return false
	end
end
function semenov_akkum_not_have()
	if db.actor:has_info("time_evening") or db.actor:has_info("time_night") then
			return false
		else
			return true
	end
end
