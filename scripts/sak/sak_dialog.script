function text_code_x10()
	local n=get_value("x18_iq_check",1)
	local text={
				"56326", "85695", "75962",
				"86596", "85369", "35692",
				"39258", "54962", "47852"
				}
	give_article("labx10_docent_code" .. n .. "_enc")
	sak.info_code()
	for id, obj in alife():objects() do
		if obj and strpos(obj:name(), "labx10_physic_destroyable_object_000",1,true) then
			local pk = get_netpk(obj,1)
			local data = pk:get()
			data.visual_name = "physics\\small_trash\\wood_board_br_01b"
			data.physic_type=3
			pk:set(data)
		end
	end
	remove_value("kol_harddisc")
	return "%c[255,216,186,140]"..text[n]
end
