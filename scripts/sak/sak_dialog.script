function rad_scaintist_doc()
	local obj = amk.spawn_item("rukzak_inventory_box",sak.v3f(306.3289,-39.3886,-26,3785),1930,67979)
	if obj then
		set_value("document_radar", obj.id)
	end
end
function spawn_rad_scaintist_doc()
	local id = get_value("document_radar")
	local obj
	if id then
		obj = server_obj(id)
	end
	if obj then
		for i=1,2 do
			g_sim:create("medkit_scientic",obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id)
			g_sim:create("grenade_f1",obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id)
			g_sim:create("ammo_7.62x54_ap",obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id)
		end
		g_sim:create("rad_scaintist_doc",obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id)
		level.map_add_object_spot_ser(obj.id,"crlc_big_treasure0","?")
		add_treas_tbl("l10_radar",obj.id)
		sak.obj_off_on(obj)
		remove_value("document_radar")
	end
end
