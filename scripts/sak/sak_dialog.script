function add_mil_trader_art()
	local m=get_value("r_task_reward",1)
	local k=get_value("r_treas_items",1)+2
	if m==1 then
			sak.create_items("af_rusty_sea-urchin_dyn"..k.."d",1)
		elseif m==2 then
			sak.create_items("af_night_star_dyn"..k.."d",1)
		elseif m==3 then
			sak.create_items("af_gold_fish_dyn"..k.."d",1)
		elseif m==4 then
			sak.create_items("af_electra_moonlight_dyn"..k.."d",1)
		else
		sak.create_items("af_cristall_dyn"..k.."d",1)
	end
end

