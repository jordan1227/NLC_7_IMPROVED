function relocate_money(victim, num, type)
	if db.actor and victim then
		if type=="in" then
			db.actor:give_money(num)
		elseif type==1 then
			db.actor:give_money(-num)
		end
		news_manager.relocate_money(db.actor, type, num)
	end
end

