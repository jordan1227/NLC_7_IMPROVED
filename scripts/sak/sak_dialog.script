function give_half_vodka()
	local total,give = #sak_inventory.eatable["vodka"],0
	if total == 1 then
		give = 1
	else
		give = math.floor(total/2)
	end
	if give > 0 then
		sak_inventory.release_actor_items("vodka", give)
	end
end

function out_vodka_from_mil()
	local objects = {}
	for id, obj in alife():objects() do
		if obj and obj.section_name and obj:section_name() == "vodka" and obj.level_name and obj.level_name == db.actor.level_name then
			if obj.parent_id~=0 and ( obj.parent_id==nil or obj.parent_id==BAD_OBJ_ID or ( server_obj(obj.parent_id):section_name()=="inventory_box" 
				or server_obj(obj.parent_id):section_name()=="rucksack" ) and not amk_offline_alife.box_is_protected(server_obj(obj.parent_id)) ) then
				objects[id] = obj
			end
		end
	end
	for id, obj in pairs(objects) do
		g_sim:release(obj,true)
	end
end

function out_wpn_from_mil()
	local objects = {}
	for id, obj in alife():objects() do
		if obj and obj.level_name and obj.level_name == db.actor.level_name and obj.section_name and strpos(obj:section_name(),"wpn_") then
			if obj.parent_id~=0 and ( obj.parent_id==nil or obj.parent_id==BAD_OBJ_ID or ( server_obj(obj.parent_id):section_name()=="inventory_box" 
				or server_obj(obj.parent_id):section_name()=="rucksack" ) and not amk_offline_alife.box_is_protected(server_obj(obj.parent_id)) ) then
				objects[id] = obj
			end
		end
	end
	for id, obj in pairs(objects) do
		g_sim:release(obj,true)
	end
end

