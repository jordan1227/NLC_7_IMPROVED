function add_art_capsule(who)
	local tbl = {}
	local art_capsule = "af_night_star_capsule_dyn1d"
	if who and type(who) == 'string' and ( who == 'sid' or who == 'bar' or who == 'sah' ) then
		tbl = get_value("capsule_ready_tbl", {})
	end
	if not table_empty(tbl) then
		if tbl[who] then
			art_capsule = tbl[who]
			tbl[who] = nil
		end
	end
	local art = string.gsub(art_capsule, "_capsule", "")
	sak.create_items(art,1)
	set_value("capsule_ready_tbl", tbl)
end
