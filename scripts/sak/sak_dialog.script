	local obj = g_sim:object(id)
	if obj then
		local r = lua_random(2,4)
		local item
		for i=1,r do
			item = nagrad.level_7[lua_random(#nagrad.level_7)]
			for i=1,r do
				g_sim:create(item, obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id)
			end
		end
	end
end
