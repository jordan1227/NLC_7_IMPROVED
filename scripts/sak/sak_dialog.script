	end
	return false
end
function transfer_any_dart()
	for i=1, table.getn(table_dart) do
		if sak.have_items_count(table_dart[i],1) then
			sak_inventory.release_actor_items(table_dart[i],1)
			break
		end
	end
end
function dart_full_have()
	for i=1, #table_dart do
		for kk,k in pairs(sak_inventory.rucksack) do
			if strpos(kk, table_dart[i],1,true) and not strpos(kk, "_capsule",1,true) then
				local kol=#k
				for m=1,kol do
					local obj=g_sim:object(k[m])
					if obj then
						local pk = get_netpk(obj,1)
						local data = pk:get()
						local cond=data.condition
						if cond>0.95 then return true end
					end
				end
			end
		end
	end
	return false
end
function transfer_dart_full()
	for i=1, #table_dart do
		for kk,k in pairs(sak_inventory.rucksack) do
			if strpos(kk, table_dart[i],1,true) and not strpos(kk, "_capsule",1,true) then
				local kol=#k
				for m=1,kol do
					local obj=g_sim:object(k[m])
					if obj then
						local pk = get_netpk(obj,1)
						local data = pk:get()
						local cond=data.condition
						if cond>0.95 then misc.release_obj(obj)
							sak.relocate_item("out", table_dart[i], 1)
						end
					end
				end
			end
		end
	end
end

-- универсальная проверка наличия предметов с состоянием >= указанного и их изъятие у ГГ
-- синтаксис <precondition>sak_dialog.cond_items_have(s,n,c,g)</precondition>, s - секция предмета, n - кол-во, c - кондиция, g - флаг изъятия предмета (true - да, false - нет)
-- если не задать аргумент(ы) n,c,g, то по дефолту им будут присвоены следующие значения: 1, 0.95, false
-- пример: <precondition>sak_dialog.cond_items_have("wpn_toz34",1,0.8,false)</precondition> - проверка наличия 1-го тозика, состояние >= 0.8
-- пример: <precondition>sak_dialog.cond_items_have("wpn_ak74",3,0.5,true)</precondition> - проверка наличия и последующее изъятие 3-ёх ак74, с состоянием >= 0.5
-- для артов действует особый синтаксис секций: "a","b","c","d","m1","m2","m3","m4" - таблицы артов 1-го, 2-го, 3-го уровней, пустышки, модификаты всех уровней, соответственно
-- также для артов можно напрямую задавать первым аргументом свою собственную таблицу секций 
-- пример для артов: <precondition>sak_dialog.cond_items_have("b",3,0.65,false)</precondition> - проверка наличия 3 любых артов 2-го уровня, состояние >= 0.65
-- пример для артов: <precondition>sak_dialog.cond_items_have("m3",2,0.35,true)</precondition> - проверка наличия и последующее изъятие 2 любых гипермодификатов, состояние >= 0.35
-- пример для артов: <precondition>sak_dialog.cond_items_have({"af_drops_dyn3d","af_medusa_dyn4d","af_electra_moonlight"},3,0.88,false)</precondition> - применение своей таблицы
function cond_items_have(s,n,c,g)
	local t_s = type(s)
	if ( t_s ~= "table" and t_s ~= "string" ) then
		log2("[cond_items_have]: wrong arg type for s = %s",t_s)
		return
	end
	
	local num, cond, give 
	if n == nil then
		num = 1
	else
		num = n
	end
	if c == nil then
		cond = 0.95
	else
		cond = c
	end
	if g == nil then
		give = false
	else
		give = g
	end
	-- Manool: затычка для тасков
	if c == nil and s == "device_pda_npc" then cond = 0.05 end
	
	local res = false
	
	if t_s == "table" then
		res = full_art_have(s,num,cond,give)
	elseif s == "a" then
		res = full_art_have(table_aart,num,cond,give)
	elseif s == "b" then
		res = full_art_have(table_bart,num,cond,give)
	elseif s == "c" then
		res = full_art_have(table_cart,num,cond,give)
	elseif s == "d" then
		res = full_art_have(table_dart,num,cond,give)
	elseif string.len(s) == 2 then
		res = full_art_have(table_modarts["mod"..(string.sub(s,2))],num,cond,give)
	else
		local tbl
		local eatable_tbl = {"device_pda_npc", "arc_art_box_8basic"}
		if sak.is_food(s) or str_in_tab(s, eatable_tbl) then
			tbl = sak_inventory.eatable
		else
			tbl = sak_inventory.rucksack
		end
		local count = 0
		local exact_items = {}
		for k,v in pairs(tbl) do
			if s == k then
				for i=1,#v do
					local obj=g_sim:object(v[i])
					if obj and check_cond(obj,cond) then
						table.insert(exact_items,obj.id)
						count = count + 1
						if count == n then
							if g then
								cond_items_give(exact_items,n)
							end
							return true
						end
					end
				end
			end
		end
	end
	return res
end
function full_art_have(s,n,c,g,excl_new)
	local count = 0
	local excl
	if excl_new == nil then
		excl = true
	else
		excl = excl_new
	end
	local excl_flt
	if not excl then
		excl_flt = function (sec) return true end
	else
		excl_flt = function (sec) return not strpos(sec,"_new",1,true) end
	end
	local exact_arts = {}
	for i=1, #s do
		for k,v in pairs(sak_inventory.rucksack) do
			if strpos(k, s[i],1,true) and not strpos(k, "_capsule",1,true) and excl_flt(k) then
				for ii=1,#v do
					local obj=g_sim:object(v[ii])
					if obj and check_cond(obj,c) then
						table.insert(exact_arts,obj.id)
						count = count + 1
						if count == n then
							if g then
								cond_items_give(exact_arts,n)
							end
							return true
						end
					end
				end
			end
		end
	end
	return false
end
function cond_items_give(tbl,num)
	if num ~= 0 and #tbl >= num then
		local count = 0
		local rel_sec_tbl = {}
		while num > count do
			local obj = g_sim:object(tbl[1])
			if obj then
				local sec = obj:section_name()
				if not rel_sec_tbl[sec] then
					rel_sec_tbl[sec] = 1
				else
					rel_sec_tbl[sec] = rel_sec_tbl[sec] + 1
				end
				misc.release_obj(obj)
				table.remove(tbl,1)
				count = count + 1
			end
		end
		for k,v in pairs(rel_sec_tbl) do
			sak.relocate_item("out", k, v)
		end
	else
		log2("[cond_items_give]: !error!")
	end
end
function check_cond(obj,c)
	if obj == nil then
		return false
	end
	local pk = get_netpk(obj,1)
	local data = pk:get()
	local cond=data.condition
	return cond >= c
end

-- Sn: универсальные функции для генерации/выдачи заранее заданных случайных артов
function pre_rolled_arts_set(cat,dyn_min,dyn_max,capsule_flag,cond,var)
	local stored = get_value(var,{})
	local sec = ""
	
	if type(cat) == 'string' then
		if cat == "a" then
			sec = table_aart[lua_random(1,7)]
		elseif cat == "b" then
			sec = table_bart[lua_random(1,7)]
		elseif cat == "c" then
			sec = table_cart[lua_random(1,7)]
		elseif cat == "d" then
			sec = table_dart[lua_random(1,7)]
		elseif string.len(cat) == 2 then
			sec = table_modarts["mod"..(string.sub(cat,2))][lua_random(1,7)]
		end
	elseif type(cat) == 'table' then
		sec = cat[lua_random(1,#cat)]
	else
		log2("pre_rolled_arts_set: incorrect cat type [%s]",type(cat))
		return
	end
	
	if sec == "" then return end
	local need_dyn = dyn_min ~= nil
	
	if capsule_flag then
		sec = sec .. "_capsule"
	end
	if need_dyn then
		local dyn
		if dyn_min == 0 then
			dyn = lua_random(1,5)
		else
			dyn = lua_random(dyn_min,dyn_max)
		end
		sec = sec .. "_dyn" .. dyn .. "d"
	end
	table.insert(stored,{sec,cond})
	-- dump_table(stored,"pre_rolled_arts_set."..var)
	set_value(var,stored)
end
function pre_rolled_arts_give(var,spawn_to_id)
	local stored = get_value(var,{})
	if #stored > 0 then
		-- dump_table(stored,"pre_rolled_arts_give."..var)
		local spawn_to_obj = db.actor
		if spawn_to_id and type(spawn_to_id) ~= 'userdata' then
			spawn_to_obj = server_obj(spawn_to_id)
		end
		if not spawn_to_obj then return end
		for _,v in ipairs(stored) do
			local art = misc.spawn_to(v[1],spawn_to_obj)
			if v[2] ~= 1 then
				if not spawn_to_id or type(spawn_to_id) == 'userdata' then
					level.client_spawn_manager():add(
					art.id, -1,
					function( id, art )
						art:set_condition(v[2])
					end
					)
				else
					params.post_cond_check(art.id,v[2])
				end
			end
			if not spawn_to_id then
				sak.relocate_item("in", v[1], 1)
			end
		end
		remove_value(var)
	end
end

function treasure_any_capsule()
	local capsule=table_capsule[lua_random(1,#table_capsule)]
	return capsule
end
function any_cart_capsule()
	local capsule=table_capsule[lua_random(1,7)]
	return capsule
end
function have_capsule()
	for i=1, table.getn(table_capsule) do
		if sak.have_items_count(table_capsule[i],1) then return true end
	end
	return false
end
function not_have_capsule()
	return not have_capsule()
end
function transfer_any_capsule(who)
	local section
	for i=1, table.getn(table_capsule) do
		if sak.have_items_count(table_capsule[i],1) then
			for ii,kk in pairs(sak_inventory.rucksack) do
				if strpos(ii, table_capsule[i],1,true) then
					section=tostring(ii)
				end
			end
			sak_inventory.release_actor_items(table_capsule[i],1)
			if who and type(who) == 'string' and ( who == 'sid' or who == 'bar' or who == 'sah' ) then
				local tbl = get_value("capsule_ready_tbl", {})
				tbl[who] = section
				set_value("capsule_ready_tbl", tbl)
			end
			break
		end
	end
end
function out_item_section_from_actor(first_speaker, second_speaker, section, amount)
	local npc = who_is_npc(first_speaker, second_speaker)
	local actor = who_is_actor(first_speaker, second_speaker)
	local i = 0
	if not amount then
		amount = 1
	end
	local function transfer_object_item(temp, item)
		local vItemSection=item:section()
		if (strpos(vItemSection,"^"..section) and i~=0) then
			amk.remove_item_from_inventory(item, actor)
			i = i - 1
		end
	end
	if amount=="all" then
		i = -1
		actor:iterate_inventory(transfer_object_item, nil)
		amount = (i+1)*(-1)
		i = 0
	elseif amount > 1 then
		i = amount
		actor:iterate_inventory(transfer_object_item, nil)
	elseif amount < 1 then
		--abort("Wrong parameters in function "relocate_item_section_from_actor"!")
	else
		amk.remove_item_from_inventory(actor:object(section), actor)
	end
	sak.relocate_item("out", section, amount - i)
	return (amount - i)
end
function relocate_item_section_from_actor(first_speaker, second_speaker, section, amount)
	local npc = who_is_npc(first_speaker, second_speaker)
	local actor = who_is_actor(first_speaker, second_speaker)
	local i = 0
	if not amount then
		amount = 1
	end
	local function transfer_object_item(temp, item)
		local vItemSection=item:section()
		if (strpos(vItemSection,section,1,true) and i~=0) then
			db.actor:transfer_item(item, npc)
			i = i - 1
		end
	end
	if amount=="all" then
		i = -1
		actor:iterate_inventory(transfer_object_item, nil)
		amount = (i+1)*(-1)
		i = 0
	elseif amount > 1 then
		i = amount
		actor:iterate_inventory(transfer_object_item, nil)
	elseif amount < 1 then
		--abort("Wrong parameters in function "relocate_item_section_from_actor"!")
	else
		actor:transfer_item(actor:object(section), npc)
	end
	sak.relocate_item("out", section, amount - i)
end
function who_is_npc(first_speaker, second_speaker)
	local npc = second_speaker
	if db.actor:id()==npc:id() then
		npc  = first_speaker
	end
	return npc
end
function who_is_actor(first_speaker, second_speaker)
	local npc = second_speaker
	if db.actor:id()~=npc:id() then
		npc  = first_speaker
	end
	return npc
end
function on_chimera_kill(obj,who)
	if obj:section() == 'nazar_chimera_weak' then return end
	local id=obj:id()
	if math.fmod(id, 20)==0 then
		amk.spawn_item_in_inv("mutant_chimera_kogot",obj)
	end
	if math.fmod(id, 30)==0 then
		amk.spawn_item_in_inv("mutant_chimera_kogot",obj)
	end
	if math.fmod(id, 40)==0 then
		amk.spawn_item_in_inv("mutant_chimera_kogot",obj)
	end
end
function on_boar_kill(obj,who)
	local id=obj:id()
	if math.fmod(id, 10)==0 then
		misc.spawn_to("mutant_boar_leg", obj)
	end
	if math.fmod(id, 20)==0 then
		misc.spawn_to("mutant_boar_leg", obj)
	end
	if math.fmod(id, 25)==0 then
		misc.spawn_to("mutant_boar_leg", obj)
	end
end
function on_burer_kill(obj,who)
	local lname = level.name()
	if obj==nil or lname=="l08u_brainlab" or lname=="lost_village" then 
		return 
	end
	local obj_sect = obj:section()
	if obj_sect=="burer_hos" and lname == "hospital" then
		amk.spawn_item_in_inv("mfake_af_dummy_fire",obj)
		return
	end
	local r = dsh.get_next_random( "burer_art_chance", 1, 100 )
	if r % 20 == 0 then
		local section=table_aart[lua_random(1,#table_aart)]
		local rnd = lua_random(2,3)
		section="mfake_"..section.."_dyn"..tostring(rnd).."d"
		amk.spawn_item_in_inv(section,obj)
		return
	end
end
function on_fracture_kill(obj,who)
	local lname = level.name()
	if obj==nil or lname=="marsh" or lname =="l03_agroprom" then 
		return 
	end
	local spawn = false
	local r = dsh.get_next_random( "fracture_art_chance", 1, 100 )
	local obj_sect = obj:section()
	if obj_sect=="fracture_weak" and (r % 33 == 0) then
		spawn = true
	elseif obj_sect=="fracture_normal" and (r % 24 == 0) then
		spawn = true
	elseif obj_sect=="fracture_strong" and (r % 19 == 0) then
		spawn = true
	end
	if spawn then
		amk.spawn_item_in_inv("mfake_af_dummy_buliz",obj)
	end
end
function on_flesh_strong_kill(obj,who)
	if obj==nil or not db.actor:has_info("dsc_greens_flesh_shkura") then return end
	local id=obj:id()
	if math.fmod(id, 2)==0 then
		return amk.spawn_item_in_inv("mutant_flesh_shkura",obj)
	end
end

function have_val_dram_1()
	if has_alife_info("val_dram_pda_out_info") then
		return have_any_dart()~=false or gg_n_cart_have(1) or gg_n_bart_have(2)==true
	else
		return have_any_dart()~=false or gg_n_cart_have(1) or have_bart()~=false
	end
end
function give_val_dram_1(first_speaker, second_speaker)
	for i=1, table.getn(table_dart) do
		if sak.have_items_count(table_dart[i],1,false,true) then
			sak_inventory.release_actor_items(table_dart[i],1,false,true)
			if not has_alife_info("val_dram_pda_out_info") then
				set_value("kocherga_bonus",true)
				local cond = lua_random(70,80) / 100
				sak_dialog.pre_rolled_arts_set("a",5,5,nil,cond,"kocherga_bonus_rew")
				set_value("rashpil_bonus_rew",true)
			end
			return
		end
	end
	for i=1, table.getn(table_cart) do
		if sak.have_items_count(table_cart[i],1,true,true) then
			sak_inventory.release_actor_items(table_cart[i],1,false,true)
			if not has_alife_info("val_dram_pda_out_info") then
				set_value("kocherga_bonus",true)
				local cond = lua_random(70,80) / 100
				sak_dialog.pre_rolled_arts_set("a",5,5,nil,cond,"kocherga_bonus_rew")
				set_value("rashpil_bonus_rew",true)
			end
			return
		end
	end
	local count = 0
	for i=1, table.getn(table_bart) do
		if count == 2 then
			if not has_alife_info("val_dram_pda_out_info") then
				set_value("kocherga_bonus",true)
				local cond = lua_random(70,80) / 100
				sak_dialog.pre_rolled_arts_set("a",5,5,nil,cond,"kocherga_bonus_rew")
				set_value("rashpil_bonus_rew",true)
			end
			return
		end
		for kk,vv in pairs(sak_inventory.rucksack) do
			if count == 2 then break end
			if strpos(kk,table_bart[i],1,true) and not strpos(kk,"_new",1,true) then
				for ii=1,#vv do
					local obj = g_sim:object(vv[ii])
					if obj then
						sak.relocate_item("out",obj:section_name(),1)
						misc.release_obj(obj.id)
						count = count + 1
					end
					if count == 2 then break end
				end
			end
		end
	end
end
function have_val_dram_2()
	return not have_val_dram_1()
end
function val_dram_timer()
	timers.start_timer("val_dram_timer",2,23,55,"sak_dialog.val_dram_timer_end()")
end
function val_dram_timer_end()
	db.actor:give_info_portion("val_dram_fire")
	sak.set_val_gulag_enemy_actor()
end
function val_dram_pda_out()
	local cash = get_value("many_cash",450)
	local money = db.actor:money()
	db.actor:give_money(-(money-cash))
	local pda = db.actor:object("device_pda")
	if pda then
		-- Sn: помимо set_actor_allow_pda здесь всё же следет оставить и само изъятие предмета
		-- т.к. часть прекондишенов проверяет его наличие; смысл переделывать, если работает?
		misc.release_obj(pda)
		level.set_actor_allow_pda(false)
		sak.relocate_item("out", "device_pda_npc_gg")
	end
end
function val_dram_restr_check()
	if not has_alife_info("val_dram_scene_end") and not has_alife_info("val_dram_fire") then
		db.actor:give_info_portion("val_dram_fire")
		sak.set_val_gulag_enemy_actor()
	end
	if has_alife_info("val_dram_scene_end") and db.actor and not db.actor:object("device_pda") and not has_alife_info("val_dram_pda_out_info") then
		db.actor:give_info_portion("val_dram_pda_out_info")
	end
end
function rashpil_pda_spawn()
	if has_alife_info("val_dram_pda_out_info") and db.actor and not db.actor:object("device_pda") then
		local obj = server_obj("val_dram_glavn")
		if obj then
			misc.spawn_to("device_pda_npc_gg",obj)
		end
		db.actor:disable_info_portion("val_dram_pda_out_info")
		db.actor:give_info_portion("pda_is_broken")
	end
end
function rashpil_pda_return()
	if new_pda_buy_prec() then
		misc.spawn_to("device_pda",db.actor)
		level.set_actor_allow_pda(true)
		sak.relocate_item("in", "device_pda_npc_gg")
	end
	set_value("rashpil_bonus_rew",true)
	db.actor:disable_info_portion("val_dram_pda_out_info")
end
function new_pda_buy_prec()
	return has_alife_info("val_dram_pda_out_info") and not db.actor:object("device_pda")
end
function new_pda_not_buy_prec()
	return not new_pda_buy_prec()
end
function kocherga_bonus_precond_yes()
	local b = get_value("kocherga_bonus")
	return b ~= nil and b == true
end
function kocherga_bonus_precond_no()
	return not kocherga_bonus_precond_yes()
end

