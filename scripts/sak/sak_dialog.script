function voronin_seif_money_coeff()
	local coeff = 1.0
	if voronin_kurjer2_precond_bad() then
		coeff = 1.5
	end
	return coeff
end
function text_money_voronin_seif_dialog()
	local day_money = math.ceil(math.sqrt(sak.day_money))
	local coeff = voronin_seif_money_coeff()
	local cost1=(3000+day_money*800) * coeff
	local cost2=(10000+day_money*2000) * coeff
	return "%c[255,216,186,140]"..string.format(game.translate_string("text_money_voronin_seif_dialog"),cost1,cost2)
end
function voronin_seif_money_have()
	local day_money = math.ceil(math.sqrt(sak.day_money))
	local coeff = voronin_seif_money_coeff()
	return db.actor:money()>=(3000+day_money*800) * coeff
end
function voronin_seif_money_not_have()
	return not voronin_seif_money_have()
end
function give_voronin_seif_money(t1,t2)
	local npc=t1
	if npc:id()==db.actor:id() then npc=t2 end
	local day_money = math.ceil(math.sqrt(sak.day_money))
	local coeff = voronin_seif_money_coeff()
	relocate_money(npc,(3000+day_money*800) * coeff,1)
end
function voronin_seif_money_dolg()
	local day_money = math.ceil(math.sqrt(sak.day_money))
	local coeff = voronin_seif_money_coeff()
	local summ = 2*(3000+day_money*800) * coeff
	set_value("voronin_dolg", summ)
	db.actor:give_info_portion("voronin_dolg_have")
end
function voronin_dolg_money_have()
	local summ = get_value("voronin_dolg", 15000)
	local day_money = math.ceil(math.sqrt(sak.day_money))
	local coeff = voronin_seif_money_coeff()
	return db.actor:money()>=((3000+day_money*800) * coeff +summ)
end
function give_voronin_dolg(t1,t2)
	local npc=t1
	if npc:id()==db.actor:id() then npc=t2 end
	local summ = get_value("voronin_dolg", 15000)
	local day_money = math.ceil(math.sqrt(sak.day_money))
	local coeff = voronin_seif_money_coeff()
	relocate_money(npc,((3000+day_money*800) * coeff +summ),1)
	db.actor:disable_info_portion("voronin_dolg_have")
end
