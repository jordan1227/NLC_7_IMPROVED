-- запчасти у Егеря
function lesnik_add_potroha(sec,num)
	local act = db.actor
	local j = 1
	if num ~= nil and type(num) == "number" then
		j = num
	end
	for i = 1,j do
		local obj = misc.spawn_to (sec, act)
		if obj then
			local cond = lua_random(35,55) * 0.01
			level.client_spawn_manager():add(
			obj.id, -1,
			function( id, obj )
				obj:set_condition( cond )
			end
			)
			sak.relocate_item("in", sec, 1)
		end
	end
end
