-- плата за поиск людей у Доцента в Баре
function bar_npc_search_money_price()
	if has_alife_info("docent_secret_room_pay_info") then
		return game.translate_string("vip_client")
	end
	local summ = 500+math.ceil(math.sqrt(sak.day_money))*100
	return summ
end
function bar_npc_search_money_have()
	local summ = bar_npc_search_money_price()
	return ( type(summ) == 'number' and db.actor:money()>=summ ) or has_alife_info("docent_secret_room_pay_info")
end
function bar_npc_search_money_give()
	if has_alife_info("docent_secret_room_pay_info") then return end
	local act = db.actor
	local summ = bar_npc_search_money_price()
	act:give_money( - summ )
	news_manager.relocate_money(act,summ,1)
end

