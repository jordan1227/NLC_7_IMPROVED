-- монолитовская экза в танке
function fill_tank_inventory_box()
	local obj = g_sim:story_object(story_ids.red_q11_n)
	if obj then
		g_sim:create("monolit_exoskeleton",obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id)
		g_sim:create("af_dummy_pellicle",obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id)
		g_sim:create("sak_document4",obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id, obj.id)
		sak.obj_off_on(obj)
	end
	level.map_add_object_spot_ser(obj.id, "crlc_big_treasure0", "?")
end
