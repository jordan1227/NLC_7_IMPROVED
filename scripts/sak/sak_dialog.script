function olded_kidney(id)
	local cond=0.15+(level.get_time_hours()/34)
	params.obj_condition(id, cond)
	local objd=g_sim:object(id)
	local pk = get_netpk(objd,1)
	local data = pk:get()
	data.condition = cond
	pk:set(data)
end
