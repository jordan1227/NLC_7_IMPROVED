end
function out_wpn_from_actor()
	out_wpn_actor(5862)
end
function add_wpn_in_actor()
	add_wpn_actor(5862)
end
function out_wpn_actor(sid)
	local in_object = level_object_by_sid(sid)
	if not in_object then return end
	local out_object = db.actor
	for i,k in pairs(sak_inventory.slots) do
		if (strpos(i, "wpn_",1,true) and (i~="wpn_binoc") and (i~="bolt")) then
			local item = client_obj(k[1])
			out_object:transfer_item(item, in_object)
			sak.relocate_item("out", i, 1)
		end
	end
	for i,k in pairs(sak_inventory.rucksack) do
		if strpos(i, "wpn_",1,true) then
			for j = 1, #k do
				local item = client_obj(k[j])
				out_object:transfer_item(item, in_object)
			end
		sak.relocate_item("out", i, #k)
		elseif strpos(i, "rucksack",1,true) then
			for a = 1,#k do
				local o_id=k[a]
				local box = client_obj(o_id)
				if box then
					box:iterate_inventory(function(_, item)				
						local sect=item:section()
						if strpos(sect, "wpn_",1,true) then
							out_object:transfer_item(item, in_object)
							sak.relocate_item("out", sect, 1)
						end
					end)
				end
			end
		end
	end
	sak.obj_off_on(in_object)
end
function mil_actor_stash_prec_yes()
	local box = level_object_by_sid(5862)
	if box then
		local cnt = box:inv_box_count()
		return cnt > 0
	end
	return false
end
function mil_actor_stash_prec_no()
	return not mil_actor_stash_prec_yes()
end
function add_wpn_actor(sid)
	local t = {}
	local out_object = level_object_by_sid(sid)
	local in_object = db.actor
	if out_object then
		local cnt = out_object:inv_box_count()
		for i = 0, cnt - 1 do
			local obj = out_object:object_from_inv_box(i)
			if obj then
				t[obj:id()] = obj
			end
		end
		for id, obj in pairs(t) do
			out_object:transfer_item(obj, in_object)
			sak.relocate_item("in", obj:section(), 1)
		end
	end
end
