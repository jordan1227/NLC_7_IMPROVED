function time_yan_psy()
	local rand = (get_value("r_task_reward",1))-1
	set_value("psy_antenna_good_time", rand)
	if rand==0 then
		return game.translate_string("t_at_midnight")
	elseif rand==1 then
		return game.translate_string("t_at_one_clock_night")
	else
		return string.format(game.translate_string("t_at_rand_clock_night"), rand)
	end
end
