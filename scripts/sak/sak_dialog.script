function voron_col_item_remove(sec)
	local tbl = get_value("voron_col_items",{})
	if table_empty(tbl) then
		tbl = { 
		["klava"] = false,
		["bandit_master_outfit_m1"] = false,
		["outfit_specnaz_m1"] = false,
		["outfit_stalker_m1"] = false,
		["soldier_outfit"] = false,
		["monolit_scientific_outfit"] = false,
		["wpn_flame"] = false
		}
	end
	if sec == "klava" then
		sak_inventory.release_actor_items("klava",1)
	else
		sak_dialog.cond_items_have(sec,1,nil,true)
	end
	tbl[sec] = true
	set_value("voron_col_items",tbl)
end
function voron_col_item_count(val,sign)
	local tbl = get_value("voron_col_items",{})
	local count = 0
	for _,v in pairs(tbl) do
		if v ~= false then
			count = count + 1
		end
	end
	if sign == "gr" then
		return count > val
	elseif sign == "ls" then
		return count < val
	end
end
