	if not has_alife_info("docent_borzyi_radio_ready") then
		sak.send_tip(game.translate_string("docent_borzyi_radio_timer_end_sms"),game.translate_string("docent_sms_h"),10,15,"g_g","sak","green")
		db.actor:give_info_portion("docent_borzyi_radio_ready")
	end
end
function docent_borzyi_radio_pay(give)
	local g = false
	if give and type(give) == "boolean" then
		g = give
	end
	local count = 0
	local ids = {}
	local items = get_shadow_inv():get_content(true)
	for k,v in items:ipairs() do
		if v.sect == "detector_elite" then
			count = count + 1
			table.insert(ids,v.id)
			if count >= 2 then
				break
			end
		end
	end
	if count < 2 then
		return false
	else
		if g then
			for _,v in ipairs(ids) do
				misc.release_obj(v)
			end
			sak.relocate_item("out", "detector_elite", 2)
		end
		return true
	end
end
function docent_borzyi_radio_reward(rnd)
	local points = { {136.7737,-4.2612,-296.2351,3302,105549}, {25.6366,-2.0875,-241.3323,3286,80059}, {-19.4819,-2.0473,-269.3688,3276,50548} }
	local p = points[rnd]
	local obj = amk.spawn_item("rukzak_inventory_box",sak.v3f(p[1],p[2],p[3]),p[4],p[5])
	if obj then
		misc.spawn_to("af_compass_dyn5d",obj)
		sak.obj_off_on(obj)
		add_treas_tbl("red_forest",obj.id)
		level.map_add_object_spot_ser(obj.id,"crlc_big_treasure"..tostring(lua_random(1,4)),"docent_borzyi_radio_reward")
	end
end

