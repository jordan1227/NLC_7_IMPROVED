--------- проверка падения репутации Меченного у Шерстюка и Борова
function reputation_down_check()	-- вызывается периодически
	ogse_signals.get_mgr():reschedule(30000)

	-- проверка падения репутации у Шерстюка
	if get_value("reputation_down_sherstuk_check_flag") == nil then
		set_value("reputation_down_sherstuk_check_flag", true)
	end
	if get_value("reputation_down_sherstuk_check_flag") and db.actor:has_info("sherstuk_enemy") then
		set_value("reputation_down_sherstuk_check_flag", false)
		timers.start_timer("reputation_down_sherstuk_report1",0,0,15,"sak_dialog.reputation_down_sherstuk_report1()")
	end

	-- проверка падения репутации у Борова
	if get_value("reputation_down_borov_check_flag") == nil then
		set_value("reputation_down_borov_check_flag", true)
	end
	if get_value("reputation_down_borov_check_flag") and db.actor:has_info("actor_enemy_for_bandit") then
		set_value("reputation_down_borov_check_flag", false)
		timers.start_timer("reputation_down_bandit_report1",0,0,15,"sak_dialog.reputation_down_bandit_report1()")
	end

end
