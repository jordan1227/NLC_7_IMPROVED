local akkum_id = nil
function af_full_akkum_have()
	akkum_id = nil
	for sec,ids in pairs(sak_inventory.rucksack) do
		if strpos(sec,"af_full_akkum",1,true) then
			-- log2("[af_full_akkum_have]: af_full_akkum_have found! | #ids = %d",#ids)
			local cond = 0
			local min_cond = 99
			for i=1,#ids do
				local obj=g_sim:object(ids[i])
				if obj then
					cond = math.modf( params.get_condition(obj.id,0.99) * 100 )
					if cond < min_cond then
						min_cond = cond
						akkum_id = obj.id
					end
				end
				-- log2("[af_full_akkum_have]: itt = %d, cond = %s, min_cond = %s, akkum_id = %s",i,cond,min_cond,tostring(akkum_id))
			end
			if akkum_id ~= nil then
				return true
			else
				return false
			end
		end
	end
	return false
end
function give_af_full_akkum()
	if akkum_id ~= nil then
		local obj = g_sim:object(akkum_id)
		if obj then
			misc.release_obj(obj)
			sak.relocate_item("out", "af_full_akkum", 1)
		end
	end
end
