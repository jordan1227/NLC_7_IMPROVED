-- портим арты по новому
function take_glassbeads_new( first_speaker, second_speaker )
	local obj = misc.spawn_to ( "af_dummy_glassbeads", db.actor )
	if obj then
		sak.relocate_item("in", "af_dummy_glassbeads", 1 )
		local objd = g_sim:object( obj.id )
		local pk = get_netpk( objd, 1 )
		ASSERT( ( pk and pk:isOk() ), "can't read netpacket of %s", obj:name() )
		local data = pk:get()
		local cond = lua_random( 25, 35 ) * 0.01
		data.condition = cond
		pk:set( data )
		level.client_spawn_manager():add(
			obj.id, -1,
			function( id, obj )
				obj:set_condition( cond )
			end
		)
	end
end
function take_battery_new( first_speaker, second_speaker )
	local obj = misc.spawn_to ( "af_dummy_battery", db.actor )
	if obj then
		sak.relocate_item("in", "af_dummy_battery", 1 )
		local objd = g_sim:object( obj.id )
		local pk = get_netpk( objd, 1 )
		ASSERT( ( pk and pk:isOk() ), "can't read netpacket of %s", obj:name() )
		local data = pk:get()
		local cond = lua_random( 30, 35 ) * 0.01
		data.condition = cond
		pk:set( data )
		level.client_spawn_manager():add(
			obj.id, -1,
			function( id, obj )
				obj:set_condition( cond )
			end
		)
	end
end
