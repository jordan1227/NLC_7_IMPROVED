function fox_reward_toz()
	local box = server_obj("esc_inventory_box_0014")
	if box then
		local toz = misc.spawn_to("wpn_toz34",box)
		misc.spawn_to("ammo_12x70_buck",box)
		if toz then
			params.post_cond_check(toz.id,(lua_random(80,90) / 100))
