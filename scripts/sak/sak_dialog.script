function gar_flame_full_have()
	local obj = db.actor:object("wpn_flame")
	return obj and gar_flame_cond(obj)
end
function gar_flame_cond(obj)
	local mag_size = system_ini():r_float("wpn_flame", "ammo_mag_size")
	if obj then
		return obj:get_ammo_in_magazine() == mag_size
	end
end
function gar_flame_not_full_have()
	local obj = db.actor:object("wpn_flame")
	return obj and not gar_flame_cond(obj)
end
