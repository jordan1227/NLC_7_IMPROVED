-- Бром спас
function spawn_drunk_dolg_spas() -- спавним спас
	local points={
				{-334.63,-22.05,217.47,16460,1839},
				{-337.12,-23.07,251.70,14561,1835},
				{-332.99,-23.02,263.95,17501,1834}
				}
	local rand=lua_random(#points)
	local spas = g_sim:create("wpn_spas12_m1",sak.v3f(points[rand][1],points[rand][2],points[rand][3]),points[rand][4],points[rand][5])
	if spas then
		params.post_cond_check(spas.id, 0.36)
	end
end
