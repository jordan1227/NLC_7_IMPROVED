function neumeha_container_spot()
	local a=get_value("kontainer", 0)
	if a==0 then return end
	local obj = g_sim:object(a)
	if obj then
		-- Sn: здесь спецом не ставится spot_ser, т.к. иначе метка будет перемещаться вместе с контейнером
		-- и в конце концов окажется на Сидоре, что выглядит тупо, учитывая контекст задания 
		level.map_add_object_spot(obj.id, "crlc_big_treasure5", "neumeha_container_spot")
	end
end
function off_kontainer()
	local a=get_value("kontainer", 0)
	if a==0 then return end
	level.map_remove_object_spot(a, "crlc_big_treasure5")
	sak_inventory.release_actor_items("arc_art_box_1basic",1)
	sak_inventory.release_actor_items("amk_af_night_star",1)
	remove_value("kontainer")
end

function add_borzyi_radio()
	local points = { {-29.3666,2.6070,-161.9111,3268,44053}, {-34.0746,2.6034,-154.3890,3266,38923}, {-27.4034,3.1681,-147.1387,3266,44063} }
	local p = points[lua_random(#points)]
	local obj = amk.spawn_item("rukzak_inventory_box",sak.v3f(p[1],p[2],p[3]),p[4],p[5])
	if obj then
		misc.spawn_to("borzyi_radio",obj)
		add_treas_tbl("red_forest",obj.id)
		sak.obj_off_on(obj)
	end
end
function borzyi_radio_signal()
	del_red_sos_spot()
	for i=1,3 do
		schedule.add("borzyi_radio_signal"..tostring(i),"sak_dialog.borzyi_radio_signaled()", 5000 * i)
	end
end
local sig_counter = 0
function borzyi_radio_signaled()
	vergas_lib.s_play([[pda\start_pda]])
	sig_counter = sig_counter + 1
	if sig_counter == 3 then
		sak.send_tip(game.translate_string("borzyi_radio_signaled_sms"),game.translate_string("thinking_out_loud"),10,15,"g_g","sak","yellow")
	end
end
function add_red_sos_spot()
	local obj = server_obj("red_smart_sos_die")
	if obj then
		level.map_add_object_spot_ser(obj.id,"crlc_big","red_sos_spot")
	end
	timers.start_timer("borzyi_rf_quest_timer",0,11,55,"sak_dialog.borzyi_rf_quest_timer()")
end
function del_red_sos_spot()
	local obj = server_obj("red_smart_sos_die")
	if obj then
		if level.map_has_object_spot(obj.id,"crlc_big")~=0 then
			level.map_remove_object_spot(obj.id,"crlc_big")
		end
	end
end
function borzyi_rf_quest_timer()
	if not has_alife_info("borzyi_rf_quest_done") then
		db.actor:give_info_portion("borzyi_rf_quest_refuse")
		del_red_sos_spot()
	end
end
