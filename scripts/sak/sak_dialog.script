function som_ammo_12x70_buck(som)
	local npc=db.actor
	local kol=1+math.ceil(som-(math.ceil(sak.day_money/10))*(som/10))
	if kol<=0 then kol=1 end
	local count=kol
	local pachka=0
	while kol>10 do
		kol=kol-10
		pachka=pachka+1
	end
	if pachka>0 then
		for i=1,pachka do
			g_sim:create("ammo_12x70_buck",npc:position(),
			npc:level_vertex_id(),
			npc:game_vertex_id(),
			npc:id())
		end
	end
	if count>(10*pachka) then
		g_sim:create_ammo("ammo_12x70_buck", npc:position(),
		npc:level_vertex_id(),
		npc:game_vertex_id(),
		npc:id(),(count-(10*pachka)))
	end
	local d_a = get_value("dan_ammo", 0)
	set_value("dan_ammo", d_a + count)
	local task_texture, task_rect=get_texture_info("ui_iconsTotal_found_thing")
	local news_text ="%c[255,1,255,1]"..game.translate_string("general_in_item").."\\n".."%c[default] "..count.." ".. game.translate_string("st_shot_count")
	npc:give_talk_message(news_text, task_texture, task_rect,"iconed_answer_item")
end
