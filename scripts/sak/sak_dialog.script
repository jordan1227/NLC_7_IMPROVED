function add_esc_vodka()
	local tbl = {"esc_inventory_box_0015","esc_inventory_box_0016","esc_inventory_box_0017"}
	local c = lua_random(1,4)
	if c ~= 4 then
		local obj = g_sim:object(tbl[c])
		if obj then
			g_sim:create("vodka",obj.position,obj.m_level_vertex_id,obj.m_game_vertex_id,obj.id)
			sak.obj_off_on(obj)
		end
	else
	g_sim:create("vodka",vector():set(-236.304702758789,-19.18630027771,-156.016006469727),21329,47)
	end
end

