function upgrade_outfit_precond()
	local item_in_slot_6 = actor_active_item(6)
	if item_in_slot_6~=nil then
		local sec = item_in_slot_6:section()
		return not str_in_tab (sec, {"bandit_veteran_", "bandit_master_", "_q_"})
	end
end
function upgrade_ok_precond()
	return get_value("upgrade_info")~=nil
end
function upgrade_not_ok_precond()
	return not upgrade_ok_precond()
end
function give_upgrade_outfit()
	local item_in_slot_6 = actor_active_item(6)
	local sec = item_in_slot_6:section()
	local cond, dec = math.modf(item_in_slot_6:condition() * 100)
	dec = math.floor(dec * 10)
	if dec >= 5 then
		cond = cond + 1
	end

	local sobj = server_obj(item_in_slot_6:id())
	local cd = sobj and sobj.custom_data or ""

	local tab = {sec,cond,cd,lua_random(4320, 5760)}
	set_value("upgrade_info", tab)
	misc.release_obj(item_in_slot_6)
    sak.relocate_item("out", sec)
end
function return_upgrade_outfit()
	local tab = get_value("upgrade_info")
	if tab == nil then return end
	local sec = tab[1]
	local outfit = misc.spawn_to(sec,db.actor)

	level.client_spawn_manager():add(
		outfit.id, -1,
		function( id, outfit )
			outfit:set_condition(tab[2] / 100)
		end
	)

	sak.relocate_item("in", sec, 1)
	local sobj = server_obj(outfit.id)
	if sobj and tab[3] ~= "" then
		sobj.custom_data = tab[3]
	end
	bind_upg_outfit.set_end_time(sobj, timers.Get_Game_Minutes() + tab[4])
	remove_value("upgrade_info")
end
