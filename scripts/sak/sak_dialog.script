function have_chargeable_pda()
	for k,v in pairs(sak_inventory.eatable) do
		if k == "device_pda_npc" then
			for _,vv in ipairs(v) do
				local status = vergas_pda.get_pda_status(vv)
				if status ~= nil and status == 2 then
					return true
				end
			end
			return false
		end
	end
	return false
end
function give_chargeable_pda(first_speaker, second_speaker)
	second_speaker:iterate_inventory(function(_, obj)
			if obj:section()=="device_pda_npc" then
				misc.release_obj(obj)
			end
		end)
	for _,v in ipairs(sak_inventory.eatable["device_pda_npc"]) do
		local status = vergas_pda.get_pda_status(v)
		if status ~= nil and status == 2 then
			local pda = client_obj(v)
			if pda then
				db.actor:transfer_item(pda, second_speaker)
				sak.relocate_item("out", "device_pda_npc", 1)
				vergas_pda.charge_pda(v)
				return
			end
		end
	end
end
function take_charged_pda(first_speaker, second_speaker)
	local obj = first_speaker:object("device_pda_npc")
	if obj then
		vergas_pda.set_pda_cond(obj:id())
		first_speaker:transfer_item(obj, second_speaker)
		sak.relocate_item("in", "device_pda_npc", 1)
	end
end
function take_bino(first_speaker, second_speaker)
	first_speaker:transfer_item(first_speaker:object("wpn_binoc"), second_speaker)
	sak.relocate_item("in", "wpn_binoc", 1)
end
