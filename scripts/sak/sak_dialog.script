function rygyi_med_ok()
	local obj = g_sim:story_object(story_ids.rygyi)
	if obj then
		if obj:alive() then
			local pk = get_netpk(obj)
			local data = pk:get()
			data.health     = 0.9
			data.upd.health = 0.9
			pk:set(data)
			local sobj=alife():object(obj.id)
			sobj.wounded=false
		else
			misc.release_by_name("rygyi")
			actor:give_info_portion("rygyi_umer")
		end
	end
end

