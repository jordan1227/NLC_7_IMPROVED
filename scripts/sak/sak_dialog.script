function esc_petruha_bm_have()
	local bm_id = get_value("petruha_dsc_bm")
	if bm_id ~= nil then
		local bm = g_sim:object(bm_id)
		if bm and bm.section_name and bm:section_name() == "wpn_bm16_full" and bm.parent_id and bm.parent_id == 0 then
			return true
		end
	end
	return false
end
function give_esc_petruha_bm(first_speaker, second_speaker)
	-- dialogs.relocate_item_section(second_speaker, "wpn_bm16_full", "out")
	local bm_id = get_value("petruha_dsc_bm")
	local obj = g_sim:object(bm_id)
	if obj then
		local c_obj = client_obj(obj.id)
		db.actor:transfer_item(c_obj, second_speaker)
		sak.relocate_item("out", "wpn_bm16_full", 1)
		remove_value("petruha_dsc_bm")
		second_speaker:set_relation(game_object.friend, first_speaker)
	end
end
