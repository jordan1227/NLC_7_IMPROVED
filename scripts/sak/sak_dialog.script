function pahom_det_charge_next_pay()
	local val = dsh.get_next_random("pahom_det_charge_request", 1, 3)
	set_value("pahom_det_charge_num",val)
end

function pahom_det_charge_pay_prec(check_flag,release_flag)
	local m_tbl = {"mutant_hand_kontroler", "mutant_e_chimera_kidney", "mutant_psevdogigant_hand"}
	local r = get_value("pahom_det_charge_num",2)
	if check_flag and type(check_flag) == "boolean" then
		return sak.have_items_count(m_tbl[r],1)
	elseif release_flag and type(release_flag) == "boolean" then
		sak_inventory.release_actor_items(m_tbl[r],1)
	else
		return translate(g_inv_name(m_tbl[r]))
	end
end

function pahom_det_charge_pay_info()
	return pahom_det_charge_pay_prec()
end

function pahom_has_det_art_cond(release_flag)
	local items = get_shadow_inv():get_content(true)
	for k,v in items:ipairs() do
		if v.sect == "detector_art_upgr" and v.obj and v.obj:condition() <= 0.95 then
			if release_flag and type(release_flag) == "boolean" then
				sak.relocate_item("out", v.sect, 1)
				misc.release_obj(v.obj)
			end
			return true
		end
	end
	return false
end

function pahom_det_art_timer_start()
	timers.start_timer("pahom_check_det_art_cond",0,0,10,"sak_dialog.pahom_det_art_timer_end()")
	set_value("pahom_det_art_timer", 1)
end

function pahom_det_art_timer_end()
	set_value("pahom_det_art_timer_end", 1)
end

function check_pahom_det_art_not_ready()
	return not value_exist("pahom_det_art_timer_end")
end

function spawn_nazar_ruck()
	local points = {
		{5,"mutant_zombie_hand",-39.765422821045,0.0088726580142975,-280.27038574219,345005,4012}, -- дача
		{5,"mutant_boar_leg",478.5770,8.8275,-283.8040,1019406,4157}, -- заправка
		{5,"mutant_flesh_eye",-261.11428833008,-1.6708285808563,-236.25967407227,123313,3964} -- плоти на юге
	}
	for i, v in ipairs(points) do
		local sobj=g_sim:create("inventory_box_ruck",sak.v3f(v[3],v[4],v[5]),v[6],v[7])
		sobj=server_obj(sobj.id)
		sobj:set_name("nazar_box"..i)
		for i=1,v[1] do g_sim:create(v[2],sobj.position,sobj.m_level_vertex_id,sobj.m_game_vertex_id,sobj.id) end
		level.map_add_object_spot_ser(sobj.id,"crlc_big_treasure3","nazar_treasure")
		sak.obj_off_on(sobj)
	end
	sak_spawn.nazar_mobs_spawn()
end

function remove_nazar_rucks()
	release("nazar_box1")
	release("nazar_box2")
	release("nazar_box3")
end

function torch_upgr_speaking_kuzn(first_speaker, second_speaker)
	local npc = who_is_npc(first_speaker, second_speaker)
	return npc:name() == 'esc_bridge_soldier5'
end

function torch_upgr_speaking_sherst(first_speaker, second_speaker)
	local npc = who_is_npc(first_speaker, second_speaker)
	return npc:name() == 'sak_military_stalker'
end

function torch_upgr_second_dlg_prec(first_speaker, second_speaker)
	local smart_name = get_value("mil_torch_upgr_smart")
	if smart_name and smart_name == 'esc_small_home1' then
		return torch_upgr_speaking_kuzn(first_speaker, second_speaker)
	elseif smart_name and smart_name == 'agr_boar_nest_2' then
		return torch_upgr_speaking_sherst(first_speaker, second_speaker)
	else
		return false
	end
end

function mil_torch_upgr_mark_smart(first_speaker, second_speaker)
	local smart
	if torch_upgr_speaking_kuzn(first_speaker, second_speaker) then
		smart = server_obj("esc_small_home1")
	elseif torch_upgr_speaking_sherst(first_speaker, second_speaker) then
		smart = server_obj("agr_boar_nest_2")
	end
	if smart then
		local g = xr_gulag.get_gulag_by_name(smart:name())
		if g then
			local tab = g.npc_info
			if tab then
				for _,v in pairs(tab) do
					local obj = server_obj(v.name)
					if obj and not obj.online then
						misc.force_online(obj.id)
					end
				end
			end
		end
		set_value("mil_torch_upgr_smart",smart:name())
		level.map_add_object_spot_ser(smart.id,"eliminate_lager_location","")
	end
end

function mil_torch_upgr_timer()
	timers.start_timer("mil_torch_upgr_timer",0,0,59,"sak_dialog.mil_torch_upgr_timer_end()")
end

function mil_torch_upgr_timer_end()
	set_value("mil_torch_upgr_timer_end",true)
end

function mil_torch_upgr_timer_end_yes_prec()
	local v = get_value("mil_torch_upgr_timer_end")
	return v ~= nil and v == true
end

function mil_torch_upgr_timer_end_no_prec()
	return not mil_torch_upgr_timer_end_yes_prec()
end

function mil_torch_upgr_smart_empty()
	local smart = get_value("mil_torch_upgr_smart")
	if smart then
		local g = xr_gulag.get_gulag_by_name(smart)
		if g:get_population_comed() == 0 then
			return true
		else
			return false
		end
	end
	return false
end

function mil_torch_upgr_outfits(num)
	local count = 0
	while count < num do
		local outfit = misc.spawn_to("outfit_soldier_m1",db.actor)
		if outfit then
			level.client_spawn_manager():add(
			outfit.id, -1,
			function( id, outfit )
				outfit:set_condition( lua_random(75,90) * 0.01 )
			end
			)
		end
		count = count + 1
	end
	sak.relocate_item("in", "outfit_soldier_m1", count)
	local smart_name = get_value("mil_torch_upgr_smart")
	if smart_name then
		local smart = server_obj(smart_name)
		if smart then
			level.map_remove_object_spot(smart.id,"eliminate_lager_location")
		end
	end
	remove_value("mil_torch_upgr_timer_end")
	remove_value("mil_torch_upgr_smart")
end

local sakharov_receipt = "info_amk_recipt_souls_bengal"
function sakharov_receipt_set(r)
	if r and type(r) == 'string' then
		sakharov_receipt = r
	end
end

function sakharov_receipt_give()
	if not has_alife_info(sakharov_receipt) then
		db.actor:give_info_portion(sakharov_receipt)
		if strpos(sakharov_receipt,"info_amk") then
			sak.info_amk_received()
		else
			sak.info_artmod()
		end
	end
end

function lim_rashpil_quest_prec_yes()
	return not lim_rashpil_quest_prec_no()
end

function lim_rashpil_quest_prec_no()
	return has_alife_info("val_borov_dead") and has_alife_info("red_scaut_pass_fire")
end

function lim_rashpil_quest_bonus_prec_yes()
	local v = get_value("rashpil_bonus_rew",false)
	return v == true
end

function lim_rashpil_quest_bonus_prec_no()
	return not lim_rashpil_quest_bonus_prec_yes() 
end

function borzyi_rashpil_exo_prec_yes()
	return has_alife_info("val_borov_dead") or has_alife_info("borzyi_borov_quest_reward_info")
end

function borzyi_rashpil_exo_prec_no()
	return not borzyi_rashpil_exo_prec_yes()
end

function borzyi_rashpil_spawn_exo(cond)
	if cond and type(cond) == 'number' then
		local obj = misc.spawn_to("exo_bandit_outfit", db.actor)
		if obj then
			params.post_cond_check(obj.id, cond / 100)
			sak.relocate_item("in", "exo_bandit_outfit", 1)
		end
	end
end

function mil_rashpil_exo_timer()
	timers.start_timer("mil_rashpil_exo_timer",0,0,59,"sak_dialog.mil_rashpil_exo_timer_end()")
end

function mil_rashpil_exo_timer_end()
	db.actor:give_info_portion("mil_rashpil_exo_timer_info")
end

function borov_rashpil_exo_prec_yes()
	return jila_abuse_prec_no() and bandit_pda_trading() and harmonica_cracked_no() and has_alife_info("borov_harmonica_start") and has_alife_info("borov_harmonica_done") 
		and has_alife_info("new_borov_kill_stalker_start") and has_alife_info("new_borov_kill_stalker_done") and not has_alife_info("atp_bandits_open_fire")
end
function borov_rashpil_exo_prec_no()
	return not borov_rashpil_exo_prec_yes()
end
function bar_need_room_prec_yes() 
	local r = db.actor:character_rank()
	return r >= 300
end
function bar_need_room_prec_no()
	return not bar_need_room_prec_yes()
end
function dolgovazyi_exo_quest_start_prec()
	local a = actor_active_item(6)
	if a then
		local sec = a:section()
		if strpos(sec,"exo") and not strpos(sec,"broken") and not strpos(sec,"outfit_m1") then
			return true
		end
	end
	return false
end
function dolgovazyi_exo_quest_exp_prec_yes()
	local cur_exp = actor_stats.get_points("repair_exp") or 0
	return cur_exp >= 30.0
end
function dolgovazyi_exo_quest_exp_prec_no()
	return not dolgovazyi_exo_quest_exp_prec_yes()
end
function dolgovazyi_exo_quest_check(rel_flag)
	local rel = type(rel_flag) == 'boolean' and rel_flag == true
	for k,v in pairs(sak_inventory.rucksack) do
		if strpos(k,"exo") and not strpos(k,"broken") and not strpos(k,"outfit_m1") then
			local exo = client_obj(v[1])
			if exo and exo:condition() >= 0.99 then
				if rel then
					sak.relocate_item("out", k, 1)
					misc.release_obj(v[1])
				end
				return true
			end
		end
	end
	return false
end
function dolgovazyi_exo_quest_final()
	level.disable_input()
	level.add_pp_effector("teleport.ppe", 1111, true)
	level.set_time_factor(10000)
	schedule.add("dolgovazyi_exo_quest_idle","sak_dialog.dolgovazyi_exo_quest_end()",3000)
end
function dolgovazyi_exo_quest_end()
	level.remove_pp_effector(1111)
	level.enable_input()
	level.set_time_factor(system_ini():r_float("alife","time_factor"))
	set_value("exo_self_rep",true)
end