blowout_when = ""

function do_blow_time()
	local when = ""
	if (get_value("blowout", -1) > -1 and get_value("blowout", -1) < 5) then return end
	local name, delay = timers.check_timer("blow_shift","amk_mod.Run_Blowout_pp()")
	local diff =(delay) / 60
	if (diff < 1) then
		when = "do_blow_time_1"
	elseif (diff < 2) then
		when = "sgtat_gen_text_1739218038_1059"
	elseif (diff >= 2 and diff <=4) then
		when = "sgtat_gen_text_1739218038_1065"
	elseif (diff > 4 and diff <=8) then
		when = "sgtat_gen_text_1739218038_1081"
	elseif (diff > 8) then
		local m_h = level:get_time_hours()
		local n_h = m_h + diff
		if (n_h >= 9 and n_h < 11) then when = "sgtat_gen_text_1739218038_1052" end
		if (n_h >= 11 and n_h < 14) then when = "sgtat_gen_text_1739218038_1090" end
		if (n_h >= 14 and n_h < 18) then when = "sgtat_gen_text_1739218038_1085" end
		if (n_h >= 18 and n_h < 22) then when = "sgtat_gen_text_1739218038_1051" end
		if (n_h >= 22 and n_h < 30) then when = "sgtat_gen_text_1739218038_1089" end
		if (n_h >= 30 and n_h < 34) then when = "sgtat_gen_text_1739218038_1068" end
		if (n_h >= 34 and n_h < 38) then when = "sgtat_gen_text_1739218038_1074" end
		if (n_h >= 38 and n_h < 42) then when = "sgtat_gen_text_1739218038_1056" end
		if (n_h >= 42 and n_h < 50) then when = "sgtat_gen_text_1739218038_1060" end
		if (n_h >= 50) then when = "do_blow_time_2" end
	end
	blowout_when = game.translate_string(when)
end
function select_blowout_dialog(name)
	local lines = sak_dialog[name]
	local m = lua_random(#lines)
	return lines[m]
end
function sidor_blowout_dialog_end()
	do_blow_time()
	local m_end = select_blowout_dialog("sidor_blowout_dialog")
	return text_talk_dialog(m_end)
end
function docent_blowout_dialog_end()
	do_blow_time()
	local m_end = select_blowout_dialog("docent_blowout_dialog")
	return text_talk_dialog(m_end)
end
function saharov_blowout_dialog_end()
	do_blow_time()
	local m_end = select_blowout_dialog("saharov_blowout_dialog")
	return text_talk_dialog(m_end)
end

