function add_treas_tbl(lvl,id)
	local tbl = get_value("treas_tbl_to_remove",{})
	if not tbl[lvl] then 
		tbl[lvl] = {}
	end
	table.insert(tbl[lvl],id)
	set_value("treas_tbl_to_remove", tbl)
end
function remove_treas_tbl(lvl)
	local tbl = get_value("treas_tbl_to_remove",{})
	if not tbl[lvl] then
		-- log2("remove_treas_tbl: no tbl for lvl %s",lvl)
		return
	else
		local l = #tbl[lvl]
		for i=l,1,-1 do
			local obj = g_sim:object(tbl[lvl][i])
			if obj and obj:section_name() == "rukzak_inventory_box" and level.map_has_object_spot(obj.id,"crlc_big_treasure0") == 0 then
				-- log2("remove_treas_tbl: all conds confirmed --> releasing obj")
				misc.release_obj(obj.id)
				table.remove(tbl[lvl],i)
			else
				-- log2("remove_treas_tbl: no obj confirmed!!")
			end
		end
		set_value("treas_tbl_to_remove", tbl)
	end
end
