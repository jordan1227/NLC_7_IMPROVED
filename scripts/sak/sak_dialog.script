is_in_trade_zone = false
function in_trade_zone()
	return is_in_trade_zone
end
function in_all_money()
	local summ_old=db.actor:money()
	local summ=get_value("actor_many", 0)
	-- sak.send_tip(tostring(-summ_old),"IN",0,15,"g_g","sak","yellow")
	db.actor:give_money(summ-summ_old)
	remove_value("actor_many")
	is_in_trade_zone = false
end
function out_all_money()
	local summ=db.actor:money()
	-- sak.send_tip(tostring(summ),"OUT",0,15,"g_g","sak","yellow")
	set_value("actor_many", summ)
	db.actor:give_money(-summ)
	is_in_trade_zone = true
end
function in_saharov_money()
	local summ=get_value("saharov_many", 0)
	db.actor:give_money(summ)
	sak.flag_sah=true
end
function out_saharov_money()
	local summ=db.actor:money()
	set_value("saharov_many", summ)
	sak.flag_sah=false
end
function neum_out_all_money(npc, actor)
	local summ=npc:money()
	dialogs.relocate_money(actor, summ, "out")
	local obj=npc:object("lot_many")
	if obj then
		sak_inventory.release_actor_items("lot_many",1)
	end
end
