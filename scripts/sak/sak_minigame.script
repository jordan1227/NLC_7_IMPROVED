function sultan_weapon(tip)
  -- local x = weapons_icons[tip][1]
  -- local y = weapons_icons[tip][2]
  db.actor:give_talk_message("%c[255,216,186,140]"..game.translate_string(amk.get_inv_name(sultan_weapons[tip][1])), "ui\\ui_iconsTotal",Frect():set(0,0,0,0),"simple_answer_center")
  -- db.actor:give_talk_message("", "ui\\ui_unique_weapon",Frect():set(x,y,350,150),"iconed_weapon_item")
  local icon = dsh.get_talk_item_icon(sultan_weapons[tip][1])
  db.actor:give_talk_message("",icon[1],icon[2],icon[3])
  db.actor:give_talk_message("%c[255,216,186,140]"..game.translate_string(get_inv_name_dial_desc(sultan_weapons[tip][1])), "ui\\ui_iconsTotal",Frect():set(0,0,0,0),"simple_answer_item")
end
function save_sultan_weapon(tip)
  set_value("sultan_weapon", tip)
end
function get_inv_name_dial_desc(section)
  local calibr, addons = {}, {}
  for k, v in ipairs(string.explode(",", get_string(section, "ammo_class", ""), true)) do
    table.insert(calibr, game.translate_string(amk.get_inv_name(v)))
  end
  if get_u32(section, "scope_status", 0) == 2 then
    for k, v in ipairs(
      string.explode(",", get_string(section, "scope_names", get_string(section, "scope_name", "")), true)
    ) do
      table.insert(addons, game.translate_string(amk.get_inv_name(v)))
    end
  elseif get_u32(section, "scope_status", 0) == 1 then
    local text = game.translate_string("ui_inv_integrated_sight")
    local s = get_float(section, "scope_lense_fov_factor", get_float(section, "scope_zoom_factor", 0))
    s = device().fov / (s * 0.75)
    if s > 1 then
      text = string.format("%s x%.1f-%s", game.translate_string("ui_inv_integrated"), s, game.translate_string("ui_inv_multiple_sight"))
    end
    table.insert(addons, text)
  end
  if get_u32(section, "silencer_status", 0) == 2 then
    table.insert(addons, game.translate_string(amk.get_inv_name(get_string(section, "silencer_name", ""))))
  elseif get_u32(section, "silencer_status", 0) == 1 then
    table.insert(addons, game.translate_string("ui_inv_integrated_silencer"))
  end
  if get_u32(section, "grenade_launcher_status", 0) == 2 then
    table.insert(addons, game.translate_string(amk.get_inv_name(get_string(section, "grenade_launcher_name", ""))))
  elseif get_u32(section, "grenade_launcher_status", 0) == 1 then
    table.insert(addons, game.translate_string("ui_inv_integrated_grenade_launcher"))
  end
  if #addons == 0 then
    table.insert(addons, "---")
  end
  return game.translate_string(get_string(section, "description", ""))..
    "\\n"..game.translate_string("Ammo")..": "..table.concat(calibr, ", ")..
    "\\n"..game.translate_string("ui_inv_sheds")..": "..table.concat(addons, ", ").."\\n"
  --  if system_ini():line_exist(section, "dialog_description") then
  --   return system_ini():r_string(section,"dialog_description")
  --  else
  --     return sprintf("#ERROR: not assigned %s.dialog_description", section)
  --  end
end

function need_sultan_weapon_art_1()
  local tip=get_value("sultan_weapon", 0)
  if tip==2 or tip==3 or tip==4 or tip==5 or tip==9 or tip==10 or tip==13  then return true end
end
function need_sultan_weapon_art_2()
  local tip=get_value("sultan_weapon", 0)
  if tip==2 or tip==3 or tip==4 or tip==5 or tip==6 or tip==8 or tip==9 or tip==10 or tip==11 or tip==13 or tip==14 or tip==17  then return true end
end
function need_sultan_weapon_art_3()
  local tip=get_value("sultan_weapon", 0)
  if tip~=12 and tip~=15 and tip~=16 and tip~=0 then return true end
end
function need_sultan_weapon_art_4()
  local tip=get_value("sultan_weapon", 0)
  if tip~=0 then return true end
end
function load_sultan_weapon_treasure()
	local tip=get_value("sultan_weapon", 0)
	local rand_treasure = dsh.get_next_random( "sultan_weapon_treasure", 1, 3 )
	local npc=db.actor
	local obj = alife():story_object(sultan_treasure[rand_treasure*2-1])
	if tip~=0 and obj then
		for k,v in pairs(sultan_weapons[tip]) do
			misc.spawn_to(v, obj)
		end 
    level.map_add_object_spot_ser(obj.id,"crlc_big_treasure0","?")
		npc:give_talk_message("%c[255,216,186,140]"..game.translate_string("sakm.sultan_treasure_"..sultan_treasure[rand_treasure*2]),"ui\\ui_iconsTotal",Frect():set(0,0,0,0),"simple_answer_item")
		npc:give_info_portion("way_sultan_treasure_"..rand_treasure)
		remove_value("sultan_weapon")
		npc:disable_info_portion("sultan_weapon_starting")
	end
end
--[[Покер с игральными костями

Для этой игры необходимо иметь пять покерных игральных костей. 
Цель игры: составить наиболее выгодную покерную комбинацию из пяти игральных костей.
Количество игроков может быть любым, но лучше всего, если число играющих не будет превышать пяти.
Каждый игрок кидает одну игральную кость, чтобы определить очередность ходов. Начинает тот у кого выпала старшая карта(Например, если выпадает Туз, то игрок у которого он выпал начинает игру)
Каждый игрок кидает все пять игральных костей, после чего он может заявить, что доволен результатами или перекинуть любое количество костей(от одной до пяти). После второго броска у него снова есть выбор - принять полученную комбинацию или снова перекинуть кости, причем он не имеет права трогать те кости, которые остались нетронутыми после первого сбрасывания. Таким образом, у каждого игрока есть три попытки собрать наиболее выгодную комбинацию. После третьего сбрасывания вне зависимости от результата ход переходит к игроку сидящему слева. В конце круга, когда все игроки сделали свои ходы, выигрывает тот у кого окажется высшая комбинация.
Возможны следующие комбинации(в порядке убывания):
1. Покер - пять костей одного вида(например, пять Королей или пять Девяток)
2. Каре - четыре кости одного вида(например, четыре Десятки)
3. Фулл хаус - три кости одного вида + пара(например, три Дамы и два Валета)
4. Тройка - три кости одного вида(например, три Туза)
5. Две пары - две кости одного вида и две кости другого вида(например, две Девятки и две Десятки)
6. Пара - две кости одного вида(например, два Короля)
7. Наивысшее очко - в случае, если ни у кого не выпало покерной комбинации выигрывает игрок с наивысшей суммой очков среди пяти несовмещающихся в комбинацию баллов, выпавших на игральных костях.
Если комбинации двух игроков одинаковы(например, у двух игроков по Каре), то выигрывает тот у кого выше очки, выпавшие на костях(например, если у одного игрока Каре Десяток, а у второго Каре Дам, то выиграл второй). Если у игроков одинаковые комбинации, то они разыгрывают партию друг с другом.
Ставки делаются перед каждой игрой. Выигравшему достается весь банк.

Другой вариант игры: правила те же, только выигрывает игрок с худшей комбинацией.]]