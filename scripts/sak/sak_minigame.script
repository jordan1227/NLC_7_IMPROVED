local npc_roll = {}
local gg_roll = {}
local vodka_lim=7
local art_lim=2

local numer = {
  "%c[255,175,2,39]"..game.translate_string("sakm.num1"),
  "%c[255,175,2,169]"..game.translate_string("sakm.num2"),
  "%c[255,65,77,235]"..game.translate_string("sakm.num3"),
  "%c[255,15,140,140]"..game.translate_string("sakm.num4"),
  "%c[255,14,175,128]"..game.translate_string("sakm.num5"),
  "%c[255,14,175,2]"..game.translate_string("sakm.num6")}

function generate_dices_drop()
	dsh.get_next_random( "dices_stas_gg_vodka", 1, 6 )
	dsh.get_next_random( "dices_stas_gg_money", 1, 6 )
	dsh.get_next_random( "dices_stas_npc_vodka", 1, 6 )
	dsh.get_next_random( "dices_stas_npc_money", 1, 6 )
	dsh.get_next_random( "dices_mongol_gg", 1, 6 )
	dsh.get_next_random( "dices_mongol_npc", 1, 6 )
	dsh.get_next_random( "dices_lysyi_gg_art1", 1, 6 )
	dsh.get_next_random( "dices_lysyi_gg_art2", 1, 6 )
	dsh.get_next_random( "dices_lysyi_npc_art1", 1, 6 )
	dsh.get_next_random( "dices_lysyi_npc_art2", 1, 6 )
end

function roll_npc(who)
	npc_roll = {}
	if who and type(who) == 'string' then
		for i=1,3 do
			table.insert(npc_roll, dsh.get_next_random( who, 1, 6 ))
		end
		if strposx(who,"npc_art2") then
			for _,v in ipairs(npc_roll) do
				if v ~= 6 then
					v = v+1
					break
				end
			end
		end
		db.actor:give_talk_message(string.format(game.translate_string("sakm.roll_npc"),numer[npc_roll[1]],numer[npc_roll[2]],numer[npc_roll[3]]), "ui\\ui_iconsTotal",Frect():set(498,188,83,47),"iconed_answer_item")
	end
end

function roll_gg(who)
	gg_roll = {}
	if who and type(who) == 'string' then
		for i=1,3 do
			table.insert(gg_roll, dsh.get_next_random( who, 1, 6 ))
		end
		db.actor:give_talk_message(string.format(game.translate_string("sakm.roll_gg"),numer[gg_roll[1]],numer[gg_roll[2]],numer[gg_roll[3]]), "ui\\ui_iconstotal", Frect():set(498,188,83,47),"iconed_answer_item")
	end
	if (npc_roll[1]+npc_roll[2]+npc_roll[3]) > (gg_roll[1]+gg_roll[2]+gg_roll[3]) then
		db.actor:give_info_portion("gg_luser")
	elseif (npc_roll[1]+npc_roll[2]+npc_roll[3]) < (gg_roll[1]+gg_roll[2]+gg_roll[3]) then
		db.actor:give_info_portion("gg_winner")
	else
		db.actor:give_info_portion("draw")
	end
end

function stas_have_vodka()
	local vodka_winned = get_value("vodka_win", 0)
	return vodka_winned<vodka_lim
end

function stas_no_have_vodka()
	return not stas_have_vodka()
end

function stas_vodka_win(num)
	if num and type(num) == 'number' then
		local vodka_winned = get_value("vodka_win", 0)
		set_value("vodka_win", vodka_winned+num)
		sak.create_items("vodka",num)
	end
end

local ochko=11
local gg_sum=0
local npc_sum=0

function new_game_ochko()
	gg_sum=0
	npc_sum=0
	db.actor:disable_info_portion("gg_winner")
	db.actor:disable_info_portion("gg_luser")
	db.actor:disable_info_portion("draw")
end

function roll_ochko_gg()
	local num = dsh.get_next_random( "dices_mongol_gg", 1, 6 )
	if (num+gg_sum)==ochko then
		db.actor:give_talk_message(string.format(game.translate_string("sakm.roll_ochko_gg_1"),numer[num],game.translate_string("sakm.summ_dises"..gg_sum)), "ui\\ui_iconsTotal",Frect():set(498,188,83,47),"iconed_answer_item")
		db.actor:give_info_portion("gg_winner")
	elseif (num+gg_sum)>ochko then
		db.actor:give_talk_message(string.format(game.translate_string("sakm.roll_ochko_gg_2"),numer[num],game.translate_string("sakm.summ_dises"..gg_sum)), "ui\\ui_iconsTotal",Frect():set(498,188,83,47),"iconed_answer_item")
		db.actor:give_info_portion("gg_luser")
	elseif (num+gg_sum)<ochko then
		if gg_sum~=0 then
			db.actor:give_talk_message(string.format(game.translate_string("sakm.roll_ochko_gg_3"),numer[num],game.translate_string("sakm.summ_dises"..gg_sum),game.translate_string("sakm.summ_dises"..gg_sum+num)), "ui\\ui_iconsTotal",Frect():set(498,188,83,47),"iconed_answer_item")
			gg_sum=(num+gg_sum)
		else 
			db.actor:give_talk_message(string.format(game.translate_string("sakm.roll_ochko_gg_4"),numer[num]), "ui\\ui_iconsTotal",Frect():set(498,188,83,47),"iconed_answer_item")
			gg_sum=(num+gg_sum)
		end
	end
end

function roll_ochko_npc()
	local num = dsh.get_next_random( "dices_mongol_npc", 1, 6 )
	if npc_sum > 8 and num ~= 1 then
		num = num - 1
	end
	if (num+npc_sum)==ochko then
		db.actor:give_talk_message(string.format(game.translate_string("sakm.roll_ochko_npc_1"),numer[num],game.translate_string("sakm.summ_dises"..npc_sum)), "ui\\ui_iconsTotal",Frect():set(498,188,83,47),"iconed_answer_item")
		db.actor:give_info_portion("gg_luser")
	elseif (num+npc_sum)>ochko then
		db.actor:give_talk_message(string.format(game.translate_string("sakm.roll_ochko_npc_2"),numer[num],game.translate_string("sakm.summ_dises"..npc_sum)), "ui\\ui_iconsTotal",Frect():set(498,188,83,47),"iconed_answer_item")
		db.actor:give_info_portion("gg_winner")
	elseif (num+npc_sum)<gg_sum then
		if npc_sum~=0 then
			db.actor:give_talk_message(string.format(game.translate_string("sakm.roll_ochko_npc_3"),numer[num],game.translate_string("sakm.summ_dises"..npc_sum),game.translate_string("sakm.summ_dises"..npc_sum+num)), "ui\\ui_iconsTotal",Frect():set(498,188,83,47),"iconed_answer_item")
			npc_sum=(num+npc_sum)
		else
			db.actor:give_talk_message(string.format(game.translate_string("sakm.roll_ochko_npc_4"),numer[num]), "ui\\ui_iconsTotal",Frect():set(498,188,83,47),"iconed_answer_item")
			npc_sum=(num+npc_sum)
		end
	elseif (num+npc_sum)==gg_sum then
		if npc_sum~=0 then
			db.actor:give_talk_message(string.format(game.translate_string("sakm.roll_ochko_npc_5"),numer[num],game.translate_string("sakm.summ_dises"..npc_sum),game.translate_string("sakm.summ_dises"..npc_sum+num)), "ui\\ui_iconsTotal",Frect():set(498,188,83,47),"iconed_answer_item")
			npc_sum=(num+npc_sum)
		else
			db.actor:give_talk_message(string.format(game.translate_string("sakm.roll_ochko_npc_6"),numer[num]), "ui\\ui_iconsTotal",Frect():set(498,188,83,47),"iconed_answer_item")
			npc_sum=(num+npc_sum)
		end
		db.actor:give_info_portion("draw")
	elseif (num+npc_sum)>gg_sum and(num+npc_sum)<ochko then
		if npc_sum~=0 then
			db.actor:give_talk_message(string.format(game.translate_string("sakm.roll_ochko_npc_7"),numer[num],game.translate_string("sakm.summ_dises"..npc_sum),game.translate_string("sakm.summ_dises"..npc_sum+num)), "ui\\ui_iconsTotal",Frect():set(498,188,83,47),"iconed_answer_item")
			npc_sum=(num+npc_sum)
		else
			db.actor:give_talk_message(string.format(game.translate_string("sakm.roll_ochko_npc_8"),numer[num]), "ui\\ui_iconsTotal",Frect():set(498,188,83,47),"iconed_answer_item")
			npc_sum=(num+npc_sum)
		end
		db.actor:give_info_portion("gg_luser")
	end
end

function take_aart()
	local c=dsh.get_next_random( "amk_anoms.spawn_rand_arts", 1, 7 )
	local d=dsh.get_next_random( "amk_anoms.spawn_rand_arts", 1, 3 )
	local item=sak_dialog.table_aart[c]
	sak.create_items(item.."_dyn"..d.."d",1)
	art_wins_lysyi()
end

function take_bart()
	local c=dsh.get_next_random( "amk_anoms.spawn_rand_arts", 1, 7 )
	local d=dsh.get_next_random( "amk_anoms.spawn_rand_arts", 1, 3 )
	local item=sak_dialog.table_bart[c]
	sak.create_items(item.."_dyn"..d.."d",1)
	art_wins_lysyi()
end

function lysyi_have_art()
	local art_winned = get_value("art_win", 0)
	return art_winned<art_lim
end

function lysyi_no_have_art()
	return not lysyi_have_art()
end

function art_wins_lysyi()
	local art_winned = get_value("art_win", 0)
	set_value("art_win", art_winned+1)
end

