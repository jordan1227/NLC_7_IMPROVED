-------------------- Обмен артов у Круглова
local cur_art = nil
local first_trade_done = false
local good_art = nil
function art_exchange_prec_yes()
	local count = get_value("art_exchange_count", 0)
	return count < 3
end

function art_exchange_prec_no()
	return not art_exchange_prec_yes()
end

function art_exchange_1trade()
	return not first_trade_done
end

function art_exchange_2trade()
	return first_trade_done
end

function art_exchange_good_art_prec()
	local res = false
	for _,v in ipairs(sak_dialog.table_bart) do
		if res then
			break
		end
		for i=3,5 do
			local sec = v.."_dyn"..i.."d"
			res = sak_dialog.cond_items_have(sec,1,0.95)
			if res then
				good_art = sec
				break
			end
		end
	end
	return res
end

function art_exchange_good_art_give()
	if good_art ~= nil then
		sak_dialog.cond_items_have(good_art,1,0.95,true)
		good_art = nil
	end
end

function art_exchange_rnd_arts()
	for i=1,3 do
		local r = dsh.get_next_random( "kruglov_art_exchange", 1, 7 )
		local art = sak_dialog.table_aart[r]
		art = art.."_dyn"..lua_random(1,3).."d"
		sak.create_items(art,1)
	end
	local count = get_value("art_exchange_count", 0)
	set_value("art_exchange_count", count + 1)
end

function art_exchange_set_art(n)
	if n and type(n) == 'number' then
		cur_art = sak_dialog.table_aart[n]
	end
end

function art_exchange_give_art(final_flag)
	if cur_art ~= nil then
		cur_art = cur_art.."_dyn"..lua_random(1,4).."d"
		sak.create_items(cur_art,1)
		cur_art = nil
	end
	if type(final_flag) == 'boolean' then
		if final_flag == true then
			local count = get_value("art_exchange_count", 0)
			set_value("art_exchange_count", count + 1)
			first_trade_done = false
		else
			first_trade_done = true
		end
	end
end

------------------- Обмен канистр на Кордоне
local add_nagrad_kanistra_esc_nagrad = 0		-- здесь храним, какую награду выбрал ГГ за канистру на Кордоне
function add_nagrad_kanistra_esc1(nagrad_item)		-- запоминаем, какую награду выбрал ГГ за канистру на Кордоне
	add_nagrad_kanistra_esc_nagrad = nagrad_item
end
function add_nagrad_kanistra_esc2()			-- награждение за канистру на Кордоне
	local items = nagrad.level_1[add_nagrad_kanistra_esc_nagrad*2-1]
	local count = nagrad.level_1[add_nagrad_kanistra_esc_nagrad*2]
	sak.create_items(items,count)			-- даем награду
	sak_dialog.take_2000_money()				-- даем деньги
	sak_inventory.release_actor_items("amk_kanistra",1)	-- забираем канистру
	timers.start_timer("timer_kanistra_esc",1,0,0,"sak_rand_nagrad.timer_kanistra_esc_end()")	-- запускаем таймер на 24 часа
	db.actor:give_info_portion("kanistra_esc_not_over")	-- включаем инфопоршень, что канистр больше не надо (выключится по таймеру)
	db.actor:disable_info_portion("esc_no_charge")
end
function timer_kanistra_esc_end()
	sak.send_tip("Сталкеры, у нас на Кордоне закончился бензин. Если есть желание заработать, несите канистры, поменяем на патроны, медикаменты, еду, Водку...","Новости Кордона",11,20,"g_g","sak","green")
	db.actor:disable_info_portion("kanistra_esc_not_over")	-- выключаем инфопоршень, теперь канистры можно менять.
end

------------------- Обмен канистр в Баре
