-------------------- Обмен модификатов у Сидоровича
function have_any_cond_modart()
	for i=1,4 do
		if sak_dialog.cond_items_have("m"..i,1) then
			return true
		end
	end
end
function save_modart_order(order)	-- Запоминаем заказ и время
	set_value("modart_order", order)
	set_value("modart_order_time", game.get_game_time():diffSec(game.CTime()))
end
function modart_order_give()			-- Награждаем ГГ из таблицы sidr_nagrad[]
	local order = get_value("modart_order")*2-1
	local order_item = sidr_nagrad[order]
	local order_count = sidr_nagrad[order+1]
	sak.create_items(order_item,order_count)
end
function modart_order_time_yes()			-- Проверяем прошли ли 24 часа, можно ли получать товар
	if get_value("modart_order_time") == nil then	-- Если переменная с временем заказа не проинициализированна (ГГ не делал заказ у Сидора), то товар получить нельзя
		return false
	end

	if game.get_game_time():diffSec(game.CTime()) - get_value("modart_order_time") > 24*60*60 then
		return true				-- 24 часа прошли, товар получить можно
	end
	return false
end
function modart_order_time_no()
	return not modart_order_time_yes()
end

