local flag_use_gadget = true 			-- true - можно использовать
local sleep_timer						-- если не равен 0, значит таймер запущен на сон

function set_get_flag_use_gadget(mode, param)
  if param ~= nil then
     set_use_gadget(param)
  end
  return flag_use_gadget
end

function set_use_gadget(flag)
  if flag_use_gadget ~= flag then
     --wprintf(" flag_use_gadget updated to~C0F %s~C07 from:\n~C0A %s~C07", DumpVar(flag), lua_traceback(' '))
     flag_use_gadget = flag
  end
end

function can_use_gadget()
  return flag_use_gadget
end


function used_podsumok_razgruzka(section)
	local inv = db.actor:object("shadow_inventory")
	if not inv then
		razgruzka.no_shadow_inv_mtv_upd()
	end
	local spwn
	open_inv_raz_pod = false
	if section == "podsumok" then
		spwn=ui_cheat_podsumok.pouch_dialog(get_hud())
	elseif section == "razgruzka" then
		spwn=ui_cheat_razgruzka.mtv_dialog(get_hud())
	elseif section == "razgruzka_new" then
		spwn=ui_cheat_razgruzka_new.mtv_dialog(get_hud())
	end
	flag_use_gadget = false
	level.start_stop_menu(spwn,true)
end

function used_notebook_of_artist()
  local wnd = level.main_input_receiver()
  level.start_stop_menu(wnd, false)
  flag_use_gadget = false
  schedule.add("us_klava", "used_items.made_used_notebook_of_artist()", 1000)
end
function made_used_notebook_of_artist()
  bind_stalker.hide_weapon()
  local spwn=ui_cheat_notebook.cheat(get_hud())
  level.start_stop_menu(spwn,true)
end

