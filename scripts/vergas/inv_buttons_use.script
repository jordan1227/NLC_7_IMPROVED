function transfer_ammo(id)
	if id == 0 or id == nil then
		return
	end

	local cobj = client_obj(id)
	if cobj then
		set_item_inv_hidden(cobj)
		db.actor:invalidate_inventory()
	end
end

function take_ammo(obj)
	--патроны могут попасть в открытый инвентарь только если разрядить ствол
	if string.sub(obj:section(),1,4) ~= "ammo" then
		return
	end

	if rucksack_mode == 1 or rucksack_mode == 3 then
		transfer_ammo(obj:id())
	end
end