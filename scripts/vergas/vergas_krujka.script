function talk_to_vergas()					--флаг разрешения на разговор с Вергасом
	local flag = set_krujka_id()
	if flag == true then
		return true
	else
		return false
	end
end

function processing_custom(n)
	local tbl_custom = get_tbl_custom()
	return tbl_custom[n]
end

