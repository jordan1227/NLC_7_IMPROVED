local str_data
local complexity
local krujka_inv
local krujka_id
local sec_prize		--секция приза, от которого отказывается ГГ
local tbl_prize_no = {}	--таблица предметов от которых отказался ГГ
local txt_nomer = lua_random(1,14)			--номер последней фразы Вергаса при смене приза
local exchange_flag = false

function attach(sm)
	sm:subscribe({signal = "on_init_modules", fun = this.init_module})
end

local temp_pos = nil
function init_module()
	complexity = back_complexity()
	if get_value("k_spawned") == nil then 
		--начинаю процесс формирования кружки
		set_value("k_spawned", false)
		if lua_random(1, 100) > 30 then
			init_krujka_vergas()
			set_value("k_spawned", true)
		end
	end
	if get_value("k_spawned") == true and not has_alife_info("vergas_krujka_done") then
		local lvl = level.name()
		if lvl ~= 'hospital' then
			return
		end
		for id=1,BAD_OBJ_ID,1 do
			local obj = g_sim:object(id)
			if obj then
				local o_lvl = g_sim:level_name(game_graph():vertex(obj.m_game_vertex_id):level_id())
				local sec = obj:section_name()
				if lvl == o_lvl and strpos(sec,"krujka_",1,true) then
					local par = obj.parent_id
					if par == nil or ( par ~= nil and par ~= BAD_OBJ_ID ) then
						return
					end
					temp_pos = { obj.position, obj.m_level_vertex_id, obj.m_game_vertex_id }
					-- Sn: на этом этапе клиентского объекта ещё нет, поэтому приходится ждать
					-- schedule.add ("adjust_krujka_pos", "vergas_krujka.adjust_krujka_pos("..id..")", 5000)
				end
			end
		end
	end
end

function adjust_krujka_pos(id)
	local cobj = client_obj(id)
	if cobj then
		alife():teleport_object(id, temp_pos[1], temp_pos[2], temp_pos[3])
	end
end

function init_krujka_vergas()
	local obj = spawn_krujka(lua_random(1,6))
	krujka_id = obj.id

	--определяю, а будет ли кружка настоящей
	if lua_random(1, 100)>30 then
		prize_vergas()
		local prob = tostring(lua_random(1,100))
		str_data = str_data..prob.."|"
		set_get_krujka_custom(1,krujka_id,str_data)
	else 
		re_vergas_prize()
	end
end

