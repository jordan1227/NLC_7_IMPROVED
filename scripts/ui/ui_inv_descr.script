	{prop = "satiety_restore_speed", text = translate("ui_inv_satiety"), tex = "satiety"},
	{prop = "thirst_restore_speed", text = translate("ui_inv_thirst"), tex = "thirst"},
	{prop = "power_restore_speed", text = translate("ui_inv_endurance"), tex = "power"},
	{prop = "radiation_restore_speed", text = translate("ui_inv_outfit_radiation_protection"), tex = "radiation_2", unit = translate("ui_inv_st_ki")},
