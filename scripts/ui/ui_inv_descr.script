-- Параметры еды
eatable_params = {
	{prop = "mr_time", text = translate("ui_inv_it_works"), tex = "timer"},
	{prop = "eat_health", text = translate("ui_inv_health"), tex = "health"},
	{prop = "wounds_heal_perc", text = translate("ui_inv_bleeding"), tex = "bleeding"},
	{prop = "eat_psy_health", text = translate("ui_inv_psy_health"), tex = "telepatic"},
	{prop = "eat_satiety", text = translate("ui_inv_satiety"), tex = "satiety"},
