tbl_arts = den1s_test.tbl_arts

function on_new_game()
	-- чряюыэшь эґы ьш ё ═╚ ҐрсышІґ эрщфхээ√є рЁҐют
    for _, v in ipairs({
		"st_pda_arts_found_1",
		"st_pda_arts_found_2",
		"st_pda_arts_found_3",
	}) do
        xr_statistic.add_pts( "arts", game.translate_string( v ), 0, 0 )
    end
	-- чряюыэшь эґы ьш ё ═╚ ҐрсышІґ яЁюіхщ ёҐрҐшёҐшъш
    -- for _, v in ipairs({
		-- "st_pda_otherstats_blowouts",
		-- "st_pda_otherstats_black_tip",
	-- }) do
        -- xr_statistic.add_pts( "otherstats", game.translate_string( v ), 0, 0 )
    -- end
	
end

function add_art_to_vars( id )
    if id ~= nil then
        local lname = level.name()
        local tbl   = get_value("tbl_bio_art", {})
        if tbl[ lname ] == nil then tbl[ lname ] = {} end
        table.insert( tbl[ lname ], id )
        set_value("tbl_bio_art", tbl)
    end 
end

function art_is_bio_art( id )
    local lname = level.name()
    local tbl   = get_value("tbl_bio_art", {})
    if tbl ~= nil then
        for k, v in pairs( tbl ) do
            if k == lname then
                for i = 1, #v do
                    if id == v[ i ] then
						xr_detector.del_from_tbl(id)
						-- dump_table(xr_detector.get_art_tbl())
                        v[ i ] = -1
                        set_value("tbl_bio_art", tbl)
                        return true
                    end
                end
            end
        end
    end
    return false
end

function handle_art_for_stats( sect, id )
	if art_is_bio_art( id ) then                                -- яЁшЁюфэ√щ рЁҐ, эґцэю чряюыэшҐ№ ёҐрҐшёҐшъґ
		local q_tbl = nil
		local d_flag = false
		if has_alife_info("detector_quest_start") and not has_alife_info("detector_quest_end") and not has_alife_info("detector_quest_fail") and not has_alife_info("detector_quest_refuse") then
			q_tbl = get_value("art_detect_quest_tbl",{})
			if not q_tbl["lvl1"] then
				q_tbl["lvl1"] = {}
			end
			if not q_tbl["lvl2"] then
				q_tbl["lvl2"] = {}
			end
			if not q_tbl["lvl9"] then
				q_tbl["lvl9"] = {}
			end
			local detector_record = razgruzka.active_detectors[8]
			if detector_record and strpos(detector_record,"art") then
				d_flag = true
			end
		end
		for k, v in pairs( tbl_arts ) do
			for i = 1, #v do
				if strposx( sect, v[ i ] ) then
				
					if k == "lvl1" then                         -- рЁҐ яхЁтюую ґЁютэ 
						if q_tbl ~= nil and d_flag then
							if not q_tbl["lvl1"][sect] then
								q_tbl["lvl1"][sect] = 0
							end
							local sum = q_tbl["lvl1"][sect]
							q_tbl["lvl1"][sect] = sum + 1
						end
						xr_statistic.add_pts( "arts",
                            game.translate_string( "st_pda_arts_found_1" ), 1, 0.5
						)
					elseif k == "lvl2" then                     -- рЁҐ тҐюЁюую ґЁютэ 
						if q_tbl ~= nil and d_flag then
							if not q_tbl["lvl2"][sect] then
								q_tbl["lvl2"][sect] = 0
							end
							local sum = q_tbl["lvl2"][sect]
							q_tbl["lvl2"][sect] = sum + 1
						end
						xr_statistic.add_pts( "arts",
                            game.translate_string( "st_pda_arts_found_2" ), 1, 0.5
						)
					elseif k == "lvl9" or k == "lvl10" then     -- ъряёґыр
						if q_tbl ~= nil and d_flag then
							if not q_tbl["lvl9"][sect] then
								q_tbl["lvl9"][sect] = 0
							end
							local sum = q_tbl["lvl9"][sect]
							q_tbl["lvl9"][sect] = sum + 1
						end
						xr_statistic.add_pts( "arts",
                            game.translate_string( "st_pda_arts_found_3" ), 1, 0.5
						)
					end
                end
            end
        end
		if q_tbl ~= nil then
            set_value("art_detect_quest_tbl",q_tbl)
		end
    end
end

function on_monster_kill_check_parts( obj, who )
	if who == nil then return  end -- хёыш ьґҐ ґсшыё  "юс тючфґє" - юёҐрты хь чряірёҐ№
	 -- хёыш хую ґсшы ръҐюЁ шыш іҐю ґуюфэю, ъЁюьх фЁґушє ═╧╤ - юёҐрты хь
    if ( not obj ) or ( who:id() == db.actor:id() ) or ( not IsStalker(who) ) then return end
	
	-- хёыш ¤Ґюґ эрё ътхёҐют√щ ьґҐрэҐ, ъюҐюЁюьґ юс чрҐхы№эю эґцэю юёҐртшҐ№ чряірёҐ№,
	-- ш эхтрцэю, ъҐю хую ґсшы - Ґюцх т√єюфшь, эшіхую эх фхыр 
	
	local keep_always = get_bool( obj:section(), "Spawn_Inventory_Item_Keep", false )
	if keep_always then
		return
	end 
	
    obj:iterate_inventory(
        function( obj, item )
            if strposx( item:section(), "mutant_" ) then
                local sobj = alife():object( item:id() )
                if sobj then alife():release( sobj ) end
            end
        end,
        obj
    )
end