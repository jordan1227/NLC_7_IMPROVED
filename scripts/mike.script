function gg_on_spot(point)
	-- ďĺđĺíîń â íóćíîĺ ěĺńňî čç đĺńňđčęňîđŕ ďîńëĺ ďđîőîćäĺíč˙ âńĺő îňěĺňîę íŕ ęŕđňĺ č ďđč íŕëč÷čč ďđŕâčëüíîé ńáîđęč íŕ ďî˙ńĺ
	local info = "stancia_restr_"
	local go_on = true
	level.add_pp_effector("red_teleport.ppe", 1524, false)
	vergas_lib.s_play([[anomaly\anomaly_gravy_blast]])
	for i=1,6 do
		if not has_alife_info(info..i) then
			go_on = false
			break
		end
	end
	if not go_on then return end
	local z={101,396,411,340,104,252}
	local pos=db.actor:position()
	if (math.abs(math.floor(pos.z)-z[point])<=1 and sborka==true) then
		schedule.add("bum_teleport","mike.bum_teleport()",6500)
	end
end
function bum_teleport()
	level.add_pp_effector("teleport.ppe", 1527, false)
	db.actor:set_actor_position(vector():set(5.0570355,5.1950564,65.282631))
	for k,v in pairs(sak_inventory.belt_items) do
		if strpos(k,"af_unknown") then
			for i=1,#v do
				misc.release_obj(v[i])
			end
		end
	end
end

local mem=false
function gg_last_memory()
	-- ďîńëĺäíčĺ âîńďîěčíŕíč˙ ďđč ďđîďŕäŕíčč â đĺńňđčęňîđ
	if mem==false then
		local count=get_value("rem_count",0)
		if count<=9 then
			sak.send_tip(game.translate_string("gg_last_memory"),game.translate_string("st_memory_h"),1,20,"g_g","rememb","yellow")
			local character=math.floor((get_value("r_task_reward", 1)+get_value("x18_iq_check",1))/2)
			repeat
			local info="rem_"..tostring(character).."_"..tostring(count)
			db.actor:give_info_portion(info)
			count = count+1
			until count==10
		end
		mem=true
		set_value("rem_count",10)
	end
end

function art_new_collection()
  -- ďđîâĺđęŕ íóćíűő ŕđňîâ íŕ ďî˙ńĺ
	if db.actor:has_info("strelok_book") then
    if not sak.arts_operate then return end
		local sum = 0
		local delta = 10
		local arts_new = { 
				{"af_unknown_1_new",239},
				{"af_unknown_2_new",274},
				{"af_unknown_3_new",247},
				{"af_unknown_4_new",845},
				{"af_unknown_5_new",396},
				{"af_unknown_6_new",654},
				{"af_unknown_7_new",781},
				{"af_unknown_8_new",545},
				{"af_unknown_9_new",24},
				{"af_unknown_10_new",121},
				{"af_unknown_11_new",182},
				{"af_unknown_12_new",244},
				{"af_unknown_13_new",142},
				{"af_unknown_14_new",60},
				{"af_unknown_15_new",790},
				{"af_unknown_16_new",346},
				{"af_unknown_17_new",162},
				{"af_unknown_18_new",683},
				{"af_unknown_19_new",614},
				{"af_unknown_20_new",609},
				{"af_unknown_21_new",766},
				{"af_unknown_22_new",477},
				{"af_unknown_23_new",49},
				{"af_unknown_24_new",877},
				{"af_unknown_25_new",702},
				{"af_unknown_26_new",317},
				{"af_unknown_27_new",51},
				{"af_unknown_28_new",804},
				{"af_unknown_29_new",237},
				{"af_unknown_30_new",357},
				{"af_unknown_31_new",753}
				}
		for i=1,31 do
			if sak_inventory.belt_items[arts_new[i][1]] then
				sum=sum+arts_new[i][2]
			end
		end
		if (sum>(1600+delta) or sum<(1600-delta)) then
			sborka = false 
		else
			if not sborka then
				sak.send_tip(game.translate_string("art_new_collection"),game.translate_string("thinking_out_loud"),0,10,"artmod","rememb","green")
			end
			sborka = true
		end
	end
end

