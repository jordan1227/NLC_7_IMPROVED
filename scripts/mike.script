local tele_art_tbl = {"af_electra_sparkler","af_blood","af_vyvert"}
function u_agr_tele()
	local start_tele=false
	local obj_id,obj=-1,nil
	local bo = false
	local komp = false
	local r = get_value("r_treas_items", 1)
	for i,k in pairs(sak_inventory.belt_items) do
		if strpos(i,"af_compass",1,true) and not strposx(i,"dyn6d") then
			komp = true
			obj_id=k[1]
			obj= g_sim:object(obj_id)
			start_tele=true
			break
		elseif strpos(i,tele_art_tbl[r],1,true) and not strposx(i,"dyn6d") and has_alife_info("first_remember_art"..r) then 
			bo = true
			obj_id=k[1]
			obj= g_sim:object(obj_id)
			start_tele=true
			break
		end
	end
	if obj==nil then
		return
	end
	if sak.arts_operate and start_tele then
		if komp then
			local sec = obj:section_name()
			local dyn = tonumber( string.sub(sec,-2,-2) )
			if dyn == 1 then
				dyn = 6
			else
				dyn = dyn - 1
			end
			local new_sec = string.sub(sec,1,-3)..dyn..'d'
			item_params.set_obj_section(obj.id, new_sec)
		elseif bo then
			local pk = get_netpk(obj,1)
			local data = pk:get()
			local cond=data.condition+0.0004
			if cond>=1 then
				cond=0.9999
			end
			local cond1=math.floor(cond*100)
			if cond1>= 36 then
				local new_cond = (cond1 - 20) / 100
				params.obj_condition(client_obj(obj.id):id(),new_cond)
				data.condition = new_cond
				pk:set(data)
			else
				misc.release_obj(obj)
			end
		end
		
		level.add_pp_effector("blink.ppe", 234, false)
		level.add_pp_effector("teleport.ppe", 2006, false)
		sak.eff_vodka()
		if bo then
			local dir=patrol("klyk_teleport"):point(0):sub(patrol("klyk_teleport"):point(0))
			db.actor:set_actor_position(patrol("klyk_teleport"):point(0))
			db.actor:set_actor_direction(-dir:getH())
		elseif komp then
			db.actor:set_actor_position(patrol("agru_tele_aver"):point(0))
		end
	end
end

