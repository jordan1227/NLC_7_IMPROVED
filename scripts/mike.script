--new_petruha_artmod_121
function zapiska_petruha_have()
	return sak.have_items_count("zapiska_petruha",1)~=false
end
function zapiska_petruha_not_have()
	return not zapiska_petruha_have()
end
function zapiska_petruha_give()
	sak_inventory.release_actor_items("zapiska_petruha",1)
end

function petruha_friend_dlg()
	return ( has_alife_info("esc_petruha_toz_start") or has_alife_info("volk_gonec_start") ) and not has_alife_info("info_zapiska_petruha")
end

function petruha_friend_spawn()
	local petruha_dsc_ids = {}
	local tbl = {{434.921539,-0.218192,143.466842,962239,4158},{428.454711,-0.215604,141.698272,952183,4158},{427.335418,0.109944,138.424346,949930,4158}}
	for i=1,3 do
		local point=tbl[i]
		local obj=alife():create("dsc_bandit_zasada_"..i,sak.v3f(point[1],point[2],point[3]),point[4],point[5])
		table.insert(petruha_dsc_ids,obj.id)
	end
	local trup=sak.create_corpse("trup_petruha_friend",vector():set(433.207336,-0.216671,138.102294),4158,960056,9819)
	misc.spawn_to("zapiska_petruha", trup)
	amk.spawn_item("arc_art_box_8basic",vector():set(433.207336,-0.216671,138.102294),4158,960056)
	local shron = g_sim:object("dsc_inventory_box_1"..lua_random(7,8))
	if shron then
		local bm = g_sim:create("wpn_bm16_full", shron.position, shron.m_level_vertex_id, shron.m_game_vertex_id, shron.id)
		if bm then
			params.post_cond_check(bm.id,0.6)
			set_value("petruha_dsc_bm", bm.id)
		end
		g_sim:create("ammo_12x70_buck", shron.position, shron.m_level_vertex_id, shron.m_game_vertex_id, shron.id)
		g_sim:create("ammo_12x70_buck", shron.position, shron.m_level_vertex_id, shron.m_game_vertex_id, shron.id)
		g_sim:create("ammo_12x70_buck", shron.position, shron.m_level_vertex_id, shron.m_game_vertex_id, shron.id)
		level.map_add_object_spot_ser(shron.id,"crlc_big_treasure0","?")
	end
	set_value("petruha_dsc_ids", petruha_dsc_ids)
end

function petruha_friend_off()
	if has_alife_info("info_zapiska_petruha_done") or has_alife_info("volk_gonec_done") then 
		return
	end
	local tbl = get_value("petruha_dsc_ids", {})
	for i=1,#tbl do
		local obj = g_sim:object(tbl[i])
		if obj and IsStalker(obj) and obj.alive and obj:alive() then
			misc.release_obj(tbl[i])
		end
	end
	local trup = g_sim:story_object(9819)
	if trup then
		misc.release_obj(trup.id)
	end
	if not has_alife_info("info_zapiska_petruha") then
		petruha_friend_bm_off()
	end
	remove_value("petruha_dsc_ids")
end
function petruha_friend_bm_off()
	local bm_id = get_value("petruha_dsc_bm")
	if bm_id ~= nil then
		local bm = g_sim:object(bm_id)
		if bm and bm.section_name and bm:section_name() == "wpn_bm16_full" and bm.parent_id and bm.parent_id ~= 0 and bm.parent_id ~= BAD_OBJ_ID then
			misc.release_obj(bm.id)
			-- log2("petruha_friend_bm_off executed")
		end
		remove_value("petruha_dsc_bm")
	end
end

function lukash_vasilev_go()
	if db.actor:has_info("assistant_bar") or db.actor:has_info("radar_on") then
		return true
	else
		return false
	end
end