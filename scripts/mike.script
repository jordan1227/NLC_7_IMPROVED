	give_n_caps(1)
end
function gg_4_caps_have()
	return gg_n_caps_have(4)
end
function give_4_caps()
	give_n_caps(4)
end

function gg_n_caps_have(n)
	local amount=0
	for a=1, #sak_dialog.table_capsule do
		for i,k in pairs(sak_inventory.rucksack) do
			if strpos(i, sak_dialog.table_capsule[a],1,true) then
				local kolvo = #k
				amount=amount+kolvo
			end
		end
	end
	if amount>=n then return true end
end
function give_n_caps(n)
	local amount
	local art_kol=n
	for a=1, #sak_dialog.table_capsule do
		amount=0
		for i,k in pairs(sak_inventory.rucksack) do
			if strpos(i, sak_dialog.table_capsule[a],1,true) then
				local kolvo = #k
				for m=1,kolvo do
					if art_kol>0 then
						local obj=g_sim:object(k[m])
						if obj then
							g_sim:release(obj, true)
						end
						amount=amount+1
						art_kol=art_kol-1
					end
				end
			end
		end
		if amount~=0 then
			sak.relocate_item("out", sak_dialog.table_capsule[a], amount)
		end
	end
end

