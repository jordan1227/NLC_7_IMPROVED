function mayatnik_aver_ready()
	if not has_alife_info("mayatnik_aver_ready_info") then
		sak.send_tip(game.translate_string("mayatnik_ready"),game.translate_string("thinking_out_loud"),2,12,"g_g","rememb","yellow")
		db.actor:disable_info_portion("mayatnik_aver_start_info")
		if level.name() == 'aver' then
			add_mayatnik_aver()
			db.actor:give_info_portion("mayatnik_aver_info")
		end
		db.actor:give_info_portion("mayatnik_aver_ready_info")
	end  
end

