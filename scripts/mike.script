local no_tele_msg = false
function gen_tele()
	local tbl = get_value("lc_history", {})
	local count = 0
	for i, lvl in ipairs(tbl) do
		if lvl=="l11_pripyat" then
			count = count + 1
		end
	end
	local obj_id,obj=-1,nil
	for i,k in pairs(sak_inventory.belt_items) do
		if strpos(i,"af_compass_",1,true) and not strposx(i,"dyn6d") then
			obj_id=k[1]
			obj= g_sim:object(obj_id)
			break
		end
	end
	if obj==nil then
		return
	end
	if sak.arts_operate then
		if count == 0 then
			if not no_tele_msg then
				sak.send_tip(game.translate_string("gen_tele"),game.translate_string("thinking_out_loud"),1,10,"g_g","sak","yellow")
				no_tele_msg = true
			end
			return
		end
		local sec = obj:section_name()
		local dyn = tonumber( string.sub(sec,-2,-2) )
		if dyn == 1 then
			dyn = 6
		else
			dyn = dyn - 1
		end
		local new_sec = string.sub(sec,1,-3)..dyn..'d'
		item_params.set_obj_section(obj.id, new_sec)
		level.add_pp_effector("blink.ppe", 234, false)
		level.add_pp_effector("teleport.ppe", 2006, false)
		sak.eff_vodka()
		db.actor:set_actor_position(vector():set(-230.58,50.04,-33.14))
	end
end

