	local obj2 = g_sim:story_object(story_ids.exit_to_rostok_01)
    if obj1 then
		level.map_add_object_spot_ser(obj1.id, "level_changer_self", "to_yantar")
	end
    if obj2 then
		level.map_add_object_spot_ser(obj2.id, "level_changer_self", "to_rostok")
	end	
end
