function timer_takeup()
	local i = get_value("klyk_once")
	if i and i == 1 then
		return
	end
	timers.start_timer("timer_takeup",0,0,15,"mike.timer_takeup_end()")
end

function timer_takeup_end()
	sleep_manager.slip_mayat()
end

function takeup_mayatnik(lvl)
	local l = lvl or level.name()
	if l=="aver" then
		local pos=db.actor:position()
		if (pos.x>320 and pos.x<361) and (pos.z>-41 and pos.z<-10) then
			timer_takeup()
			local id = get_value("mayatnik_aver")
			local go_on = false
			if id ~= nil then
				local mayat = server_obj(id)
				if mayat and mayat:section_name() == "af_mayatnik_capsule" and mayat.parent_id == 0 then
					go_on = true
				end
			end
			if go_on then
				db.actor:disable_info_portion("mayatnik_aver_ready_info")
				db.actor:disable_info_portion("mayatnik_aver_info")
				remove_value("mayatnik_aver")
			end
		end
	end  
	if l=="l11_pripyat" then
		local pos=db.actor:position()
		if (pos.x>15 and pos.x<45) and (pos.z>340 and pos.z<370) then
			timer_takeup()
			local id = get_value("mayatnik_prip")
			local go_on = false
			if id ~= nil then
				local mayat = server_obj(id)
				if mayat and mayat:section_name() == "af_mayatnik_capsule" and mayat.parent_id == 0 then
					go_on = true
				end
			end
			if go_on then
				db.actor:disable_info_portion("mayatnik_prip_ready_info")
				db.actor:disable_info_portion("mayatnik_prip_info")
				remove_value("mayatnik_prip")
			end
		end
	end
end

