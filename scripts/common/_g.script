function change_all_af_effects( af )
 local af_obj = af:get_artefact()

for _, k in ipairs({
    "bleeding_restore_speed",
    "health_restore_speed",
    "power_restore_speed",
    "satiety_restore_speed",
--   "psy_health_restore_speed",
    "radiation_restore_speed",
  }) do
  
   if k == "radiation_restore_speed" then 
   -- îáđŕáŕňűâŕĺňń˙ ŇÎËÜĘÎ âűâîä đŕäčŕöčč (îňđčö.çíŕ÷ĺíčĺ)  
          if  af_obj[ k ]< 0 then 
          af_obj[ k ] = af_obj[ k ]*af:condition()
		  ODS( string.format( 
		      "dsh changed property type = %s: value = %s", k, tostring(af_obj[ k ])
			   ))
		  end
   else 
   -- îáđŕáŕňűâŕţňń˙ ŇÎËÜĘÎ ďîëîć.çíŕ÷ĺíč˙  - âîńńňŕíŕâëčâŕţůčĺ
          if  af_obj[ k ]> 0 then
            af_obj[ k ] = af_obj[ k ]*af:condition()
			ODS( string.format( 
		      "dsh changed property type = %s: value = %s", k, tostring(af_obj[ k ])
			   ))
		  end   
	end	  
end  -- end FOR DO

  local af_imm = af.immunities
  for _, k in ipairs({
    "chemical_burn_immunity",
    "burn_immunity",
    "explosion_immunity",
    "fire_wound_immunity",
    "radiation_immunity",
    "shock_immunity",
    "strike_immunity",
    "telepatic_immunity",
    "wound_immunity",
  }) do
      if af_imm[ k ] <= 1 then 
        af_imm[ k ] = 1 - ( 1 - af_imm[k] ) * af:condition()
		--[[ODS( string.format( 
		      "dsh changed immunity type = %s: value = %s", k, tostring(af_imm[ k ])
			  )) --]]
      end	
  end -- end FOR DO
  
end -- end proc change_all_af_effects

--==============================================================================================
-- Ěŕňĺěŕňč÷ĺńęč ďđŕâčëüíîĺ îęđóăëĺíčĺ. Đŕáîňŕĺň č äë˙ îňđčöŕňĺëüíűő ÷čńĺë.
function math.round(v)
	return (v>=0 and math.floor(v+0.5)) or math.ceil(v-0.5)
end

-- https://github.com/naxac/CP2_AddOn/blob/8d140d24aa042d283b3aa8b28f372d2e5a202c52/Game/gamedata/scripts/xr_extensions.script
-- âűđŕâíčâŕíčĺ çíŕ÷ĺíč˙ n â ďđĺäĺëű îň min äî max
math.clamp = function( n, min, max )
	if min > max then
		min, max = max, min
	end
	return ( n > max and max ) or ( n < min and min ) or n
end

function release_tbl(t)
  for i, o in pairs(t) do
    if type(o) == "userdata" then
      release(o)
    else
      release(i)
    end
  end
end

function release(o)
	if not o then return end

	if type(o) ~= "userdata" then -- id čëč name
		local o = g_sim:object(o)
		if o then g_sim:release(o) end
	elseif o.section_name then -- ńĺđâĺđíűé îáúĺęň
		g_sim:release(o)
	else -- ęëčĺíňńęčé îáúĺęň
		local o = g_sim:object(o:id())
		if o then g_sim:release(o) end
	end
end

function disable_memory_object( npc, enemy )
  local be = npc:best_enemy()
  if be and be:id() == enemy:id() and xr_wounded.is_wounded( enemy ) then
    return
  end
  npc:enable_memory_object( enemy, false )
end

function enable_memory_object( npc, enemy )
  npc:enable_memory_object( enemy, true )
end

function set_outfit_additional_inventory_weight(obj, val)
	obj:set_additional_max_walk_weight(val)
end

function set_outfit_additional_inventory_weight2(obj, val)
	obj:set_additional_max_weight(val)
end

function set_default_outfit_additional_inventory_weight(obj)
	local val = sys_ini:r_float(obj:section(), "additional_inventory_weight")
	obj:set_additional_max_walk_weight(val)
end

function set_default_outfit_additional_inventory_weight2(obj)
	local val = sys_ini:r_float(obj:section(), "additional_inventory_weight2")
	obj:set_additional_max_weight(val)
end

function is_obj_in_hide(obj)
	local rq = obj and level.ray_query(obj:position(), vector():set(0, 1, 0), 200, rq_target.rqtBoth, obj)
	return rq and rq.result
end

