function pack_args (...)
 local result = {}
 for i = 1, select("#", ...) do
   local v = select(i, ...)
   table.insert(result, v)
 end
 return result
end

--[=[]]
function lua_random(a,b)
  if a==nil then
  return math.random()
  elseif b==nil then
  return math.random(a)
  else
  -- return math.random(a,b+1)
  return math.random(a,b)
  end
end
--]=]

function lua_random(a,b)
  local crnd = CRandom()
  if a==nil then
  -- Ŕđăóěĺíňŕ íĺň: âĺđíóňü ÷čńëî ń ďëŕâŕţůĺé ňî÷ęîé čç číňĺđâŕëŕ [0, 1)
  return crnd:randF(0.0,1.0)
  elseif b==nil then
  -- Ňîëüęî ďĺđâűé ŕđăóěĺíň: âĺđíóňü ÷čńëî čç číňĺđâŕëŕ [1, a) ń a ÂĘËŢ×ČŇĹËÜÍÎ!
  local gen=crnd:randI(tonumber(a)+1)
  return gen>0 and gen or 1
  else
  -- Îáŕ ŕđăóěĺíňŕ: âĺđíóňü ÷čńëî čç číňĺđâŕëŕ [a, b) ń b ÂĘËŢ×ČŇĹËÜÍÎ!
    a,b=tonumber(a),tonumber(b)
    if a>b then -- Ĺńëč ńňŕđňîâîĺ ÷čńëî číňĺđâŕëŕ áîëüřĺ ęîíĺ÷íîăî, ňî íóćíî ďîěĺí˙ňü čő ěĺńňŕěč!
    return crnd:randI(b,a+1)
    else
    return crnd:randI(a,b+1)
    end
  end
end

