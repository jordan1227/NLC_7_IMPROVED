--=================================[Ôóíęöčč čç xrLuaFix]========================================
--Cđĺçŕňü ďĺđâîĺ "ńëîâî"
string.trim_w = function(s) return s:gsub("%s-(%S+)%s+", '', 1) end
--Ńđĺçŕňü ďđîáĺëű ńëĺâŕ
string.trim_l = function(s) return s:gsub("^%s+", '') end
--Ńđĺçŕňü ďđîáĺëű ńďđŕâŕ
string.trim_r = function(s) return s:gsub("%s*$", '') end
--Ńđĺçŕňü ďđîáĺëű ńëĺâŕ č ńďđŕâŕ
string.trim   = function(s) return s:match( "^%s*(.*%S)" ) or "" end
------------------------------------------------------------------------------------------------
--Âîçâđŕůŕĺň ęîë-âî ýëĺěĺíňîâ â ňŕáëčöĺ. Äë˙ ěŕńńčâîâ íŕäî čńďîëüçîâŕňü îďĺđŕňîđ #.
table.size = function(t)
	local size = 0
	for _ in pairs(t) do size = size + 1 end
	return size
end
--Âîçâđŕůŕĺň ńëó÷ŕéíűé ýëĺěĺíň ěŕńńčâŕ. Äë˙ îáű÷íűő ňŕáëčö ňŕęîĺ äĺëŕňü íĺň íčęŕęîăî ńěűńëŕ. Â äâčćęĺ áűëî ńäĺëŕíî ęŕę-ňî ńňđŕííî.
table.random = function(t)
	return t[lua_random(#t)]
end
--Âîçâđŕůŕĺň ěŕńńčâ ń ęëţ÷ŕěč ňŕáëčöű
table.keys = function(t)
	local arr = {}
	for k, _ in pairs(t) do
		table.insert(arr, k)
	end
	return arr
end
--Âîçâđŕůŕĺň ěŕńńčâ ń çíŕ÷ĺíč˙ěč ňŕáëčöű
table.values = function(t)
	local arr = {}
	for _, v in pairs(t) do
		table.insert(arr, v)
	end
	return arr
end
--==============================================================================================
-- Âç˙ňî čç ŕääîíŕ Naxac'a
local to_ptrn = {
	[' '] = '%s',
	['.'] = '%.',
	['%'] = '%%',
	['*'] = '%*',
	['-'] = '%-'
}
string.explode = function( div,    -- đŕçäĺëčňĺëü
                           str,    -- ńňđîęŕ
                           clear ) -- îáđĺçŕňü ëč ďđîáĺëű ďî ęđŕ˙ě ńňđîę (false/true)
	local ret = {}
	for s in str:gmatch("([^"..(to_ptrn[div] or div).."]+)") do
		ret[#ret+1] = (clear and s:trim() or s)
	end
	return ret
end
--==============================================================================================
-- î÷čńňęŕ ńňđîęč îň "ëčříčő" ńčěâîëîâ (ďîëĺçíî ďđč đŕáîňĺ ń FS)
string.clear = function(str) --KRodin: ďîďđŕâčë ôóíęöčţ, ňĺďĺđü đŕáîňŕĺň.
	return str:gsub( '[/:<>|%*%?"\\]*', "" )
end
--==============================================================================================
-- Ôîđěŕňčđîâŕíčĺ ňĺęńňŕ ďî řčđčíĺ
-- http://www.amk-team.ru/forum/topic/13216-sborochnyy-ceh/?do=findComment&comment=959286
string.width = function(str, width, return_table, indent, paragrapf)
    indent    = indent    or 0
    paragrapf = paragrapf or 0
    width     = (width or 80) - indent

    local i = string.rep(' ', indent)
    local t = {}
    local line = string.rep(' ', paragrapf)

    for exp, word in str:gmatch('(%s-(%S+))') do
        if line == '' and #t ~= 0 then
            exp = word
        end

        local l_len = #line
        local len = l_len + #exp
        
        if len > width then
            t[#t+1], line = line, word
        else
            line = line .. exp
            if l_len == width then
                t[#t+1], line = line, ''
            end
        end
    end

    t[#t+1] = line

    if return_table then
        return t
    else
        return i .. table.concat(t, '\n' .. i)
    end
end
--==============================================================================================
function table.copy(tbl) --Âîçâđŕůŕĺň ęîďčţ ňŕáëčöű.
	local mt = getmetatable(tbl)
	local res = {}
	for k, v in pairs(tbl) do
		if type(k) == "table" then
			k = table.copy(k)
		end
		if type(v) == "table" then
			v = table.copy(v)
		end
		res[k] = v
	end
	setmetatable(res, mt)
	return res
end
--=================================[CUIScriptWnd Extension]=====================================
-- Âűçîâ îáű÷íűé, ęŕę č â AddCallback, íî ďîńëĺ ďîńëĺäíĺăî ŕđăóěĺíňŕ ěîćíî ďĺđĺäŕâŕňü ěíîćĺńňâî äîďîëíčňĺëüíűő.
function CUIScriptWnd:Connect(name, event, func, ...)
	local args = {...}
	return self:AddCallback( name, event, function() func(unpack(args)) end )
end
--==============================================================================================
local tostring_all_tbl = {
    ["table"] 	   = function(table, ind) --Đŕńďĺ÷ŕňęŕ ňŕáëčö
                        local res = "{" --Íŕ÷ŕëî
                        local end_res = ind and "\n"..ind.."}" or "\n}" --Ęîíĺö
                        local def_ind = "  " --Îňńňóď îň íŕ÷ŕëŕ ńňđîęč
                        ind = ind and ind..def_ind or def_ind --Äë˙ ęŕćäîé "ňŕáëčöű âíóňđč ňŕáëčöű" îňńňóď óâĺëč÷čâŕĺňń˙ â 2 đŕçŕ
                        for k, v in pairs(table) do
                            res = res.."\n"..ind.."["..tostring_all(k, ind).."] = "..tostring_all(v, ind)..","
                        end
                        return res..end_res
                    end,
    ["string"]    = function(v) return "'"..v.."'" end, --Ńňđîęč áĺđ¸ě â ęŕâű÷ęč. Ýňî íóćíî, ÷ňîáű ěîćíî áűëî îňëč÷čňü ńňđîęó "123" îň ÷čńëŕ 123, "nil" îň nil č ňä...
    ["number"]    = function(v) return tostring(v) end,
    ["boolean"]   = function(v) return tostring(v) end,
    ["nil"]       = function(v) return tostring(v) end,
    ["function"]  = function() return "[[FUNCTION]]" end, --Function, Userdata č Thread đŕńďĺ÷ŕňŕňü íĺëüç˙, ďđîńňî çŕěĺíčě íŕ ńňđîęč
    ["userdata"]  = function() return "[[USERDATA]]" end,
    ["thread"]    = function() return "[[THREAD]]" end,
}
--Ęîíâĺđňčđîâŕíčĺ ÷ĺăî óăîäíî â ńňđîęó. Čńďîëüçîâŕňü ňîëüęî äë˙ âűâîäŕ â ëîă!
function tostring_all(obj, ind) --ind - ńëóćĺáíűé ŕđăóěĺíň äë˙ đŕńďĺ÷ŕňęč "ňŕáëčö â ňŕáëčöŕő".
	return tostring_all_tbl[type(obj)](obj, ind)
end

dump_table = function(...) local args = {...} if #args > 0 and type(args[1]) == 'table' then log2("dumping %s:\n%s", args[2] or "table", tostring_all(args[1]) or {}) end end

--Ôóíęöčîíŕëüíŕ˙ îá¸đňęŕ äë˙ log1.
--Äĺëŕĺň äîďîëíčňĺëüíóţ đŕáîňó ďî ęîíâĺđňŕöčč ďŕđŕěĺňđîâ, ęîňîđűĺ íĺ âîńďđčíčěŕţňń˙ đîäíîé ôóíęöčĺé string.format.
--Ďŕđŕěĺňđű ěîćíî ďĺđĺäŕâŕňü ËŢÁÎĂÎ ŇČĎŔ! Â ńňđîęĺ ôîđěŕňŕ îíč äîëćíű ńňî˙ňü ęŕę %s (ďîňîěó, ÷ňî áóäóň ńęîíâĺđňčđîâŕíű â ńňđîęč).
function log3(fmt, ...)
	local args = {...}
	for i=1, #args do
		args[i] = tostring_all(args[i])
	end
	local res, msg = pcall(string.format, fmt, unpack(args))
	if not res then --Ĺńëč ďđîčçîřëŕ îřčáęŕ
		msg = "!!log3 failed: "..msg.."\n"..debug.traceback()
	end
	log1(msg)
end
--==============================================================================================
function abort(fmt, ...)
	log1("!!****************************[ABORT]*********************************")
	log1(debug.traceback())
	log3(fmt, ...)
	log1("!!********************************************************************")
	error(tostring(fmt))
end
function ASSERT(cond, ...)
	if not cond then
		abort(...)
	end
end
--==============================================================================================
function cmd(scmd, ...)
	ASSERT(scmd, "[cmd] scmd is a nil reference")
	local args = {...}
	if #args > 0 then
		scmd = scmd..' '..table.concat(args, ' ')
	end
	get_console():execute(scmd)
end
--==============================================================================================
log = function(...) --[[log1(...)]] end
