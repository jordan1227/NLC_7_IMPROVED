function local_hours()
  return math.floor(math.mod(game.time()/1000, 86400)/ 3600)
end

-- Ż ŕá¨â áâŕ®Şă ˘¨¤  "   , ˇˇˇ, ˘˘˘..." ˘ â ˇ«¨ćă {"   ", "ˇˇˇ", "˘˘˘", ... }
-- —ăŁ ©
function parse_names(s)
  local t = {}
  if s and type(s) == "string" then
    for name in string.gfind(s, "([%w_\\]+)%p*") do
      table.insert(t, name)
    end
    return t
  end
end


function parse_key_value(s)
    local t = {}
  if s==nil then
    return nil
  end
    local key, nam = nil, nil
    for name in string.gfind(s, "([%w_\\]+)%p*") do
    if key==nil then
      key = name
    else
      t[key] = name
      key = nil
    end
    end
    return t
end


-- Ż ŕá¨â áâŕ®Şă ˘¨¤  "n1, n2, n3..." ˘ â ˇ«¨ćă {n1, n2, n3, ... } Ł¤Ą n1, n2, n3... - ćĄ«ëĄ ç¨á« 
