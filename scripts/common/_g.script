end]]

-- Ż ŕá¨â áâŕ®Şă ˘¨¤  "n1, n2, n3..." ˘ â ˇ«¨ćă {n1, n2, n3, ... } Ł¤Ą n1, n2, n3... - ¤ŕ®ˇ­ëĄ ç¨á« 
function parse_nums(s)
  local t = {}

  for entry in string.gfind(s, "([%d%.]+)%,*") do
    table.insert(t, tonumber(entry))
  end

  return t
end

