	amk_anoms.spawn_anomaly("greedy_zone",sak.v3f(498.4777,-50.3591,-11.2008),1920,165796, shape, "static")
	amk_anoms.spawn_anomaly("greedy_zone",sak.v3f(504.044,-50.006,10.531),1920,168238,shape,"static")
	
	shape = {shtype=0,radius=2.5,center={0,0.5,0}}
	amk_anoms.spawn_anomaly("greedy_zone",sak.v3f(506.7563,-50.0328,-2.0918),1901,209938, shape, "static")
	amk_anoms.spawn_anomaly("amk_zone_mosquito_bald_strong",sak.v3f(-153.8413,0.4049,-314.1360),3239,6006, shape, "static")
	amk_anoms.spawn_anomaly("amk_zone_mosquito_bald_strong",sak.v3f(-149.8607,0.5639,-309.2581),3239,6751, shape, "static")
	
	local res = g_sim:create("space_restrictor",vector():set(-161.71,-0.9,-318.46),5153,3237)
    local custom = "[logic]\nactive = sr_idle@work\n[sr_idle@work]\non_actor_inside = %=sak.red_kill_zone2()%"
