-- fix_manager v. 1.2
-- Как пользоваться:
-- Названия выполняемых функций должны быть внесены в таблицу fixes_pack или fixes_pack_all (функции run_fixes) в ковычках, через запятую: "script_name.fix_name", "other_script_name.othter_fix_name", ...
-- Функции, выполненные из таблицы fixes_pack, сохраняются и повторно не вызываются, в отличии от ф-ий из fixes_pack_all, которые отрабатывают при каждой (пере)загрузке.
-- Для очистки сохранённого списка вызовов следует выполнить run_fixes с аргументом true, т.е. run_fixes(true).

function fix_mgr()
	run_fixes()
	fix_physic_objects()
	fix_npc_pos()
end

function run_fixes(clear)  
	local fixes_pack = {

	}
	
	local fixes_pack_all = {
	
	}
	
	if clear then
		log2("[ s_fixes ]: clearing saved vars")
		local t = {}
		set_value("fixes_done_tbl", t)
	end

	if #fixes_pack == 0 and #fixes_pack_all == 0 then 
		log2("[ s_fixes ]: fixes_pack is empty")
		return
	end
	
	if #fixes_pack_all > 0 then
		for _,fix_name in ipairs(fixes_pack_all) do
			log2("[ s_fixes ]: trying to apply fix = %s from [fixes_pack_all]", fix_name)
			loadstring(fix_name.."()")()
		end
	end
	
	if #fixes_pack > 0 then
		local fixes_done_tbl = get_value("fixes_done_tbl", {}) --- таблица для хранения названий всех фиксов
		local fix_tbl = {}
		for _, fix_name in pairs(fixes_pack) do
			if str_in_tab (fix_name,fixes_done_tbl) then
				log2("[ s_fixes ]: fix_name = %s has already been executed earlier --> ignoring", fix_name)
			else
				log2("[ s_fixes ]: trying to apply fix = %s", fix_name)
				loadstring(fix_name.."()")()
			end	
			table.insert(fix_tbl, fix_name)
		end
		set_value("fixes_done_tbl", fix_tbl)
	end
end

function new_game_spawn()
	log2("~~[%s.new_game_spawn]: done!", script_name())

	red_forest_eco_restr()
	red_forest_kill_restr()
	x18_kill_restr()
	spawn_agro_blocks()
	sanek_trade_res()
	x18_botan_book_spawn()
	ros_kill_restr()
	rad_greedys()
	bar_tp()
	-- bar_rad()
	mil_aver_lc_debris_spawn()
	garb_lv_rad()
	dsh.get_next_random("pda_drop_chance", 1, 1000)
	dsh.get_next_random("pda_status_rnd", 1, 10)
	dsh.get_next_random("pda_treas_rnd", 1, 100)
	dsh.get_next_random("sultan_weapon_treasure", 1, 3)
	dsh.get_next_random("generate_mutant_table", 1, 3)
	dsh.get_next_random("generate_mutant_request", 1, 5)
	dsh.get_next_random("generate_mutant_reward", 1, 5)
	amk.spawn_item("sleeping_pill",sak.v3f(-213.0025,-22.5375652313232,-126.3443),59,41279)
end

-- Фиксирование костей физ. объектов, смена позиции, если они не должны перемещаться
function fix_physic_objects()
	local pt = profile_timer()
	pt:start()

	local ph_objects = {
		-- {"bar_kletka_0001", "bone01", 161.990005493164, 0.100000001490116, 82.0299987792969, 42125, 1211} -- машина в баре на проходе к Лисапеду // Sn: этот объект теперь статик
	}

	for _, v in ipairs(ph_objects) do
		local sobj = server_obj(v[1])
		if sobj then
			local pk = get_netpk(sobj, 1)
			local data = pk:get()
			data.fixed_bones = v[2]
			pk:set(data)
			sobj:used_ai_locations(false)

			-- Manool: эти свойства доступны для записи
			-- Всё-таки позиция обновляется после свитча оффлайн-онлайн,
			-- если свойства перезаписать ПОСЛЕ перезаписи нетпакета
			sobj.position = vector():set(v[3], v[4], v[5])
			sobj.m_level_vertex_id = v[6]
			sobj.m_game_vertex_id = v[7]

			local ini = sobj:spawn_ini()
			ini.readonly = false
			ini:w_bool("collide", "ignore_static", true) -- игнорирование статики (если у какого-нибудь объекта его нет)
			sobj:save_spawn_ini()
		end
	end
	pt:stop()
	log2("[%s.fix_physic_objects]: Time: %.2fms (%s)", script_name(), pt:time() / 1000, pt:time())
end

function fix_npc_pos()
	local level_npc = {
		["l01_escape"] = {
			{"esc_vergas", -219.050003051758,-19.8999996185303,-168.899993896484, 34087, 47},
		},
		["l05_bar"] = {
			{"bar_lisaped", 164.899993896484, 0.25, 108.449996948242, 43119, 1187},
		},
		["l04_darkvalley"] = {
			{"val_bandit_trader", 28.7099990844727,4.53999996185303,-85.3899993896484, 209382, 1099},
		},
	}
	local npct = level_npc[level.name()]
	if not npct then return end
	for _, par in pairs(npct) do
		local sobj = alife():object(par[1])
		local targ_pos = vector():set(par[2], par[3], par[4])
		if sobj and sobj.level_name == level.name() then
			-- log2("[%s.fix_npc_pos]: [%s] has wrong pos: {%s, %s, %s} %s, %s",
			-- 	script_name(), sobj:name(), sobj.position.x, sobj.position.y, sobj.position.z, sobj.m_level_vertex_id, sobj.m_game_vertex_id
			-- )
			alife():teleport_object(sobj.id, targ_pos, par[5], par[6])
		end
	end
end

function mil_aver_lc_debris_spawn()
	local obj = amk.spawn_item("physic_object",sak.v3f(-31.4152,-7.9518,-56.8445),1592,276525)
	if obj then
		local pk = get_netpk(obj,1)
		local data = pk:get()
		data.visual_name = "new_item\\stena_yantar"
		data.physic_type=3
		data.fixed_bones="link"
		data.mass=250
		data.custom_data = "[collide]\nignore_static"
		pk:set(data)
		set_value("mil_aver_lc_debris",obj.id)
	end
end

function spawn_agro_blocks()
	local blocks = g_sim:create("physic_object",vector():set(-130.0938,0.3198,-139.0064),4,810)
	local pk, data
	if blocks then
		pk = get_netpk(blocks,1)
		data = pk:get()
		data.visual_name="physics\\prop_3bloks"
		data.mass=300
		data.fixed_bones = "bone01","bone02","bone03","bone04","bone05"
		pk:set(data)
	end
end

function red_forest_eco_restr()
	local res = g_sim:create("space_restrictor",vector():set(-152.3122,2.2915,-28.1060),6298,3240)
    local custom = "[logic]\nactive = sr_idle@idle\n[sr_idle@idle]\non_info = {+info_saharov_scientist_rf_start} sr_idle@work\n[sr_idle@work]\non_actor_inside = nil %+scientist_red_forest_dead =doc.red_corpses()%"
	kotovod_restrictors.rewrite_restrictor(res, custom, 10.0)
end

