function x18_botan_book_spawn()
	local t = {"x18_inventory_box", "x18_inventory_box_0002", "x18_inventory_box1"}
	local r = get_value("r_treas_items", 1)
	local box = server_obj(t[r])
	if box then
		misc.spawn_to("x18_botan_book",box)
	end
end

