  if health>1 then health=1 end
 
    if health <= 0 then
       --wprintf(" heath_add: %.3f += %.3f   actor killing from: \n %s ", healt, add, debug.traceback(" ", 2))
       -- health = 1
    end
 
  if health < 0 then health=0 end
 
  actor_params.cond_prop("health", health)
end
