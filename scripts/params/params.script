function set_direction(coor_x,coor_y,coor_z)
  local dir_d = vector()
  dir_d:set(coor_x, coor_y, coor_z)
  local h_rad = -dir_d:getH()
  local p_rad = -dir_d:getP()
  coord_params.camera_angles(h_rad, p_rad)
end

function outfit_weight_cond(item_in_slot_6,cond,fast)
	-- local nname = 'nil'
	-- if item_in_slot_6 then
		-- nname = item_in_slot_6:name()
	-- end
	-- log2("outfit_weight_cond called for [%s] cond [%.4f] - cond_old [%.4f] = [%.4f]", nname, cond, cond_old, math.abs(cond-cond_old))
	if item_in_slot_6~=nil then
		if math.abs(cond-cond_old)>0.05 or fast then
			local section=item_in_slot_6:section()
			actor_immunities_add(section,cond)
			-- texman.swap_sleeve(sleeve[section][1],sleeve[section][2],sleeve[section][3],sleeve[section][4])
			cond_old=cond
			-- log2("outfit_weight_cond called for armor [%s] with cond [%s] fast_mode [%s]", section, tostring(cond), tostring(fast))
		end
	else
		if math.abs(cond-cond_old)>0.05 then
			actor_immunities_add()
			cond_old=0.03
			-- texman.swap_sleeve("000","css","001","001")
			-- log2("outfit_weight_cond called for armor [nil] with cond [%s]", tostring(cond))
		end
	end  
end

local cache_out = {} -- Manool: кэширование параметров для оптимизации
local function get_out_prot(sect, par)
  if not cache_out[sect] then cache_out[sect] = {} end
  if not cache_out[sect][par] then
    local out_prot = string.gsub(par, "_immunity", "_protection")
    cache_out[sect][par] = sys_ini:r_float(sect, out_prot)
  end
  -- log3("cache_out = %s", cache_out)
  return cache_out[sect][par]
end

function actor_immunities_add(out_sect,key)
	local old_param = 0.6+tonumber(level.get_game_difficulty())*0.4
	for i,k in pairs(actor_params.immun_params) do
		if i~="unk_max_offset" then
			local new_param
			if out_sect then
				local param_out_prot = get_out_prot(out_sect, i)
				if i=="telepatic_immunity" then
					old_param=(old_param+0.2)
				end
				new_param = old_param*(1-(param_out_prot*key))
			else
				new_param = old_param*5
			end
			if i=="telepatic_immunity" then
				new_param=(new_param*sak.black_bonus)
			end
			actor_params.immun_prop (i, new_param)
		end
	end
end

