
local body_states = { -- флажки состояния тела актора
[1] = "fwd",
[2] = "back",
[4] = "l_strafe",
[8] = "r_strafe",
[16] = "crouch",
[17] = "crouch", -- crouch в движении
[32] = "accel",
[48] = "creep",
[49] = "creep", -- creep в движении
[64] = "turn",
[128] = "jump",
[256] = "fall",
[512] = "landing",
[1024] = "landing2",
[2048] = "climb",
[4096] = "sprint",
[8192] = "l_lookout",
[16384] = "r_lookout"
}

-- получения флагов состояния тела актора
function actor_body_state()
  local aobj = get_actor_obj()
  local body_state = aobj and body_states[ aobj:get_body_state() ]
  if body_state then
    return body_state
  else
    return ""
  end
end

