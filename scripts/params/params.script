function move_speed_set(val)
	if not sak.game_began then return end
	local v = get_value("block_sleep_menu", 0)
	if val == 0 then -- Sn: длЯ принудительной проверки действиЯ энергетика
		if v == 1 then
			db.actor.speed_multiplier = 1.2
		else
			db.actor.speed_multiplier = 1
		end
		arc_arts.check_artefact()
		return
	else
		if v == 1 then
			db.actor.speed_multiplier = 1.2
		else
			db.actor.speed_multiplier = val
		end
	end
	-- log2("move_speed_set: db.actor.speed_multiplier [%.2f]",db.actor.speed_multiplier)
end
